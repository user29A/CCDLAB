void Form1::UserDefinedShiftRotateMenuItem_DoubleClick(System::Object^  sender, System::EventArgs^  e)
{
	array<String^>^ FileNames;
	String^ dir = (String^)GetReg("L2EventListPath");

	if (!UVNUVTOFUV)
	{
		if (LinearRotationChck->Checked)
		{
			double xshift, yshift, rotation, xcenter, ycenter;
			try
			{
				xshift = ::Convert::ToDouble(UserXShiftTxt->Text);
				yshift = ::Convert::ToDouble(UserYShiftTxt->Text);
				xcenter = ::Convert::ToDouble(UserRotationXTxt->Text);
				ycenter = ::Convert::ToDouble(UserRotationYTxt->Text);
				rotation = ::Convert::ToDouble(UserRotationTxt->Text)*Math::PI/180;//degrees to radians
			}
			catch (...)
			{
				::MessageBox::Show("There seems to be something wrong with one of the shift/rotate values.  Please check and try again.","Error...");
				return;
			}
		}

		if (GeneralTransformChck->Checked)
		{
			double xshift, yshift, xcenter, ycenter, TCA, TCB, TCC, TCD;
			try
			{
				xshift = ::Convert::ToDouble(TransformShiftXTxt->Text);
				yshift = ::Convert::ToDouble(TransformShiftYTxt->Text);
				xcenter = ::Convert::ToDouble(TransformCenterXTxt->Text);
				ycenter = ::Convert::ToDouble(TransformCenterYTxt->Text);
				TCA = ::Convert::ToDouble(TransformCoefATxt->Text);
				TCB = ::Convert::ToDouble(TransformCoefBTxt->Text);
				TCC = ::Convert::ToDouble(TransformCoefCTxt->Text);
				TCD = ::Convert::ToDouble(TransformCoefDTxt->Text);
			}
			catch (...)
			{
				::MessageBox::Show("There seems to be something wrong with one of the shift/rotate values.  Please check and try again.","Error...");
				return;
			}
		}

		UVITMenu->HideDropDown();
		ShiftAndRotateMenuItem->HideDropDown();
		UserDefinedShiftRotateMenuItem->HideDropDown();

		OpenFileDialog^ dlg = gcnew OpenFileDialog();
		dlg->InitialDirectory = dir;
		dlg->Filter = "FITS (*.fits)|*.fits";
		dlg->Multiselect = true;
		dlg->Title = "Select the Centroid INTEGERS List (_XYInts_List)";
		if (dlg->ShowDialog() != ::DialogResult::OK)
			return;

		FileNames = dlg->FileNames;
	}
	else
	{
		FileNames = UVNUVTOFUVFILES;
		UVNUVTOFUV = false;
	}
		
	
	String^ IntsFile = FileNames[0];
	int ind = IntsFile->LastIndexOf("\\");
	dir = IntsFile->Substring(0,ind);
	SetReg("L2EventListPath",dir);

	Form1::Enabled = false;
	WAITBAR = gcnew JPWaitBar::WaitBar();
	WAITBAR->ProgressBar->Maximum = FileNames->Length;
	WAITBAR->Text = "Transforming centroid list(s)...";
	UVRotationWrkr->RunWorkerAsync(FileNames);
	WAITBAR->ShowDialog();

}

void Form1::UVRotationWrkr_DoWork(System::Object^  sender, System::ComponentModel::DoWorkEventArgs^  e)
{
	array<String^>^ IntsFiles = (array<String^>^)e->Argument;

	for (int wrkri = 0; wrkri < IntsFiles->Length; wrkri++)
	{
		if (WAITBAR->DialogResult == ::DialogResult::Cancel)
			return;
		UVRotationWrkr->ReportProgress(wrkri);

		String^ IntsFile = IntsFiles[wrkri];


		if (LinearRotationChck->Checked)
		{
			double xshift, yshift, rotation, xcenter, ycenter;
			xshift = ::Convert::ToDouble(UserXShiftTxt->Text);
			yshift = ::Convert::ToDouble(UserYShiftTxt->Text);
			xcenter = ::Convert::ToDouble(UserRotationXTxt->Text);
			ycenter = ::Convert::ToDouble(UserRotationYTxt->Text);
			rotation = ::Convert::ToDouble(UserRotationTxt->Text)*Math::PI/180;//degrees to radians

			String^ FracFile = IntsFile->Replace("Ints","Frac");

			JPFits::FitsFile^ FracFits = gcnew JPFits::FitsFile(FracFile,nullptr,true,true,false);
			JPFits::FitsFile^ IntsFits = gcnew JPFits::FitsFile(IntsFile,nullptr,true,true,false);
			int NPts = FracFits->Height;

			bool horzflip = FlipHorizontalMenuItem->Checked;
			bool vertflip = FlipVerticalMenuItem->Checked;
			double x, y, xprime, yprime;
			int fracx, intsx, fracy, intsy;
			::Random^ r = gcnew Random();
			try
			{
			//#pragma omp parallel for private(x, y, xprime, yprime, fracx, intsx, fracy, intsy, r)
			for (int j = 0; j < NPts; j++)
			{
				x = (IntsFits->Image[0,j] + FracFits->Image[0,j] + 16) + r->NextDouble();//must add 16 to fractionals
				y = (IntsFits->Image[1,j] + FracFits->Image[1,j] + 16) + r->NextDouble();//and put the centroid somewhere within the 1/32 bin

				if (horzflip)
					x = 511*32 - x;
				if (vertflip)
					y = 511*32 - y;

				xprime = (x - xcenter*32)*Math::Cos(rotation) - (y - ycenter*32)*Math::Sin(rotation) + xcenter*32 + xshift*32;
				yprime = (x - xcenter*32)*Math::Sin(rotation) + (y - ycenter*32)*Math::Cos(rotation) + ycenter*32 + yshift*32;

				//now need to split out integer and decimal parts back into their own lists...
				intsx = Math::DivRem(int(xprime),32,fracx)*32;
				fracx -= 16;//reset frac to be from -16
				intsy = Math::DivRem(int(yprime),32,fracy)*32;
				fracy -= 16;//reset frac to be from -16
				IntsFits->Image[0,j] = intsx;
				IntsFits->Image[1,j] = intsy;
				FracFits->Image[0,j] = fracx;
				FracFits->Image[1,j] = fracy;
			}
			}
			catch( Exception^ e)
			{
				MessageBox::Show(e->Data + "	" + e->InnerException + "	" + e->Message + "	" + e->Source + "	" + e->StackTrace + "	" + e->TargetSite);
			}
			

			if (horzflip)
			{
				IntsFits->AddKey("HORZFLIP","true","Image Flipped Horizontally",-1);
				FracFits->AddKey("HORZFLIP","true","Image Flipped Horizontally",-1);
			}
			if (vertflip)
			{
				IntsFits->AddKey("VERTFLIP","true","Image Flipped Vertically",-1);
				FracFits->AddKey("VERTFLIP","true","Image Flipped Vertically",-1);
			}
			if (xshift != 0)
			{
				IntsFits->AddKey("XSHIFT",xshift.ToString(),"Centroids X-Shift",-1);
				FracFits->AddKey("XSHIFT",xshift.ToString(),"Centroids X-Shift",-1);
			}
			if (yshift != 0)
			{
				IntsFits->AddKey("YSHIFT",yshift.ToString(),"Centroids Y-Shift",-1);
				FracFits->AddKey("YSHIFT",yshift.ToString(),"Centroids Y-Shift",-1);
			}
			if (rotation != 0)
			{
				IntsFits->AddKey("ROTATN",rotation.ToString(),"Centroids Rotation Angle",-1);
				FracFits->AddKey("ROTATN",rotation.ToString(),"Centroids Rotation Angle",-1);
			}

			IntsFile = IntsFile->Insert(IntsFile->LastIndexOf("."),"_FSRR");
			IntsFits->WriteFile(IntsFile,::TypeCode::Int16);
			FracFile = FracFile->Insert(FracFile->LastIndexOf("."),"_FSRR");
			FracFits->WriteFile(FracFile,::TypeCode::Int16);
		}

		if (GeneralTransformChck->Checked)
		{
			double xshift, yshift, xcenter, ycenter, TCA, TCB, TCC, TCD;
			xshift = ::Convert::ToDouble(TransformShiftXTxt->Text);
			yshift = ::Convert::ToDouble(TransformShiftYTxt->Text);
			xcenter = ::Convert::ToDouble(TransformCenterXTxt->Text);
			ycenter = ::Convert::ToDouble(TransformCenterYTxt->Text);
			TCA = ::Convert::ToDouble(TransformCoefATxt->Text);
			TCB = ::Convert::ToDouble(TransformCoefBTxt->Text);
			TCC = ::Convert::ToDouble(TransformCoefCTxt->Text);
			TCD = ::Convert::ToDouble(TransformCoefDTxt->Text);
			
			String^ FracFile = IntsFile->Replace("Ints","Frac");

			JPFits::FitsFile^ IntsFits = gcnew JPFits::FitsFile(IntsFile,nullptr,true,true,false);
			JPFits::FitsFile^ FracFits = gcnew JPFits::FitsFile(FracFile,nullptr,true,true,false);
			int NPts = FracFits->Height;

			double x, y, xprime, yprime;
			int fracx, intsx, fracy, intsy;
			::Random^ r = gcnew Random();

			for (int j = 0; j < NPts; j++)
			{
				x = (IntsFits->Image[0,j] + FracFits->Image[0,j] + 16) + r->NextDouble();//must add 16 to fractionals
				y = (IntsFits->Image[1,j] + FracFits->Image[1,j] + 16) + r->NextDouble();//and put the centroid somewhere within the 1/32 bin

				xprime = (x - xcenter*32)*TCA + (y - ycenter*32)*TCB + xcenter*32 + xshift*32;
				yprime = (x - xcenter*32)*TCC + (y - ycenter*32)*TCD + ycenter*32 + yshift*32;

				//now need to split out integer and decimal parts back into their own lists...
				intsx = Math::DivRem(int(xprime),32,fracx)*32;
				fracx -= 16;//reset frac to be from -16
				intsy = Math::DivRem(int(yprime),32,fracy)*32;
				fracy -= 16;//reset frac to be from -16
				IntsFits->Image[0,j] = intsx;
				IntsFits->Image[1,j] = intsy;
				FracFits->Image[0,j] = fracx;
				FracFits->Image[1,j] = fracy;
			}
			//now give the shifted/rotated list a new name and save

			/*if (xshift != 0)
			{
				IntsFits->AddKey("XSHIFT",xshift.ToString(),"Centroids X-Shift",-1);
				FracFits->AddKey("XSHIFT",xshift.ToString(),"Centroids X-Shift",-1);
			}
			if (yshift != 0)
			{
				IntsFits->AddKey("YSHIFT",yshift.ToString(),"Centroids Y-Shift",-1);
				FracFits->AddKey("YSHIFT",yshift.ToString(),"Centroids Y-Shift",-1);
			}*/

			IntsFile = IntsFile->Insert(IntsFile->LastIndexOf("."),"_FSRG");
			IntsFits->WriteFile(IntsFile,::TypeCode::Int16);
			FracFile = FracFile->Insert(FracFile->LastIndexOf("."),"_FSRG");
			FracFits->WriteFile(FracFile,::TypeCode::Int16);
		}
	}
}

void Form1::UVRotationWrkr_ProgressChanged(System::Object^  sender, System::ComponentModel::ProgressChangedEventArgs^  e)
{
	WAITBAR->TextMsg->Text = "Transforming file " + (e->ProgressPercentage+1).ToString() + " of " + WAITBAR->ProgressBar->Maximum.ToString();
	WAITBAR->ProgressBar->Value = e->ProgressPercentage;
	WAITBAR->Refresh();//find all Update() and replace with Refresh()
}

void Form1::UVRotationWrkr_RunWorkerCompleted(System::Object^  sender, System::ComponentModel::RunWorkerCompletedEventArgs^  e)
{
	Form1::Enabled = true;

	if (WAITBAR->DialogResult != ::DialogResult::Cancel)
		::MessageBox::Show("Completed shifting/rotating the centroid list.");

	WAITBAR->Close();
}

void Form1::INTAtoINTADriftCorrectionMenuItem_Click(System::Object^  sender, System::EventArgs^  e)
{
	String^ dir = (String^)GetReg("L2EventListPath");
	OpenFileDialog^ dlg = gcnew OpenFileDialog();
	dlg->InitialDirectory = dir;
	dlg->Filter = "FITS (*.fits)|*.fits";
	dlg->Multiselect = false;

	dlg->Title = "Select the DRIFT List (_XYDrift_List)";
	dlg->Filter = "DRIFT (*.drift)|*.drift";
	if (dlg->ShowDialog() != ::DialogResult::OK)
		return;
	String^ driftlistfile = dlg->FileName;
	dir = driftlistfile->Substring(0,driftlistfile->LastIndexOf("\\"));
	SetReg("L2EventListPath", dir);

	::FolderBrowserDialog^ fdlg = gcnew FolderBrowserDialog();
	fdlg->SelectedPath = dir;
	fdlg->Description = "Select the folder of the INT-mode *.fits image files to be drift corrected...";
	if (fdlg->ShowDialog() == ::DialogResult::Cancel)
		return;
	array<String^>^ filelist = Directory::GetFiles(fdlg->SelectedPath,"*.fits",::SearchOption::TopDirectoryOnly);
	if (filelist->Length == 0)
	{
		::MessageBox::Show("No files found in that directory.","Error");
		return;
	}
	SetReg("FolderBrowserPath",fdlg->SelectedPath);

	array<double,2>^ drifts = FitsFile::ReadImageArrayOnly(driftlistfile,nullptr);
	if (filelist->Length != drifts->GetLength(1))
	{
		MessageBox::Show("Number of drift measurements not equal to number of files in the directory.  Check your work.","Error...");
		return;
	}

	String^ savepath = fdlg->SelectedPath + "\\" + "de-drifted";
	Directory::CreateDirectory(savepath);
	SetReg("FolderBrowserPath",savepath);

	array<Object^>^ arg = gcnew array<Object^>(3);
	arg[0] = (Object^)driftlistfile;
	arg[1] = (Object^)fdlg->SelectedPath;
	arg[2] = (Object^)savepath;
	Form1::Enabled = false;
	WAITBAR = gcnew JPWaitBar::WaitBar();
	WAITBAR->ProgressBar->Maximum = 100;
	WAITBAR->DialogResult = ::DialogResult::OK;
	WAITBAR->Text = "Applying Drift Correction...";
	INTAtoINTAapplyDriftWrkr->RunWorkerAsync(arg);
	WAITBAR->Show();
}

void Form1::INTAtoINTAapplyDriftWrkr_DoWork(System::Object^  sender, System::ComponentModel::DoWorkEventArgs^  e)
{
	array<Object^>^ arg = (array<Object^>^)e->Argument;
	String^ driftlistfile = (String^)arg[0];
	String^ driftlistpath = (String^)arg[1];
	String^ savepath      = (String^)arg[2];

	array<double,2>^ drifts = FitsFile::ReadImageArrayOnly(driftlistfile,nullptr);
	array<String^>^ filelist = Directory::GetFiles(driftlistpath,"*.fits",::SearchOption::TopDirectoryOnly);

	for (int i = 0; i < filelist->Length; i++)
	{
		if (WAITBAR->DialogResult == ::DialogResult::Cancel)
			return;
		INTAtoINTAapplyDriftWrkr->ReportProgress(100*i/filelist->Length);

		FitsFile^ fits = gcnew FitsFile(filelist[i],nullptr,true,true,false);
		fits->SetImage(JPMath::ShiftArrayInt(fits->Image,-int(drifts[1,i])/32,int(drifts[2,i])/32),false);//or round instead of int?
		String^ name = savepath + "\\" + fits->FileName;
		name = name->Replace(".fits","_deDrift.fits");
		fits->WriteFile(name,::TypeCode::Int16);
	}
}

void Form1::INTAtoINTAapplyDriftWrkr_ProgressChanged(System::Object^  sender, System::ComponentModel::ProgressChangedEventArgs^  e)
{
	WAITBAR->ProgressBar->Value = e->ProgressPercentage;
	WAITBAR->TextMsg->Text = String::Concat("Completed: ",e->ProgressPercentage,"%");
	WAITBAR->Refresh();//find all Update() and replace with Refresh()
}

void Form1::INTAtoINTAapplyDriftWrkr_RunWorkerCompleted(System::Object^  sender, System::ComponentModel::RunWorkerCompletedEventArgs^  e)
{
	WAITBAR->Close();
	Form1::Enabled = true;
	Form1::Focus();

	if (WAITBAR->DialogResult == ::DialogResult::Cancel)
		return;

	::MessageBox::Show("Completed drift-correcting the INT-mode images.");
}

void Form1::UVGeneralRegistrationMenuItem_Click(System::Object^  sender, System::EventArgs^  e)
{
	if (!UVREGISTRATION)
	{
		UVITMenu->HideDropDown();
		UVGeneralRegistrationMenuItem->HideDropDown();

		String^ dir = (String^)GetReg("L2EventListPath");
		OpenFileDialog^ dlg = gcnew OpenFileDialog();
		dlg->InitialDirectory = dir;
		dlg->Filter = "FITS (*.fits)|*.fits";
		dlg->Multiselect = true;
		dlg->Title = "Select the Centroid INTEGERS Lists (_XYInts_List)";
		if (dlg->ShowDialog() != ::DialogResult::OK)
			return;

		if (dlg->FileNames->Length == 1)
		{
			::MessageBox::Show("Need to select more than 1 file for image registration...", "Error...");
			return;
		}

		dir = dlg->FileNames[0]->Substring(0,dlg->FileNames[0]->LastIndexOf("\\"));
		dir = dir->Substring(0,dir->LastIndexOf("\\"));
		SetReg("L2EventListPath", dir);
		SetReg("OpenFilesPath", dir);

		if (MessageBox::Show("Please select point sources (LEFT-CLICK) which stay within the field of view for the duration of the image set!  RIGHT-CLICK when done.","Centroid List Registration...",::MessageBoxButtons::OKCancel) == ::DialogResult::Cancel)
			return;

		if (UVGeneralRegistrationResolutionDrop->SelectedIndex == 2)
			ListToImage4PixMenuItem->PerformClick();
		if (UVGeneralRegistrationResolutionDrop->SelectedIndex == 1)
			ListToImage2PixMenuItem->PerformClick();
		if (UVGeneralRegistrationResolutionDrop->SelectedIndex == 0)
			ListToImage1PixMenuItem->PerformClick();
		UVITMenu->HideDropDown();
		ConvertListToImgMenu->HideDropDown();

		IWLC = 1;
		ImageWindow->Cursor->Hide();
		EqualHWChck->Checked = true;
		HalfWidthXUpD->Value = UVLISTTOIMAGEPREC*10/2;
		FNDCOORDS = gcnew array<int,2>(1,2);//this is for plotting the local max point in the ROI
		FNDCOORDRECTS = gcnew array<Rectangle,1>(1);
		ShowFoundCoordsChck->Checked = true;//this is for plotting the local max point in the ROI
		MANREGCOORDS = gcnew array<int,2>(0,0);
		MANREGCOORDRECTS = gcnew array<Rectangle,1>(0);

		UVREGISTRATION = true;
		UVREGISTRATIONFILES = dlg->FileNames;
		UVREGISTRATIONFILESINDEX = 0;
		UVREGISTRATION_CENTROIDS = nullptr;
		UVCREATEIMAGEFILENAME = UVREGISTRATIONFILES[UVREGISTRATIONFILESINDEX];
		UVAutoDriftImageViewChck->Checked = true;
		UVCREATEIMAGENOW = true;

		ConvertListToImgMenu_Click(sender,e);
		return;
	}

	if (UVREGISTRATION && MANREGCOORDRECTS->Length == 0)//clicked out without any point selections
	{
		UVREGISTRATION = false;
		ShowFoundCoordsChck->Checked = false;
		ImageWindow->Cursor->Show();
		ImageWindow->Refresh();

		ListToImage8PixMenuItem->PerformClick();
		UVITMenu->HideDropDown();
		ConvertListToImgMenu->HideDropDown();

		return;
	}

	if (UVREGISTRATION && UVREGISTRATIONFILESINDEX < UVREGISTRATIONFILES->Length-1)
	{
		::DialogResult res = MessageBox::Show("Continue to image " + (UVREGISTRATIONFILESINDEX+2).ToString() + " of " + (UVREGISTRATIONFILES->Length).ToString() + "?","Centroid List Registration...",::MessageBoxButtons::YesNoCancel);
		
		if (res == ::DialogResult::Cancel)//stop registration
		{
			UVREGISTRATION = false;
			ShowFoundCoordsChck->Checked = false;//this is for plotting the local max point in the ROI
			ImageWindow->Cursor->Show();
			ImageWindow->Cursor = ::Cursors::Cross;
			ShowCursorBox->Checked = true;
			ImageWindow->Refresh();

			ListToImage8PixMenuItem->PerformClick();
			UVITMenu->HideDropDown();
			ConvertListToImgMenu->HideDropDown();

			return;
		}

		if (res == ::DialogResult::No)//keep moving points
			return;

		//else it is yes
		ShowFoundCoordsChck->Checked = false;//this is for plotting the local max point in the ROI...the selected MANREGCOORS are still plotted
		ShowCursorBox->Checked = false;
		ImageWindow->Cursor = ::Cursors::Hand;
		ImageWindow->Cursor->Show();

		UVREGISTRATION_ANCHOR_INDEX = ::Int32::MaxValue;
		UVREGISTRATION_TRANSLATE = true;
		UVREGISTRATION_ROTATION_INDEX = ::Int32::MaxValue;
		UVREGISTRATION_ROTATION_THETA = 0;

		UVREGISTRATIONFILESINDEX++;
		UVCREATEIMAGEFILENAME = UVREGISTRATIONFILES[UVREGISTRATIONFILESINDEX];
		UVCREATEIMAGENOW = true;
		ConvertListToImgMenu_Click(sender,e);
		return;
	}

	if (UVREGISTRATION && UVREGISTRATIONFILESINDEX == UVREGISTRATIONFILES->Length-1)//now compute the transformations and apply them to the centroid lists
	{
		UVREGISTRATION = false;
		ShowFoundCoordsChck->Checked = false;
		ShowCursorBox->Checked = true;
		ImageWindow->Cursor = ::Cursors::Cross;
		ImageWindow->Refresh();

		if (::MessageBox::Show("Determine and apply the registration tranformation(s)?", "Centroid Registration...", ::MessageBoxButtons::OKCancel) == ::DialogResult::Cancel)
			return;

		UVCONVERTLISTTOIMAGEBATCHFILES = gcnew array<String^>(UVREGISTRATIONFILES->Length);
		AUTOLOADIMAGESFILES = gcnew array<String^>(UVREGISTRATIONFILES->Length);

		Form1::Enabled = false;
		WAITBAR = gcnew JPWaitBar::WaitBar();
		WAITBAR->ProgressBar->Maximum = UVREGISTRATIONFILES->Length;
		WAITBAR->Text = "Registration...";
		WAITBAR->ProgressBar->Value = 1;
		WAITBAR->TextMsg->Text = "Wait a sec while I make a copy of the reference file...";
		UVRegistrationWrkr->RunWorkerAsync();
		WAITBAR->ShowDialog();
	}

}

void Form1::UVRegistrationWrkr_DoWork(System::Object^  sender, System::ComponentModel::DoWorkEventArgs^  e)
{
	try
	{
		String^ IntsFile = UVREGISTRATIONFILES[0];
		String^ FracFile = UVREGISTRATIONFILES[0]->Replace("Ints","Frac");
		::File::Copy(IntsFile, IntsFile->Insert(IntsFile->LastIndexOf("."),"_RGSTRD"), true);
		::File::SetLastWriteTime(IntsFile->Insert(IntsFile->LastIndexOf("."),"_RGSTRD"),::DateTime::Now);
		::File::Copy(FracFile, FracFile->Insert(FracFile->LastIndexOf("."),"_RGSTRD"), true);
		::File::SetLastWriteTime(FracFile->Insert(FracFile->LastIndexOf("."),"_RGSTRD"),::DateTime::Now);
		UVCONVERTLISTTOIMAGEBATCHFILES[0] = IntsFile->Insert(IntsFile->LastIndexOf("."),"_RGSTRD");

		array<double>^ x1 = gcnew array<double>(UVREGISTRATION_CENTROIDS->GetLength(1));
		array<double>^ x2 = gcnew array<double>(UVREGISTRATION_CENTROIDS->GetLength(1));
		array<double>^ y1 = gcnew array<double>(UVREGISTRATION_CENTROIDS->GetLength(1));
		array<double>^ y2 = gcnew array<double>(UVREGISTRATION_CENTROIDS->GetLength(1));
		array<double>^ P0 = gcnew array<double>(5){0,0,0,0,0};

		for (int j = 0; j < UVREGISTRATION_CENTROIDS->GetLength(1); j++)
		{
			x1[j] = UVREGISTRATION_CENTROIDS[0,j,0];
			y1[j] = UVREGISTRATION_CENTROIDS[0,j,1];
		}

		MLFit^ fit = gcnew MLFit();
		MWNumericArray^ mwx1 = gcnew MWNumericArray(x1);
		MWNumericArray^ mwy1 = gcnew MWNumericArray(y1);
		MWNumericArray^ mwx2;
		MWNumericArray^ mwy2;
		MWNumericArray^ mwP0 = gcnew MWNumericArray(P0);

		double x, y, xprime, yprime;
		int fracx, intsx, fracy, intsy;
		::Random^ r = gcnew Random();

		bool general_transformation = true;//if not general then linear rotation only

		for (int i = 1; i < UVREGISTRATIONFILES->Length; i++)
		{
			if (WAITBAR->DialogResult == ::DialogResult::Cancel)
				return;
			UVRegistrationWrkr->ReportProgress(i+1);

			IntsFile = UVREGISTRATIONFILES[i];
			FracFile = IntsFile->Replace("Ints","Frac");
			JPFits::FitsFile^ IntsFits = gcnew JPFits::FitsFile(IntsFile,nullptr,true,true,false);
			JPFits::FitsFile^ FracFits = gcnew JPFits::FitsFile(FracFile,nullptr,true,true,false);
			int NPts = FracFits->Height;

			for (int j = 0; j < UVREGISTRATION_CENTROIDS->GetLength(1); j++)
			{
				x2[j] = UVREGISTRATION_CENTROIDS[i,j,0];
				y2[j] = UVREGISTRATION_CENTROIDS[i,j,1];
			}

			if (x1->Length == 1)
			{
				for (int j = 0; j < NPts; j++)
				{
					x = (IntsFits->Image[0,j] + FracFits->Image[0,j] + 16) + r->NextDouble();//must add 16 to fractionals
					y = (IntsFits->Image[1,j] + FracFits->Image[1,j] + 16) + r->NextDouble();//and put the centroid somewhere within the 1/32 bin

					xprime = x - (x2[0] - x1[0])/double(UVLISTTOIMAGEPREC)*32;
					yprime = y - (y2[0] - y1[0])/double(UVLISTTOIMAGEPREC)*32;

					//now need to split out integer and decimal parts back into their own lists...
					intsx = Math::DivRem(int(xprime),32,fracx)*32;
					fracx -= 16;//reset frac to be from -16
					intsy = Math::DivRem(int(yprime),32,fracy)*32;
					fracy -= 16;//reset frac to be from -16
					IntsFits->Image[0,j] = intsx;
					IntsFits->Image[1,j] = intsy;
					FracFits->Image[0,j] = fracx;
					FracFits->Image[1,j] = fracy;
				}
			}

			if (x1->Length > 1)//then have 2-D points for rotation tranformation, else just single points for shifting
			{

				mwx2 = gcnew MWNumericArray(x2);
				mwy2 = gcnew MWNumericArray(y2);

				P0 = gcnew array<double>(5){UVREGISTRATION_THETAS[i],UVREGISTRATION_XCENTERS[i],UVREGISTRATION_YCENTERS[i],UVREGISTRATION_XSHIFTS[i],UVREGISTRATION_YSHIFTS[i]};
				mwP0 = gcnew MWNumericArray(P0);

				MWNumericArray^ mwRegFit = (MWNumericArray^)fit->RotnFlipSkwShiftFit(mwx1, mwx2, mwy1, mwy2, mwP0);
				array<double,2>^ P0fit = (array<double,2>^)mwRegFit->ToArray(MWArrayComponent::Real);

				double rotation = P0fit[0,0]*Math::PI/180;
				double xcenter =  P0fit[0,1];
				double ycenter =  P0fit[0,2];
				double xshift =   P0fit[0,3];
				double yshift =   P0fit[0,4];
				double TCA, TCB, TCC, TCD;

				//::MessageBox::Show(UVREGISTRATION_THETAS[i].ToString() + "	" + P0fit[0,0].ToString());

				if (general_transformation)
				{
					P0 = gcnew array<double>(8){Math::Cos(rotation), -Math::Sin(rotation), Math::Sin(rotation), Math::Cos(rotation), xcenter, ycenter, xshift, yshift};
					mwP0 = gcnew MWNumericArray(P0);
					mwRegFit = (MWNumericArray^)fit->RotnFlipSkwShiftFit(mwx1, mwx2, mwy1, mwy2, mwP0);
					P0fit = (array<double,2>^)mwRegFit->ToArray(MWArrayComponent::Real);

					TCA = P0fit[0,0];
					TCB = P0fit[0,1];
					TCC = P0fit[0,2];
					TCD = P0fit[0,3];
					xcenter =  P0fit[0,4];
					ycenter =  P0fit[0,5];
					xshift =   P0fit[0,6];
					yshift =   P0fit[0,7];
				}

				xcenter /= double(UVLISTTOIMAGEPREC);
				ycenter /= double(UVLISTTOIMAGEPREC);
				xshift  /= double(UVLISTTOIMAGEPREC);
				yshift  /= double(UVLISTTOIMAGEPREC);

				for (int j = 0; j < NPts; j++)
				{
					x = (IntsFits->Image[0,j] + FracFits->Image[0,j] + 16) + r->NextDouble();//must add 16 to fractionals
					y = (IntsFits->Image[1,j] + FracFits->Image[1,j] + 16) + r->NextDouble();//and put the centroid somewhere within the 1/32 bin

					if (!general_transformation)
					{
						xprime = (x - xcenter*32)*Math::Cos(rotation) - (y - ycenter*32)*Math::Sin(rotation) + xcenter*32 + xshift*32;
						yprime = (x - xcenter*32)*Math::Sin(rotation) + (y - ycenter*32)*Math::Cos(rotation) + ycenter*32 + yshift*32;
					}
					else
					{
						xprime = (x - xcenter*32)*TCA + (y - ycenter*32)*TCB + xcenter*32 + xshift*32;
						yprime = (x - xcenter*32)*TCC + (y - ycenter*32)*TCD + ycenter*32 + yshift*32;
					}

					//now need to split out integer and decimal parts back into their own lists...
					intsx = Math::DivRem(int(xprime),32,fracx)*32;
					fracx -= 16;//reset frac to be from -16
					intsy = Math::DivRem(int(yprime),32,fracy)*32;
					fracy -= 16;//reset frac to be from -16
					IntsFits->Image[0,j] = intsx;
					IntsFits->Image[1,j] = intsy;
					FracFits->Image[0,j] = fracx;
					FracFits->Image[1,j] = fracy;
				}
			}

			IntsFile = IntsFile->Insert(IntsFile->LastIndexOf("."),"_RGSTRD");
			IntsFits->WriteFile(IntsFile,::TypeCode::Int16);
			FracFile = FracFile->Insert(FracFile->LastIndexOf("."),"_RGSTRD");
			FracFits->WriteFile(FracFile,::TypeCode::Int16);

			UVCONVERTLISTTOIMAGEBATCHFILES[i] = IntsFile;
		}
	}
	catch (Exception^ e)
	{
		MessageBox::Show(e->Data + "	" + e->InnerException + "	" + e->Message + "	" + e->Source + "	" + e->StackTrace + "	" + e->TargetSite);
	}

	WAITBAR->DialogResult = ::DialogResult::OK;
}

void Form1::UVRegistrationWrkr_ProgressChanged(System::Object^  sender, System::ComponentModel::ProgressChangedEventArgs^  e)
{
	WAITBAR->ProgressBar->Value = e->ProgressPercentage;
	WAITBAR->TextMsg->Text = "Registering file " + e->ProgressPercentage.ToString() + " of " + WAITBAR->ProgressBar->Maximum.ToString();
	WAITBAR->Refresh();//find all Update() and replace with Refresh()
}

void Form1::UVRegistrationWrkr_RunWorkerCompleted(System::Object^  sender, System::ComponentModel::RunWorkerCompletedEventArgs^  e)
{
	Form1::Enabled = true;
	ListToImage8PixMenuItem->PerformClick();
	UVITMenu->HideDropDown();
	ConvertListToImgMenu->HideDropDown();

	WAITBAR->Close();

	if (WAITBAR->DialogResult == ::DialogResult::Cancel)
		return;

	if (::MessageBox::Show("Completed registration of the centroid lists.  Would you like to convert them to images?","Images?",::MessageBoxButtons::OKCancel) == ::DialogResult::Cancel)
		return;

	UVCONVERTLISTTOIMAGEBATCH = true;
	WAITBAR = gcnew JPWaitBar::WaitBar();
	WAITBAR->ProgressBar->Maximum = UVCONVERTLISTTOIMAGEBATCHFILES->Length;
	WAITBAR->Text = "Creating images...";
	Form1::Enabled = false;
	UVConvertListToImgWrkr->RunWorkerAsync(UVCONVERTLISTTOIMAGEBATCHFILES);
	WAITBAR->ShowDialog();

}

void Form1::UVCombineCentroidListsMenuItem_Click(System::Object^  sender, System::EventArgs^  e)
{
	::OpenFileDialog^ ofd = gcnew ::OpenFileDialog();
	ofd->Multiselect = true;
	String^ dir = (String^)GetReg("L2EventListPath");
	ofd->InitialDirectory = dir;
	ofd->Filter = "FITS (*.fits)|*.fits";
	ofd->Title = "Select the Centroid INTEGERS Lists (_XYInts_List)";

	if (ofd->ShowDialog() != ::DialogResult::OK)
		return;

	dir = ofd->FileNames[0]->Substring(0,ofd->FileNames[0]->LastIndexOf("\\"));
	dir = dir->Substring(0,dir->LastIndexOf("\\"));
	SetReg("L2EventListPath", dir);
	SetReg("OpenFilesPath", dir);

	Form1::Enabled = false;
	WAITBAR = gcnew JPWaitBar::WaitBar();
	WAITBAR->ProgressBar->Maximum = ofd->FileNames->Length;
	WAITBAR->Text = "Merge...";
	WAITBAR->ProgressBar->Value = 0;
	UVMergeCentroidListsWrkr->RunWorkerAsync(ofd->FileNames);
	WAITBAR->ShowDialog();
}

void Form1::UVMergeCentroidListsWrkr_DoWork(System::Object^  sender, System::ComponentModel::DoWorkEventArgs^  e)
{
	array<String^>^ filenames = (array<String^>^)e->Argument;

	String^ dir = filenames[0]->Substring(0,filenames[0]->LastIndexOf("\\"));
	dir = dir->Substring(0,dir->LastIndexOf("\\"));

	JPFits::FitsFile^ intsfits;
	JPFits::FitsFile^ fracfits;
	JPFits::FitsFile^ timefits;
	JPFits::FitsFile^ framefits;
	JPFits::FitsFile^ flatfits;
	JPFits::FitsFile^ HJDfits;
	JPFits::FitsFile^ mdMmfits;

	//first get the total number of centroids, and also the total time
	int N_centroids = 0;
	for (int i = 0; i < filenames->Length; i++)
	{
		intsfits = gcnew JPFits::FitsFile(filenames[i],nullptr,true,false,false);
		N_centroids += intsfits->Height;
	}

	//create the arrays for the cenrtoid lists (time list, frame list, flat list, XYInts list, XYFrac list
	/*array<unsigned __int32>^ mergedTimearray   = gcnew array<unsigned __int32>(N_centroids);
	array<unsigned __int16>^ mergedFramearray  = gcnew array<unsigned __int16>(N_centroids);*/
	array<unsigned __int32>^ newTimearray = gcnew array<unsigned __int32>(N_centroids);
	array<unsigned __int32>^ newFramearray = gcnew array<unsigned __int32>(N_centroids);//now has to be int32 because it won't roll over
	array<double>^			 mergedFlatarray   = gcnew array<double>(N_centroids);
	array<__int16,2>^		 mergedXYIntsarray = gcnew array<__int16,2>(2,N_centroids);
	array<__int16,2>^		 mergedXYFracarray = gcnew array<__int16,2>(2,N_centroids);
	array<double>^			 mergedHJDarray   = gcnew array<double>(N_centroids);
	array<__int16,2>^		 mergedmdMmarray = gcnew array<__int16,2>(2,N_centroids);

	//now run through the files and collect the centroid lists into the big list
	String^ intsfile;
	String^ fracfile;
	String^ timefile;
	String^ framefile;
	String^ flatfile;
	String^ HJDfile;
	String^ mdMmfile;

	double time_per_frame = 0;
	double time = 0;
	double frame = 0;
	double currtime = 0;
	double currframe = 0;
	newTimearray[0] = (unsigned __int32)time;
	newFramearray[0] = (unsigned __int32)frame;
	
	int index = -1;
	for (int i = 0; i < filenames->Length; i++)
	{
		if (WAITBAR->DialogResult == ::DialogResult::Cancel)
			return;
		UVMergeCentroidListsWrkr->ReportProgress(i);

		intsfile = filenames[i];
		fracfile = intsfile->Replace("Ints","Frac");

		timefile = intsfile->Remove(intsfile->IndexOf("XYInts")) + "TimeList.fits";
		String^ deDrift = "_deDrift";
		while (intsfile->Contains(deDrift))
		{
			timefile = timefile->Replace("TimeList","TimeList_deDrift");
			deDrift += "_deDrift";
		}

		framefile = timefile->Replace("Time","Frame");

		flatfile = timefile->Replace("Time","Flat");

		HJDfile = timefile->Replace("Time","HJD");

		mdMmfile = timefile->Replace("TimeList","XYmdMm_List");

		intsfits = gcnew JPFits::FitsFile(intsfile,nullptr,false,true,false);
		fracfits = gcnew JPFits::FitsFile(fracfile,nullptr,false,true,false);
		timefits = gcnew JPFits::FitsFile(timefile,nullptr,false,true,false);
		framefits = gcnew JPFits::FitsFile(framefile,nullptr,false,true,false);
		flatfits = gcnew JPFits::FitsFile(flatfile,nullptr,false,true,false);
		HJDfits = gcnew JPFits::FitsFile(HJDfile,nullptr,false,true,false);
		mdMmfits = gcnew JPFits::FitsFile(mdMmfile,nullptr,false,true,false);

		//there should be no roll-overs in the time or frame lists for each set, so do soemthing to gather the total number of frames and time by gathering
		//the start & end time & frame for each set etc
		//then the merged list requires an artificial time & frame list which reproduces the same total time & total frames of the sum of the sets...
		//in this case we dont even need to create a merged time and frame list from the data, just need to gather the total frames & time and then make the lists
		time_per_frame = (timefits->Image[0,intsfits->Height-1] - timefits->Image[0,0])/(framefits->Image[0,intsfits->Height-1] - framefits->Image[0,0]);
		currtime = timefits->Image[0,0];
		currframe = framefits->Image[0,0];

		for (int j = 0; j < intsfits->Height; j++)
		{
			index++;

			mergedXYIntsarray[0,index] = (__int16)intsfits->Image[0,j];
			mergedXYIntsarray[1,index] = (__int16)intsfits->Image[1,j];

			mergedXYFracarray[0,index] = (__int16)fracfits->Image[0,j];
			mergedXYFracarray[1,index] = (__int16)fracfits->Image[1,j];

			mergedmdMmarray[0,index] = (__int16)mdMmfits->Image[0,j];
			mergedmdMmarray[1,index] = (__int16)mdMmfits->Image[1,j];

			mergedFlatarray[index] = flatfits->Image[0,j];

			mergedHJDarray[index] = HJDfits->Image[0,j];

			/*mergedTimearray[index] = (unsigned __int32)timefits->Image[0,j];
			mergedFramearray[index] = (unsigned __int16)framefits->Image[0,j];*/

			if (timefits->Image[0,j] != currtime)//frame should change too...
			{
				if (framefits->Image[0,j] == currframe)
					::MessageBox::Show("Time changed but frame didn't...","Error...");

				currtime = timefits->Image[0,j];
				currframe = framefits->Image[0,j];

				double multiplier = 1;
				if (j != 0)
					multiplier = framefits->Image[0,j] - framefits->Image[0,j-1];
				if (j == 0)
					multiplier = framefits->Image[0,j] - 0 + 1;

				frame += multiplier;
				time += multiplier*time_per_frame;
			}

			newTimearray[index] = (unsigned __int32)time;
			newFramearray[index] = (unsigned __int32)frame;			
		}
	}

	intsfile = intsfile->Remove(intsfile->IndexOf("_XYInts")-15,15);
	intsfile = intsfile->Insert(intsfile->IndexOf("_XYInts"),"__MASTER__");
	//intsfile = intsfile->Remove(intsfile->IndexOf("_XYInts")-22,5);
	intsfile = dir + intsfile->Substring(intsfile->LastIndexOf("\\"));
	fracfile = intsfile->Replace("XYInts","XYFrac");

	timefile = intsfile->Remove(intsfile->IndexOf("XYInts")) + "TimeList.fits";
	String^ deDrift = "_deDrift";
	while (intsfile->Contains(deDrift))
	{
		timefile = timefile->Replace("TimeList","TimeList_deDrift");
		deDrift += "_deDrift";
	}

	framefile = timefile->Replace("Time","Frame");

	flatfile = timefile->Replace("Time","Flat");

	HJDfile = timefile->Replace("Time","HJD");

	mdMmfile = timefile->Replace("TimeList","XYmdMm_List");

	WAITBAR->TextMsg->Text = "Writing the merged list...";
	WAITBAR->Refresh();

	intsfits = gcnew JPFits::FitsFile(intsfile,mergedXYIntsarray,false);
	GatherHeader(filenames,intsfits);
	intsfits->AddKey("TIMEMULT", filenames->Length.ToString(), "Multiplier for merged list int. time",-1);
	intsfits->WriteFile(::TypeCode::Int16);

	fracfits = gcnew JPFits::FitsFile(fracfile,mergedXYFracarray,false);
	GatherHeader(filenames,fracfits);
	fracfits->AddKey("TIMEMULT", filenames->Length.ToString(), "Multiplier for merged list int. time",-1);
	fracfits->WriteFile(::TypeCode::Int16);

	timefits = gcnew JPFits::FitsFile(timefile,/*mergedTimearray*/newTimearray,false);
	GatherHeader(filenames,timefits);
	timefits->AddKey("TIMEMULT", filenames->Length.ToString(), "Multiplier for merged list int. time",-1);
	timefits->WriteFile(::TypeCode::UInt32);

	framefits = gcnew JPFits::FitsFile(framefile,/*mergedFramearray*/newFramearray,false);//now has to be int32 because it won't roll over
	GatherHeader(filenames,framefits);
	framefits->AddKey("TIMEMULT", filenames->Length.ToString(), "Multiplier for merged list int. time",-1);
	framefits->WriteFile(::TypeCode::UInt32);

	flatfits = gcnew JPFits::FitsFile(flatfile,mergedFlatarray,false);
	GatherHeader(filenames,flatfits);
	flatfits->AddKey("TIMEMULT", filenames->Length.ToString(), "Multiplier for merged list int. time",-1);
	flatfits->WriteFile(::TypeCode::Double);

	HJDfits = gcnew JPFits::FitsFile(HJDfile,mergedHJDarray,false);
	GatherHeader(filenames,HJDfits);
	HJDfits->AddKey("TIMEMULT", filenames->Length.ToString(), "Multiplier for merged list int. time",-1);
	HJDfits->WriteFile(::TypeCode::Double);

	mdMmfits = gcnew JPFits::FitsFile(mdMmfile,mergedmdMmarray,false);
	GatherHeader(filenames,mdMmfits);
	mdMmfits->AddKey("TIMEMULT", filenames->Length.ToString(), "Multiplier for merged list int. time",-1);
	mdMmfits->WriteFile(::TypeCode::Int16);

	e->Result = intsfile;
}

void Form1::UVMergeCentroidListsWrkr_ProgressChanged(System::Object^  sender, System::ComponentModel::ProgressChangedEventArgs^  e)
{
	WAITBAR->ProgressBar->Value = e->ProgressPercentage+1;
	WAITBAR->TextMsg->Text = "Merging file " + (e->ProgressPercentage+1).ToString() + " of " + WAITBAR->ProgressBar->Maximum.ToString();
	WAITBAR->Refresh();//find all Update() and replace with Refresh()
}

void Form1::UVMergeCentroidListsWrkr_RunWorkerCompleted(System::Object^  sender, System::ComponentModel::RunWorkerCompletedEventArgs^  e)
{
	if (::MessageBox::Show("Completed merging the centroid lists.  Would you like to create the image?","Merged...",::MessageBoxButtons::YesNo) == ::DialogResult::No)
	{
		WAITBAR->Close();
		Form1::Enabled = true;
		return;
	}

	//then create the image
	ConvertListToImgMenu_DropDownOpened(sender,e);
	ConvertListToImgMenu->HideDropDown();
	UVCONVERTLISTTOIMAGEBATCH = true;
	AUTOLOADIMAGESFILES = gcnew array<String^>(1){(String^)e->Result};
	WAITBAR->ProgressBar->Maximum = AUTOLOADIMAGESFILES->Length;
	WAITBAR->Text = "Creating image(s)...";
	UVConvertListToImgWrkr->RunWorkerAsync(AUTOLOADIMAGESFILES);
}

void Form1::UVNUVToFUVFrameMenuItem_Click(System::Object^  sender, System::EventArgs^  e)
{
	TransformCoefATxt->Text = "0.84898";
	TransformCoefBTxt->Text = "0.53007";
	TransformCoefCTxt->Text = "0.53007";
	TransformCoefDTxt->Text = "-0.84898";
	TransformShiftXTxt->Text = "0";
	TransformShiftYTxt->Text = "0";
	TransformCenterXTxt->Text = "255";
	TransformCenterYTxt->Text = "255";

	GeneralTransformChck->Checked = false;
	GeneralTransformChck->PerformClick();
	UVITMenu->HideDropDown();
	ShiftAndRotateMenuItem->HideDropDown();
	UserDefinedShiftRotateMenuItem->HideDropDown();

	String^ dir = (String^)GetReg("L2EventListPath");
	OpenFileDialog^ dlg = gcnew OpenFileDialog();
	dlg->InitialDirectory = dir;
	dlg->Filter = "FITS (*.fits)|*.fits";
	dlg->Multiselect = true;
	dlg->Title = "Select the Centroid INTEGERS List (_XYInts_List)";
	if (dlg->ShowDialog() != ::DialogResult::OK)
		return;

	UVNUVTOFUVFILES = dlg->FileNames;
	UVNUVTOFUV = true;
	UserDefinedShiftRotateMenuItem_DoubleClick(sender,e);
}

void Form1::BackgroundCountsPixelFrameTxt_TextChanged(System::Object^  sender, System::EventArgs^  e)
{
	if (BackgroundCountsPixelFrameTxt->Text == "-" || BackgroundCountsPixelFrameTxt->Text == "-." || BackgroundCountsPixelFrameTxt->Text == ".")
		return;

	try
	{
		::Convert::ToDouble(BackgroundCountsPixelFrameTxt->Text);
	}
	catch (...)
	{
		BackgroundCountsPixelFrameTxt->Text = "0";
	}
	SetReg("BackgroundCountsPixelFrameTxt",BackgroundCountsPixelFrameTxt->Text);
}

void Form1::CorrectBackgroundCountsChck_Click(System::Object^  sender, System::EventArgs^  e)
{
	UVITMenu->ShowDropDown();
	DeSaturateROICountsMenuItem->ShowDropDown();

	if (CorrectBackgroundCountsChck->Checked)
		BackgroundCountsPixelFrameTxt->Enabled = true;
	else
		BackgroundCountsPixelFrameTxt->Enabled = false;
}

void Form1::DeSaturateROICountsMenuItem_DoubleClick(System::Object^  sender, System::EventArgs^  e)
{
	UVITMenu->HideDropDown();
	DeSaturateROICountsMenuItem->HideDropDown();

	String^ imgname = IMAGESET[FileListDrop->SelectedIndex]->FullFileName;
	String^ dedrift = "";
	while (imgname->Contains(dedrift + "_deDrift"))
		dedrift += "_deDrift";

	String^ framesname = imgname->Substring(0, imgname->IndexOf("deFPN")) + "FrameList" + dedrift + ".fits";
	String^ timessname = framesname->Replace("Frame","Time");
	
	String^ intsname = imgname->Substring(0, imgname->IndexOf("_IMAGE"));
	intsname = intsname->Insert(intsname->IndexOf("deFPN"), "XYInts_List_") + ".fits";
	String^ fracsname = intsname->Replace("Ints","Frac");

	array<double>^ frames = JPFits::FitsFile::ReadImageVectorOnly(framesname,nullptr);
	JPFits::FitsFile^ FracFits = gcnew FitsFile(fracsname,nullptr,true,true,false);
	JPFits::FitsFile^ IntsFits = gcnew FitsFile(intsname,nullptr,true,true,false);

	String^ EXTXRNG = FracFits->GetKeyValue("EXTXRNG");//from GSE CCDLAB processing
	if (EXTXRNG == "")
		EXTXRNG = "0:511";//from L2 data
	String^ EXTYRNG = FracFits->GetKeyValue("EXTYRNG");//from GSE CCDLAB processing
	if (EXTYRNG == "")
		EXTYRNG = "0:511";//from L2 data
	int ix = EXTXRNG->IndexOf(":");
	int iy = EXTYRNG->IndexOf(":");
	double rx1 = ::Convert::ToDouble(EXTXRNG->Substring(0,ix));//range start
	double ry1 = ::Convert::ToDouble(EXTYRNG->Substring(0,iy));
	double rx2 = ::Convert::ToDouble(EXTXRNG->Substring(ix+1));//range end
	double ry2 = ::Convert::ToDouble(EXTYRNG->Substring(iy+1));

	String^ xoffset = FracFits->GetKeyValue("XOFFSET");//from GSE CCCDLAB processing
	if (xoffset == "")
		xoffset = FracFits->GetKeyValue("WIN_XOFF");//from L2 data
	double ox = ::Convert::ToDouble(xoffset);//x offset
	String^ yoffset = FracFits->GetKeyValue("YOFFSET");//from GSE CCCDLAB processing
	if (yoffset == "")
		yoffset = FracFits->GetKeyValue("WIN_YOFF");//from L2 data
	double oy = ::Convert::ToDouble(yoffset);//y offset

	double curframe = -1;
	double framecount = 0;
	double rawcount = 0;
	double frameskips = 0;
	int XEND = XSUBRANGE->Length-1;
	int YEND = YSUBRANGE->Length-1;

	double prec = 1;
	String^ strprec = IMAGESET[FileListDrop->SelectedIndex]->GetKeyValue("IMAGPREC");
	if (strprec != "")
		prec = ::Convert::ToDouble(strprec);

	for (int i = 0; i < frames->Length; i++)
	{
		int xpos = (int)((IntsFits->Image[0,i] - rx1*32 - ox*32 + FracFits->Image[0,i] + 16)/32 * prec);
		int ypos = (int)((IntsFits->Image[1,i] - ry1*32 - oy*32 + FracFits->Image[1,i] + 16)/32 * prec);

		if (xpos >= XSUBRANGE[0] && ypos >= YSUBRANGE[0] && xpos <= XSUBRANGE[XEND] && ypos <= YSUBRANGE[YEND])
		{
			rawcount++;
			if (curframe != (int)frames[i])
			{
				curframe = (int)frames[i];
				framecount++;
			}
		}
	}

	curframe = frames[0];
	for (int i = 0; i < frames->Length; i++)
	{
		if (curframe != frames[i])
		{
			frameskips += frames[i] - curframe - 1;
			curframe = frames[i];
		}
	}

	double nframes = frames[frames->Length-1] - frames[0] + 1;

	double bg = 0;
	if (CorrectBackgroundCountsChck->Checked)
		bg = ::Convert::ToDouble(BackgroundCountsPixelFrameTxt->Text);//total counts per pixel for image near ROI
	bg = bg * SUBIMAGE->Length;//total bg counts in ROI
	bg = bg / nframes;//rate probability of bg event in ROI per frame

	double zeros = nframes - framecount;//number of zero count frames
	double Pzero = zeros/nframes;//rate probability of zero-count frames per frame
	double correctedcountrate = Math::Log(1/Pzero) - bg;//rate per frame
	
	String^ result;
	result += "ROI WIndow Size:	" + XSUBRANGE->Length.ToString() + "x" + YSUBRANGE->Length.ToString() + "\r\n";
	result += "Raw ROI Count:	" + rawcount.ToString() + "\r\n";
	result += "Image ROI Count:	" + SUBIMAGESUM.ToString() + "\r\n";
	result += "Effective ROI Flat:	" + (rawcount/SUBIMAGESUM).ToString() + "\r\n";
	result += "Total Time in List:	" + IMAGESET[FileListDrop->SelectedIndex]->GetKeyValue("TOTITIME") + "\r\n";
	result += "N Frames in List:	" + nframes.ToString() + "\r\n";
	result += "Dataless Frames:	" + frameskips.ToString() + "\r\n";
	result += "ROI Data Frames:	" + framecount.ToString() + "\r\n";
	result += "ROI 0 Count Frames:	" + zeros.ToString() + "\r\n";
	result += "ROI P(0):	" + (Pzero).ToString() + "\r\n";
	result += "ROI Raw Count Rate/f:	" + (rawcount/nframes).ToString() + "\r\n";
	result += "ROI Raw Desaturated Rate/f:	" + correctedcountrate.ToString() + "\r\n";
	result += "ROI Flat Desaturated Rate/f:	" + (correctedcountrate/(rawcount/SUBIMAGESUM)).ToString() + "\r\n";
	result += "ROI Background Rate/f:	" + bg.ToString() + "\r\n";
	result += "ROI Raw Desaturated Rate/s:	" + (correctedcountrate*nframes/::Convert::ToDouble(IMAGESET[FileListDrop->SelectedIndex]->GetKeyValue("TOTITIME"))).ToString() + "\r\n";
	result += "ROI Flat Desaturated Rate/s:	" + (correctedcountrate/(rawcount/SUBIMAGESUM)*nframes/::Convert::ToDouble(IMAGESET[FileListDrop->SelectedIndex]->GetKeyValue("TOTITIME"))).ToString() + "\r\n";
	System::Windows::Forms::Clipboard::SetText(result);

	COG_PLOT->Close();

	result = "";
	result += "ROI WIndow Size:			" + XSUBRANGE->Length.ToString() + "x" + YSUBRANGE->Length.ToString() + "\r\n";
	result += "Raw ROI Count:			" + rawcount.ToString() + "\r\n";
	result += "Image ROI Count:			" + SUBIMAGESUM.ToString() + "\r\n";
	result += "Effective ROI Flat:			" + (rawcount/SUBIMAGESUM).ToString() + "\r\n";
	result += "Total Time in List:			" + IMAGESET[FileListDrop->SelectedIndex]->GetKeyValue("TOTITIME") + "\r\n";
	result += "N Frames in List:			" + nframes.ToString() + "\r\n";
	result += "Dataless Frames:			" + frameskips.ToString() + "\r\n";
	result += "ROI Data Frames:			" + framecount.ToString() + "\r\n";
	result += "ROI 0 Count Frames:			" + zeros.ToString() + "\r\n";
	result += "ROI P(0):				" + (Pzero).ToString() + "\r\n";
	result += "ROI Raw Count Rate/f:		" + (rawcount/nframes).ToString() + "\r\n";
	result += "ROI Raw Desaturated Rate/f:		" + correctedcountrate.ToString() + "\r\n";
	result += "ROI Flat Desaturated Rate/f:		" + (correctedcountrate/(rawcount/SUBIMAGESUM)).ToString() + "\r\n";
	result += "ROI Background Rate/f:		" + bg.ToString() + "\r\n";
	result += "ROI Raw Desaturated Rate/s:		" + (correctedcountrate*nframes/::Convert::ToDouble(IMAGESET[FileListDrop->SelectedIndex]->GetKeyValue("TOTITIME"))).ToString() + "\r\n";
	result += "ROI Flat Desaturated Rate/s:		" + (correctedcountrate/(rawcount/SUBIMAGESUM)*nframes/::Convert::ToDouble(IMAGESET[FileListDrop->SelectedIndex]->GetKeyValue("TOTITIME"))).ToString() + "\r\n";
	::MessageBox::Show(result,"This table copied to clipboard...");	
}

void Form1::ExtractROICentroidListMenuItem_Click(System::Object^  sender, System::EventArgs^  e)
{
	String^ imgname = IMAGESET[FileListDrop->SelectedIndex]->FullFileName;
	String^ dedrift = "";
	while (imgname->Contains(dedrift + "_deDrift"))
		dedrift += "_deDrift";

	String^ framesname = imgname->Substring(0, imgname->IndexOf("deFPN")) + "FrameList" + dedrift + ".fits";
	String^ timesname = framesname->Replace("Frame","Time");
	String^ flatsname = framesname->Replace("Frame","Flat");
	String^ HJDSname = framesname->Replace("Frame","HJD");
	String^ mdMmsname = framesname->Replace("FrameList","XYmdMm_List");
	
	String^ intsname = imgname->Substring(0, imgname->IndexOf("_IMAGE"));
	intsname = intsname->Insert(intsname->IndexOf("deFPN"), "XYInts_List_") + ".fits";
	String^ fracsname = intsname->Replace("Ints","Frac");

	JPFits::FitsFile^ FrameFits = gcnew FitsFile(framesname,nullptr,true,true,false);
	JPFits::FitsFile^ TimeFits = gcnew FitsFile(timesname,nullptr,true,true,false);
	JPFits::FitsFile^ FracFits = gcnew FitsFile(fracsname,nullptr,true,true,false);
	JPFits::FitsFile^ IntsFits = gcnew FitsFile(intsname,nullptr,true,true,false);
	JPFits::FitsFile^ FlatFits = gcnew FitsFile(flatsname,nullptr,true,true,false);
	JPFits::FitsFile^ HJDFits = gcnew FitsFile(HJDSname,nullptr,true,true,false);
	JPFits::FitsFile^ mdMmFits = gcnew FitsFile(mdMmsname,nullptr,true,true,false);

	String^ EXTXRNG = FracFits->GetKeyValue("EXTXRNG");//from GSE CCDLAB processing
	if (EXTXRNG == "")
		EXTXRNG = "0:511";//from L2 data
	String^ EXTYRNG = FracFits->GetKeyValue("EXTYRNG");//from GSE CCDLAB processing
	if (EXTYRNG == "")
		EXTYRNG = "0:511";//from L2 data
	int ix = EXTXRNG->IndexOf(":");
	int iy = EXTYRNG->IndexOf(":");
	double rx1 = ::Convert::ToDouble(EXTXRNG->Substring(0,ix));//range start
	double ry1 = ::Convert::ToDouble(EXTYRNG->Substring(0,iy));
	double rx2 = ::Convert::ToDouble(EXTXRNG->Substring(ix+1));//range end
	double ry2 = ::Convert::ToDouble(EXTYRNG->Substring(iy+1));

	String^ xoffset = FracFits->GetKeyValue("XOFFSET");//from GSE CCCDLAB processing
	if (xoffset == "")
		xoffset = FracFits->GetKeyValue("WIN_XOFF");//from L2 data
	double ox = ::Convert::ToDouble(xoffset);//x offset
	String^ yoffset = FracFits->GetKeyValue("YOFFSET");//from GSE CCCDLAB processing
	if (yoffset == "")
		yoffset = FracFits->GetKeyValue("WIN_YOFF");//from L2 data
	double oy = ::Convert::ToDouble(yoffset);//y offset

	array<bool>^ ROItrue = gcnew array<bool>(FrameFits->Height);
	int c = 0;

	double prec = 1;
	String^ strprec = IMAGESET[FileListDrop->SelectedIndex]->GetKeyValue("IMAGPREC");
	if (strprec != "")
		prec = ::Convert::ToDouble(strprec);

	int XSTART = XSUBRANGE[0];
	int YSTART = YSUBRANGE[0];
	int XEND = XSUBRANGE[XSUBRANGE->Length-1];
	int YEND = YSUBRANGE[YSUBRANGE->Length-1];

	for (int i = 0; i < FrameFits->Height; i++)
	{
		int xpos = (int)((IntsFits->Image[0,i] - rx1*32 - ox*32 + FracFits->Image[0,i] + 16)/32 * prec);
		int ypos = (int)((IntsFits->Image[1,i] - ry1*32 - oy*32 + FracFits->Image[1,i] + 16)/32 * prec);

		if (xpos >= XSTART && ypos >= YSTART && xpos <= XEND && ypos <= YEND)
		{
			c++;
			ROItrue[i] = true;
		}
		else
			ROItrue[i] = false;
	}

	XSTART /= int(prec);
	YSTART /= int(prec);
	XEND /= int(prec);
	YEND /= int(prec);

	array<double>^ ROItimelist = gcnew array<double>(c);
	array<double>^ ROIframelist = gcnew array<double>(c);
	array<double,2>^ ROIintslist = gcnew array<double,2>(2,c);
	array<double,2>^ ROIfraclist = gcnew array<double,2>(2,c);
	array<double>^ ROIflatlist = gcnew array<double>(c);
	array<double>^ ROIHJDlist = gcnew array<double>(c);
	array<double,2>^ ROImdMmlist = gcnew array<double,2>(2,c);

	c = 0;
	for (int i = 0; i < FrameFits->Height; i++)
	{
		if (ROItrue[i])
		{
			ROItimelist[c] = TimeFits->Image[0,i];
			ROIframelist[c] = FrameFits->Image[0,i];
			ROIintslist[0,c] = IntsFits->Image[0,i];
			ROIintslist[1,c] = IntsFits->Image[1,i];
			ROIfraclist[0,c] = FracFits->Image[0,i];
			ROIfraclist[1,c] = FracFits->Image[1,i];
			ROImdMmlist[0,c] = mdMmFits->Image[0,i];
			ROImdMmlist[1,c] = mdMmFits->Image[1,i];
			ROIflatlist[c] = FlatFits->Image[0,i];
			ROIHJDlist[c] = HJDFits->Image[0,i];
			c++;
		}
	}

	timesname = timesname->Substring(0, timesname->IndexOf(".fits")) + "_ROIx" + XSTART.ToString() + "-" + XEND.ToString() + "y" + YSTART.ToString() + "-" + YEND.ToString() + ".fits";
	JPFits::FitsFile^ ROItimeFits = gcnew JPFits::FitsFile(timesname, ROItimelist, false);
	ROItimeFits->CopyHeader(FrameFits);
	ROItimeFits->SetKey("EXTXRNG", XSTART.ToString() + ":" +  XEND.ToString(), "Extraction X-Range", true, -1);
	ROItimeFits->SetKey("EXTYRNG", YSTART.ToString() + ":" +  YEND.ToString(), "Extraction Y-Range", true, -1);
	ROItimeFits->WriteFile(::TypeCode::UInt32);

	framesname = framesname->Substring(0, framesname->IndexOf(".fits")) + "_ROIx" + XSTART.ToString() + "-" + XEND.ToString() + "y" + YSTART.ToString() + "-" + YEND.ToString() + ".fits";
	JPFits::FitsFile^ ROIframeFits = gcnew JPFits::FitsFile(framesname, ROIframelist, false);
	ROIframeFits->CopyHeader(ROItimeFits);
	ROIframeFits->WriteFile(::TypeCode::UInt32);

	intsname = intsname->Substring(0, intsname->IndexOf(".fits")) + "_ROIx" + XSTART.ToString() + "-" + XEND.ToString() + "y" + YSTART.ToString() + "-" + YEND.ToString() + ".fits";
	JPFits::FitsFile^ ROIintsFits = gcnew JPFits::FitsFile(intsname, ROIintslist, false);
	ROIintsFits->CopyHeader(ROItimeFits);
	ROIintsFits->WriteFile(::TypeCode::Int16);

	fracsname = fracsname->Substring(0, fracsname->IndexOf(".fits")) + "_ROIx" + XSTART.ToString() + "-" + XEND.ToString() + "y" + YSTART.ToString() + "-" + YEND.ToString() + ".fits";
	JPFits::FitsFile^ ROIfracFits = gcnew JPFits::FitsFile(fracsname, ROIfraclist, false);
	ROIfracFits->CopyHeader(ROItimeFits);
	ROIfracFits->WriteFile(::TypeCode::Int16);

	flatsname = flatsname->Substring(0, flatsname->IndexOf(".fits")) + "_ROIx" + "_ROIx" + XSTART.ToString() + "-" + XEND.ToString() + "y" + YSTART.ToString() + "-" + YEND.ToString() + ".fits";
	JPFits::FitsFile^ ROIflatFits = gcnew JPFits::FitsFile(flatsname, ROIflatlist, false);
	ROIflatFits->CopyHeader(ROItimeFits);
	ROIflatFits->WriteFile(::TypeCode::Double);

	HJDSname = HJDSname->Substring(0, HJDSname->IndexOf(".fits")) + "_ROIx" "_ROIx" + XSTART.ToString() + "-" + XEND.ToString() + "y" + YSTART.ToString() + "-" + YEND.ToString() + ".fits";
	JPFits::FitsFile^ ROIHJDSFits = gcnew JPFits::FitsFile(HJDSname, ROIHJDlist, false);
	ROIHJDSFits->CopyHeader(ROItimeFits);
	ROIHJDSFits->WriteFile(::TypeCode::Double);

	mdMmsname = mdMmsname->Substring(0, mdMmsname->IndexOf(".fits")) + "_ROIx" + XSTART.ToString() + "-" + XEND.ToString() + "y" + YSTART.ToString() + "-" + YEND.ToString() + ".fits";
	JPFits::FitsFile^ ROImdMmFits = gcnew JPFits::FitsFile(mdMmsname, ROImdMmlist, false);
	ROImdMmFits->CopyHeader(ROItimeFits);
	ROImdMmFits->WriteFile(::TypeCode::Int16);

	::MessageBox::Show("ROI centroid list extracted and written in image directory.","Success...");
}

void Form1::ConsolidateNUVApplyToFUV_Click(System::Object^  sender, System::EventArgs^  e)
{
	::OpenFileDialog^ ofd = gcnew ::OpenFileDialog();
	ofd->Multiselect = true;
	String^ dir = (String^)GetReg("L2EventListPath");
	ofd->InitialDirectory = dir;
	ofd->Filter = "FITS (*.drift)|*.drift";
	ofd->Title = "Select the MOST RECENT NUV or VIS DRIFT Series (*.drift)";
	if (ofd->ShowDialog() != ::DialogResult::OK)
		return;
	SetReg("L2EventListPath",ofd->FileNames[0]->Substring(0,ofd->FileNames[0]->LastIndexOf("\\")));
	array<String^>^ FileNames = ofd->FileNames;

	//need to get the FUV lists...please select the FUV TIME lists...this can be done right away with the NUV drift series selection
	ofd = gcnew ::OpenFileDialog();
	ofd->Multiselect = true;
	dir = (String^)GetReg("L2EventListPath");
	ofd->InitialDirectory = dir;
	ofd->Filter = "FITS (*.fits)|*.fits";
	ofd->Title = "Select the FUV or NUV TIME Series to apply drift to (*TimeList.fits)";
	if (ofd->ShowDialog() != ::DialogResult::OK)
		return;
	SetReg("L2EventListPath",ofd->FileNames[0]->Substring(0,ofd->FileNames[0]->LastIndexOf("\\")));
	SetReg("OpenFilesPath",ofd->FileNames[0]->Substring(0,ofd->FileNames[0]->LastIndexOf("\\")));
	array<String^>^ FUVTimeListNames = ofd->FileNames;
	for (int i = 0; i < FUVTimeListNames->Length; i++)
		if (!FUVTimeListNames[i]->Contains("TimeList"))
		{
			::MessageBox::Show("Error: Seems that one of the TimeList files is not what it should be: " + FUVTimeListNames[i],"Error...",::MessageBoxButtons::OK);
			return;
		}

	Form1::Enabled = false;
	WAITBAR = gcnew JPWaitBar::WaitBar();
	WAITBAR->ProgressBar->Maximum = 100;
	WAITBAR->Text = "DeDrift FUV or NUV from NUV or VIS Drift Series...";
	WAITBAR->ProgressBar->Value = 0;
	array<Object^>^ arg = gcnew array<Object^>(2);
	arg[0] = FileNames;
	arg[1] = FUVTimeListNames;
	UVDriftNUVtoFUVBGWrkr->RunWorkerAsync(arg);
	WAITBAR->ShowDialog();
}

void Form1::UVDriftNUVtoFUVBGWrkr_DoWork(System::Object^  sender, System::ComponentModel::DoWorkEventArgs^  e)
{
	array<Object^>^ arg = (array<Object^>^)e->Argument;
	array<String^>^ FileNames = (array<String^>^)arg[0];
	array<String^>^ FUVTimeListNames = (array<String^>^)arg[1];
	String^ driftserieschannel = "";

	//have the most recent drift series, now must search for possible 1st order series to consolidate all orders together first
	//first must sort the directories in sequence
	array<double>^ dirtimes = gcnew array<double>(FileNames->Length);
	for (int i = 0; i < FileNames->Length; i++)
	{
		String^ path = FileNames[i]->Substring(0,FileNames[i]->LastIndexOf("\\"));
		String^ dirtime = path->Substring(path->LastIndexOf("_")+1,10);
		dirtimes[i] = ::Convert::ToDouble(dirtime);
	}
	Array::Sort(dirtimes,FileNames);
	array<String^>^ FilePaths = gcnew array<String^>(FileNames->Length);
	for (int i = 0; i < FileNames->Length; i++)
		FilePaths[i] = FileNames[i]->Substring(0,FileNames[i]->LastIndexOf("\\"));
	//filepaths/names now sorted in time order

	//now go to each path, and do a first consolidation/compactification of the drift series in each path (observation) if there are 1st & 2nd Order etc. series
	//can assume that all series are processed equally, so if only find 1st order, no need to process this step
	array<String^>^ pathcompactseriesFILES = gcnew array<String^>(FilePaths->Length);
	for (int i = 0; i < FilePaths->Length; i++)
	{
		if (WAITBAR->DialogResult == ::DialogResult::Cancel)
			return;
		UVDriftNUVtoFUVBGWrkr->ReportProgress((i+1)*100/FilePaths->Length,"Consolidating " + driftserieschannel + " drift series...");

		array<String^>^ pathdriftseries = ::Directory::GetFiles(FilePaths[i],"*.drift");
		array<int>^ pathdriftserieslengths = gcnew array<int>(pathdriftseries->Length);//filename length gives the drift series order
		for (int j = 0; j < pathdriftserieslengths->Length; j++)
			pathdriftserieslengths[j] = pathdriftseries[j]->Length;
		Array::Sort(pathdriftserieslengths,pathdriftseries);//now the driftseries are sorted in order Order..i.e., the last one is the shortest, highest order
		Array::Reverse(pathdriftserieslengths);
		Array::Reverse(pathdriftseries);//now the first one is the shortest

		JPFits::FitsFile^ pathconsolidatedseries = gcnew FitsFile(pathdriftseries[0],nullptr,true,true,false);
		if (i == 0)
		{
			driftserieschannel = pathconsolidatedseries->GetKeyValue("DETECTOR");
			if (driftserieschannel == "" || driftserieschannel != "NUV" && driftserieschannel != "VIS")//although FUV COULD be used for NUV...should never need...can do if needed
			{
				::MessageBox::Show("Drift series channel not identifiable or FUV:  DETECTOR = " + driftserieschannel + "; Exiting.","Error");
				WAITBAR->CancelBtn->PerformClick();
				return;
			}
		}
		for (int j = 1; j < pathdriftseries->Length; j++)
		{
			JPFits::FitsFile^ pathconsolidatedseries_lowerorder = gcnew FitsFile(pathdriftseries[j],nullptr,true,true,false);//lower order is longer length

			#pragma omp parallel for
			for (int m = 1; m < 3; m++)
				for (int k = 0; k < pathconsolidatedseries->Height; k++)
					pathconsolidatedseries->Image[m,k] += pathconsolidatedseries_lowerorder->Image[m,k];
		}
		//pathconsolidatedseries now has all drift correction orders combined for this path
		//now compactify it to unique time elements only
		int c = 0;
		double time = -1;
		for (int j = 0; j < pathconsolidatedseries->Height; j++)
		{
			if (time != pathconsolidatedseries->Image[0,j])
			{
				c++;
				time = pathconsolidatedseries->Image[0,j];
			}
		}
		array<double,2>^ pathcompactseries = gcnew array<double,2>(3,c);
		c = 0;
		time = -1;
		for (int j = 0; j < pathconsolidatedseries->Height; j++)
		{
			if (time != pathconsolidatedseries->Image[0,j])
			{
				pathcompactseries[0,c] = pathconsolidatedseries->Image[0,j];
				pathcompactseries[1,c] = pathconsolidatedseries->Image[1,j];
				pathcompactseries[2,c] = pathconsolidatedseries->Image[2,j];
				c++;
				time = pathconsolidatedseries->Image[0,j];
			}
		}
		//now have the pathcompactseries...write it in the path to disk as FITS .drift file

		String^ pathcompactseriesFILE = FileNames[i];
		pathcompactseriesFILE = pathcompactseriesFILE->Insert(pathcompactseriesFILE->IndexOf("_XYDrift_List") + 13,"__COMPACT_");
		pathcompactseriesFILE = pathcompactseriesFILE->Remove(pathcompactseriesFILE->IndexOf("COMPACT") + 8,7);
		JPFits::FitsFile^ pathcompactseriesFITS = gcnew FitsFile(pathcompactseriesFILE,pathcompactseries,false);
		pathcompactseriesFITS->WriteFile(::TypeCode::Double);
		pathcompactseriesFILES[i] = pathcompactseriesFILE;
	}

	//String them together
	FitsFile^ fits;
	int c = 0;
	for (int i = 0; i < pathcompactseriesFILES->Length; i++)
	{
		fits = gcnew FitsFile(pathcompactseriesFILES[i],nullptr,true,false,false);
		c += fits->Height;
	}
	array<double,2>^ pathcompactseriesconsolidated = gcnew array<double,2>(3,c);
	array<double,2>^ NUVstartendtimes = gcnew array<double,2>(2,pathcompactseriesFILES->Length);//need this for later but good to produce here with this
	c = 0;
	for (int i = 0; i < pathcompactseriesFILES->Length; i++)
	{
		fits = gcnew FitsFile(pathcompactseriesFILES[i],nullptr,true,true,false);
		NUVstartendtimes[0,i] = fits->Image[0,0];
		NUVstartendtimes[1,i] = fits->Image[0,fits->Height-1];
		for (int k = 0; k < fits->Height; k++)
		{
			pathcompactseriesconsolidated[0,c] = fits->Image[0,k];
			pathcompactseriesconsolidated[1,c] = fits->Image[1,k];
			pathcompactseriesconsolidated[2,c] = fits->Image[2,k];
			c++;
		}
		::File::Delete(pathcompactseriesFILES[i]);//delete them so that they don't clutter the directories
	}

	/*fits = gcnew FitsFile("C:\\Users\\Joseph E Postma\\Desktop\\SMC\\test.fits",pathcompactseriesconsolidated,false);
	fits->WriteFile(TypeCode::Double);
	::MessageBox::Show("Here");
	return;*/

	//now have consolidated & compactified all selected NUV drift series into a single string
	//now they must be used for FUV...they will need to be transformed to FUV coordinates
	array<double>^ Pvistonuv = gcnew array<double>(4){1.01075, -0.04301, -0.04301, -1.01075};//from Shyam Feb 2017
	array<double>^ Pnuvtofuv = gcnew array<double>(4){0.84898, 0.53007, 0.53007, -0.84898};//from Shyam Feb 2017
	array<double>^ Pvistofuv = gcnew array<double>(4){0, 0, 0, 0};//???
	double dx, dy, dxp, dyp;
	if (driftserieschannel == "NUV")
	{
		UVDriftNUVtoFUVBGWrkr->ReportProgress(0,"Transforming NUV drift series to FUV frame...");
		#pragma omp parallel for private(dx, dy)
		for (int i = 0; i < c; i++)
		{
			dx = pathcompactseriesconsolidated[1,i];
			dy = pathcompactseriesconsolidated[2,i];

			pathcompactseriesconsolidated[1,i] = Pnuvtofuv[0]*dx + Pnuvtofuv[1]*dy;//NUV to FUV
			pathcompactseriesconsolidated[2,i] = Pnuvtofuv[2]*dx + Pnuvtofuv[3]*dy;
		}
	}
	fits = gcnew FitsFile(FUVTimeListNames[0],nullptr,true,false,false);
	String^ applyserieschannel = fits->GetKeyValue("DETECTOR");
	if (driftserieschannel == "VIS")
	{
		UVDriftNUVtoFUVBGWrkr->ReportProgress(0,"Transforming VIS drift series to " + applyserieschannel + " frame...");
		if (applyserieschannel == "FUV")
		{
			#pragma omp parallel for private(dx, dy, dxp, dyp)
			for (int i = 0; i < c; i++)
			{
				dx = pathcompactseriesconsolidated[1,i];
				dy = pathcompactseriesconsolidated[2,i];

				dxp = Pvistonuv[0]*dx + Pvistonuv[1]*dy;//VIS to NUV
				dyp = Pvistonuv[2]*dx + Pvistonuv[3]*dy;

				pathcompactseriesconsolidated[1,i] = Pnuvtofuv[0]*dxp + Pnuvtofuv[1]*dyp;//NUV to FUV
				pathcompactseriesconsolidated[2,i] = Pnuvtofuv[2]*dxp + Pnuvtofuv[3]*dyp;

				/*pathcompactseriesconsolidated[1,i] = Pvistofuv[0]*dx + Pvistofuv[1]*dy;//VIS to FUV
				pathcompactseriesconsolidated[2,i] = Pvistofuv[2]*dx + Pvistofuv[3]*dy;*/
			}
		}
		else if (applyserieschannel == "NUV")
		{
			#pragma omp parallel for private(dx, dy)
			for (int i = 0; i < c; i++)
			{
				dx = pathcompactseriesconsolidated[1,i];
				dy = pathcompactseriesconsolidated[2,i];

				pathcompactseriesconsolidated[1,i] = Pvistonuv[0]*dx + Pvistonuv[1]*dy;
				pathcompactseriesconsolidated[2,i] = Pvistonuv[2]*dx + Pvistonuv[3]*dy;
			}
		}
		else
		{
			::MessageBox::Show("Error...section 8");
			return;
		}
	}
	
	//now save the new consolidated FUV-frame drift series
	/*String^ upperpath = FilePaths[0]->Substring(0,FilePaths[0]->LastIndexOf("\\"));
	upperpath = upperpath->Substring(0,upperpath->LastIndexOf("\\")+1);
	String^ file = pathcompactseriesFILES[0]->Substring(pathcompactseriesFILES[0]->LastIndexOf("\\")+1);
	file = file->Remove(file->IndexOf("NUV")+4,18);
	file = file->Insert(file->IndexOf("NUV")+4,"_CONSOLIDAT_");
	FitsFile^ pathcompactseriesconsolidatedFITS = gcnew FitsFile(upperpath+file,pathcompactseriesconsolidated,false);
	pathcompactseriesconsolidatedFITS->WriteFile(::TypeCode::Double);*/
	//now have the consolidated FUV-frame drift series saved...perhaps not necessary to save, but can anyway
	
	//now string together the FUV TimeLists
	c = 0;
	for (int i = 0; i < FUVTimeListNames->Length; i++)
	{
		fits = gcnew FitsFile(FUVTimeListNames[i],nullptr,true,false,false);
		c += fits->Height;
	}
	array<double>^ FUVTimeList = gcnew array<double>(c);
	c = 0;
	for (int i = 0; i < FUVTimeListNames->Length; i++)
	{
		fits = gcnew FitsFile(FUVTimeListNames[i],nullptr,true,true,false);
		String^ FUVFrameListName = FUVTimeListNames[i]->Replace("TimeList", "FrameList");
		array<double>^ frames = FitsFile::ReadImageVectorOnly(FUVFrameListName, nullptr);
		double timeperframe = (fits->Image[0, fits->Height - 1] - fits->Image[0, 0]) / (frames[fits->Height-1] - frames[0]);
		for (int k = 0; k < fits->Height; k++)
		{
			FUVTimeList[c] = fits->Image[0,k] + timeperframe/2;//hard-coded time per frame/2 to center the time...this could be a problem later if frame size is diff or whatever
			c++;
		}
	}

	//Now interpolate-spline the series via Matlab, return all FUV-time values via Matlab at same time
	// -> MATLAB returns interpolated time series for FUV
	UVDriftNUVtoFUVBGWrkr->ReportProgress(50,"Interpolating " + driftserieschannel + " drift series to " + applyserieschannel + "...");
	MLMath::NUVtoFUVDriftSeries^ mwinterp = gcnew MLMath::NUVtoFUVDriftSeries();
	MWNumericArray^ mwFUVTimeList = gcnew MWNumericArray(FUVTimeList);
	MWNumericArray^ mwpathcompactseriesconsolidated = gcnew MWNumericArray(pathcompactseriesconsolidated);
	MWNumericArray^ mwFUVinterpdriftseries = gcnew MWNumericArray();
	UVDriftNUVtoFUVBGWrkr->ReportProgress(100,"Interpolating " + driftserieschannel + " drift series to " + applyserieschannel + "...");
	mwFUVinterpdriftseries = (MWNumericArray^)mwinterp->NUVtoFUVDriftSeriesInterp(mwpathcompactseriesconsolidated, mwFUVTimeList);
	array<double,2>^ FUVinterpdriftseries = (array<double,2>^)mwFUVinterpdriftseries->ToArray(MWArrayComponent::Real);

	//Now, for EACH FUVTimeList, see if there is any time overlap of valid interpolation, and make its drift series to save for each one
	//so, need to compare the FUV TimeList with the NUVdriftseries time list to see where valid overlapping FUV times are; FUV times that are not valid can be set = -1
	//use the NUVstartendtimes to check for good FUV times...
	bool brk = false;
	#pragma omp parallel for private(brk)
	for (int i = 0; i < FUVTimeList->Length; i++)
	{
		brk = false;
		for (int j = 0; j < pathcompactseriesFILES->Length; j++)
		{
			if (FUVTimeList[i] >= NUVstartendtimes[0,j] && FUVTimeList[i] <= NUVstartendtimes[1,j])
			{
				brk = true;
				break;
			}
		}
		if (brk)
			continue;
		FUVTimeList[i] = -1;
	}

	/*fits = gcnew FitsFile("C:\\Users\\Joseph E Postma\\Desktop\\SMC\\test.fits",FUVTimeList,false);
	fits->WriteFile(TypeCode::Double);
	::MessageBox::Show("Here");
	return;*/
	
	//so now have FUV times which are from the original FUV lists and which are good times
	//now need to go through the individual FUV lists/directories and create drift series for those good times and save them in those directories
	//then after that or at the same time, would need to apply them to the centroid lists and make new de-drifted centroid lists
	ArrayList^ createimagexyintslist = gcnew ArrayList();
	c = 0;
	for (int i = 0; i < FUVTimeListNames->Length; i++)
	{
		if (WAITBAR->DialogResult == ::DialogResult::Cancel)
			return;
		UVDriftNUVtoFUVBGWrkr->ReportProgress((i+1)*100/FUVTimeListNames->Length,"Drift-correcting " + applyserieschannel + " centroids...");

		String^ fuvtimelistName = FUVTimeListNames[i];
		String^ fuvxyfraclistName = fuvtimelistName->Replace("TimeList","XYFrac_List_deFPN_deDIST");
		String^ fuvxyintslistName = fuvtimelistName->Replace("TimeList","XYInts_List_deFPN_deDIST");
		String^ fuvflatlistName = fuvtimelistName->Replace("TimeList","FlatList");
		String^ fuvframelistName = fuvtimelistName->Replace("TimeList","FrameList");
		String^ fuvHJDlistName = fuvtimelistName->Replace("TimeList","HJDList");
		String^ fuvmdmmlistName = fuvtimelistName->Replace("TimeList","XYmdMm_List");

		//load the timelist and find out where it is good, if at all
		//they will be loaded in the same order as the string is contructed, so then can just equate them tracking indices
		FitsFile^ fuvtimelistFITS = gcnew FitsFile(fuvtimelistName,nullptr,true,true,false);
		int L = 0;//need to know how long the new lists will be...
		for (int j = 0; j < fuvtimelistFITS->Height; j++)
		{
			fuvtimelistFITS->Image[0,j] = FUVTimeList[c+j];
			if (fuvtimelistFITS->Image[0,j] == -1)
				L++;
		}
		c += fuvtimelistFITS->Height;

		//if there are any good times in this list, not all values will be = -1
		if (L == fuvtimelistFITS->Height)//then no good times
			continue;//go to next interation

		L = fuvtimelistFITS->Height - L;//need to know how long the new lists will be...
		
		//so now there are some good times
		//now make the dedrifted lists for this directory
		array<double>^ fuvtimelistdedrift = gcnew array<double>(L);
		array<double>^ fuvframelistdedrift = gcnew array<double>(L);
		array<double>^ fuvflatlistdedrift = gcnew array<double>(L);
		array<double>^ fuvHJDlistdedrift = gcnew array<double>(L);
		array<double,2>^ fuvxyintslistdedrift = gcnew array<double,2>(2,L);
		array<double,2>^ fuvxyfraclistdedrift = gcnew array<double,2>(2,L);
		array<double,2>^ fuvmdmmlistdedrift = gcnew array<double,2>(2,L);

		array<double>^ fuvframelist = JPFits::FitsFile::ReadImageVectorOnly(fuvframelistName,nullptr);
		array<double>^ fuvflatlist = JPFits::FitsFile::ReadImageVectorOnly(fuvflatlistName,nullptr);
		array<double>^ fuvHJDlist = JPFits::FitsFile::ReadImageVectorOnly(fuvHJDlistName,nullptr);
		array<double,2>^ fuvxyintslist = JPFits::FitsFile::ReadImageArrayOnly(fuvxyintslistName,nullptr);
		array<double,2>^ fuvxyfraclist = JPFits::FitsFile::ReadImageArrayOnly(fuvxyfraclistName,nullptr);
		array<double,2>^ fuvmdmmlist = JPFits::FitsFile::ReadImageArrayOnly(fuvmdmmlistName,nullptr);

		int counter = 0;
		for (int j = 0; j < fuvtimelistFITS->Height; j++)
		{
			if (fuvtimelistFITS->Image[0,j] == -1)
				continue;

			fuvtimelistdedrift[counter] = fuvtimelistFITS->Image[0,j];
			fuvframelistdedrift[counter] = fuvframelist[j];
			fuvflatlistdedrift[counter] = fuvflatlist[j];
			fuvHJDlistdedrift[counter] = fuvHJDlist[j];
			fuvmdmmlistdedrift[0,counter] = fuvmdmmlist[0,j];
			fuvmdmmlistdedrift[1,counter] = fuvmdmmlist[1,j];
			fuvxyintslistdedrift[0,counter] = fuvxyintslist[0,j] - FUVinterpdriftseries[0,j + c - fuvtimelistFITS->Height];
			fuvxyintslistdedrift[1,counter] = fuvxyintslist[1,j] - FUVinterpdriftseries[1,j + c - fuvtimelistFITS->Height];
			fuvxyfraclistdedrift[0,counter] = fuvxyfraclist[0,j];
			fuvxyfraclistdedrift[1,counter] = fuvxyfraclist[1,j];
			counter++;
		}
		
		//check for initial noise frames in the FUV list...it would only be for the first time in the FUV time list
		counter = 0;
		for (int j = 0; j < fuvtimelistdedrift->Length; j++)
		{
			if (fuvtimelistdedrift[0] == fuvtimelistdedrift[j])
			{
				counter++;
				continue;
			}
			break;
		}
		if (counter >= 1000)//then resize the dedrifted lists and get rid of initial noise
		{
			array<double>^ fuvtimelistdedriftTEMP = gcnew array<double>(L - counter);
			array<double>^ fuvframelistdedriftTEMP = gcnew array<double>(L - counter);
			array<double>^ fuvflatlistdedriftTEMP = gcnew array<double>(L - counter);
			array<double>^ fuvHJDlistdedriftTEMP = gcnew array<double>(L - counter);
			array<double,2>^ fuvxyintslistdedriftTEMP = gcnew array<double,2>(2,L - counter);
			array<double,2>^ fuvxyfraclistdedriftTEMP = gcnew array<double,2>(2,L - counter);
			array<double,2>^ fuvmdmmlistdedriftTEMP = gcnew array<double,2>(2,L - counter);

			for (int j = 0; j < L - counter; j++)
			{
				fuvtimelistdedriftTEMP[j] = fuvtimelistdedrift[j + counter];
				fuvframelistdedriftTEMP[j] = fuvframelistdedrift[j + counter];
				fuvflatlistdedriftTEMP[j] = fuvflatlistdedrift[j + counter];
				fuvHJDlistdedriftTEMP[j] = fuvHJDlistdedrift[j + counter];
				fuvmdmmlistdedriftTEMP[0,j] = fuvmdmmlistdedrift[0,j + counter];
				fuvmdmmlistdedriftTEMP[1,j] = fuvmdmmlistdedrift[1,j + counter];
				fuvxyintslistdedriftTEMP[0,j] = fuvxyintslistdedrift[0,j + counter];
				fuvxyintslistdedriftTEMP[1,j] = fuvxyintslistdedrift[1,j + counter];
				fuvxyfraclistdedriftTEMP[0,j] = fuvxyfraclistdedrift[0,j + counter];
				fuvxyfraclistdedriftTEMP[1,j] = fuvxyfraclistdedrift[1,j + counter];
			}

			fuvtimelistdedrift = fuvtimelistdedriftTEMP;
			fuvframelistdedrift = fuvframelistdedriftTEMP;
			fuvflatlistdedrift = fuvflatlistdedriftTEMP;
			fuvHJDlistdedrift = fuvHJDlistdedriftTEMP;
			fuvmdmmlistdedrift = fuvmdmmlistdedriftTEMP;
			fuvxyintslistdedrift = fuvxyintslistdedriftTEMP;
			fuvxyfraclistdedrift = fuvxyfraclistdedriftTEMP;
		}

		String^ HJD0 = fuvHJDlistdedrift[0].ToString("#.0000000");
		fuvtimelistFITS->SetKey("HJD0", HJD0, "HJD of start of imaging", true, 14);

		//now have the dedrifted and drift corrected set of lists for this directory
		//need to write them to their directory
		String^ fuvtimelistNamededrift = fuvtimelistName->Replace("TimeList","TimeList_deDrift");
		String^ fuvframelistNamededrift = fuvtimelistName->Replace("TimeList","FrameList_deDrift");
		String^ fuvflatlistNamededrift = fuvtimelistName->Replace("TimeList","FlatList_deDrift");
		String^ fuvHJDlistNamededrift = fuvtimelistName->Replace("TimeList","HJDList_deDrift");
		String^ fuvxyfraclistNamededrift = fuvtimelistName->Replace("TimeList","XYFrac_List_deFPN_deDIST_deDrift");
		String^ fuvxyintslistNamededrift = fuvtimelistName->Replace("TimeList","XYInts_List_deFPN_deDIST_deDrift");
		String^ fuvmdmmlistNamededrift = fuvtimelistName->Replace("TimeList","XYmdMm_List_deDrift");

		fits = gcnew FitsFile(fuvtimelistNamededrift,fuvtimelistdedrift,false);
		fits->CopyHeader(fuvtimelistFITS);
		fits->WriteFile(::TypeCode::UInt32);
		fits = gcnew FitsFile(fuvframelistNamededrift,fuvframelistdedrift,false);
		fits->CopyHeader(fuvtimelistFITS);
		fits->WriteFile(::TypeCode::UInt32);
		fits = gcnew FitsFile(fuvflatlistNamededrift,fuvflatlistdedrift,false);
		fits->CopyHeader(fuvtimelistFITS);
		fits->WriteFile(::TypeCode::Double);
		fits = gcnew FitsFile(fuvHJDlistNamededrift,fuvHJDlistdedrift,false);
		fits->CopyHeader(fuvtimelistFITS);
		fits->WriteFile(::TypeCode::Double);
		fits = gcnew FitsFile(fuvmdmmlistNamededrift,fuvmdmmlistdedrift,false);
		fits->CopyHeader(fuvtimelistFITS);
		fits->WriteFile(::TypeCode::Int16);
		fits = gcnew FitsFile(fuvxyfraclistNamededrift,fuvxyfraclistdedrift,false);
		fits->CopyHeader(fuvtimelistFITS);
		fits->WriteFile(::TypeCode::Int16);
		fits = gcnew FitsFile(fuvxyintslistNamededrift,fuvxyintslistdedrift,false);
		fits->CopyHeader(fuvtimelistFITS);
		fits->WriteFile(::TypeCode::Int16);

		//dedrifted lists now written
		createimagexyintslist->Add(fuvxyintslistNamededrift);
	}

	if (createimagexyintslist->Count == 0)
		return;

	array<String^>^ xyintslist = gcnew array<String^>(createimagexyintslist->Count);
	for (int i = 0; i < createimagexyintslist->Count; i++)
		xyintslist[i] = (String^)createimagexyintslist[i];

	e->Result = xyintslist;
}

void Form1::UVDriftNUVtoFUVBGWrkr_ProgressChanged(System::Object^  sender, System::ComponentModel::ProgressChangedEventArgs^  e)
{
	WAITBAR->ProgressBar->Value = e->ProgressPercentage;
	WAITBAR->TextMsg->Text = (String^)e->UserState;
	WAITBAR->Refresh();
}

void Form1::UVDriftNUVtoFUVBGWrkr_RunWorkerCompleted(System::Object^  sender, System::ComponentModel::RunWorkerCompletedEventArgs^  e)
{
	if (WAITBAR->DialogResult == ::DialogResult::Cancel)
	{
		Form1::Enabled = true;
		return;
	}

	//now create the images
	ConvertListToImgMenu_DropDownOpened(sender,e);
	ConvertListToImgMenu->HideDropDown();
	UVCONVERTLISTTOIMAGEBATCH = true;
	AUTOLOADIMAGESFILES = (array<String^>^)e->Result;
	WAITBAR->ProgressBar->Maximum = AUTOLOADIMAGESFILES->Length;
	WAITBAR->Text = "Creating image(s)...";
	UVConvertListToImgWrkr->RunWorkerAsync(AUTOLOADIMAGESFILES);
}


