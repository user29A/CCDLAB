void Form1::UVL1ExtractArchiveBGWrkr_DoWork(System::Object^  sender, System::ComponentModel::DoWorkEventArgs^  e)
{
	array<String^>^ files = (array<String^>^)e->Argument;
	::Diagnostics::Process^ p = gcnew ::Diagnostics::Process();
	//p->StartInfo->UseShellExecute = false;
	p->StartInfo->FileName = "c:\\Program Files\\7-Zip\\7z.exe";
	String^ extdir = files[0]->Substring(0,files[0]->LastIndexOf("\\"));
	String^ archdir = extdir + "\\archive";
	::Directory::CreateDirectory(archdir);

	for (int i = 0; i < files->Length; i++)
	{
		if (WAITBAR->DialogResult == ::DialogResult::Cancel)
			return;
		UVL1ExtractArchiveBGWrkr->ReportProgress(100*i/files->Length);
		
		String^ extfile = files[i];
		p->StartInfo->Arguments = "\"x\" " + "\"" + extfile + "\" " + "\"-o" + extdir;
		p->Start();
		p->WaitForExit();

		if (WAITBAR->DialogResult == ::DialogResult::Cancel)
			return;
		UVL1ExtractArchiveBGWrkr->ReportProgress((100*i+50)/files->Length);

		::File::Move(extfile, archdir + "\\" + extfile->Substring(extfile->LastIndexOf("\\")+1));

		extfile = extfile->Substring(0,extfile->LastIndexOf("."));
		String^ orbit = extfile->Substring(0,extfile->LastIndexOf(".tar"));
		orbit = orbit->Substring(orbit->LastIndexOf("_")+1);
		::Directory::CreateDirectory(extdir + "\\" + orbit);
		String^ extdirorbit = extdir + "\\" + orbit;
		p->StartInfo->Arguments = "\"x\" " + "\"" + extfile + "\" " + "\"-o" + extdirorbit;
		p->Start();
		p->WaitForExit();

		File::Delete(extfile);
	}
}

void Form1::UVL1ExtractArchiveBGWrkr_ProgressChanged(System::Object^  sender, System::ComponentModel::ProgressChangedEventArgs^  e)
{
	WAITBAR->ProgressBar->Value = e->ProgressPercentage;
	WAITBAR->TextMsg->Text = "Completed: " + e->ProgressPercentage.ToString() + "%";
	WAITBAR->Refresh();
}

void Form1::UVL1ExtractArchiveBGWrkr_RunWorkerCompleted(System::Object^  sender, System::ComponentModel::RunWorkerCompletedEventArgs^  e)
{
	if (WAITBAR->DialogResult == ::DialogResult::Cancel)
	{
		Form1::Enabled = true;
		Form1::Focus();
		return;
	}

	WAITBAR->Hide();
	WAITBAR->Close();
	Form1::Enabled = true;
	Form1::Focus();

	::FolderBrowserDialog^ fbd = gcnew ::FolderBrowserDialog();
	fbd->SelectedPath = (String^)GetReg("L2EventListPath");
	array<String^>^ orbitdirs = ::Directory::GetDirectories(fbd->SelectedPath);//should just be orbit-wise directories here

	for (int i = 0; i < orbitdirs->Length; i++)
	{
		String^ orbit = orbitdirs[i]->Substring(orbitdirs[i]->LastIndexOf("\\")+1);
		array<String^>^ L1fitsfiles = ::Directory::GetFiles(orbitdirs[i], "*level1.fits", ::IO::SearchOption::AllDirectories);
		bool deldir = false;
		
		for (int j = 0; j < L1fitsfiles->Length; j++)
		{
			String^ newL1file = fbd->SelectedPath + "\\" + orbit + "_" + L1fitsfiles[j]->Substring(L1fitsfiles[j]->LastIndexOf("\\")+1);
			while(::File::Exists(newL1file))//then need to add some appendage
			{
				int ind = newL1file->LastIndexOf(".");
				if (newL1file->Substring(ind-1,1) == ")")
				{
					int num = ::Convert::ToInt32(newL1file->Substring(newL1file->LastIndexOf("(") + 1,newL1file->LastIndexOf(")") - 1 - newL1file->LastIndexOf("(")));
					newL1file = newL1file->Replace("(" + num.ToString() + ")","(" + (num+1).ToString() + ")");
				}
				else
				{
					newL1file = newL1file->Insert(ind," (1)");
					if (::File::Exists(newL1file))
					{
						int num = ::Convert::ToInt32(newL1file->Substring(newL1file->LastIndexOf("(") + 1,newL1file->LastIndexOf(")") - 1 - newL1file->LastIndexOf("(")));
						newL1file = newL1file->Replace("(" + num.ToString() + ")","(" + (num+1).ToString() + ")");
					}
				}
			}
			::File::Move(L1fitsfiles[j], newL1file);
			deldir = true;//then it entere this dir loop becuase there were files
		}

		array<String^>^ L1tctfiles = ::Directory::GetFiles(orbitdirs[i], "*level1.tct", ::IO::SearchOption::AllDirectories);
		for (int j = 0; j < L1tctfiles->Length; j++)
		{
			String^ newL1file = fbd->SelectedPath + "\\" + orbit + "_" + L1tctfiles[j]->Substring(L1tctfiles[j]->LastIndexOf("\\")+1);
			while(::File::Exists(newL1file))//then need to add some appendage
			{
				int ind = newL1file->LastIndexOf(".");
				if (newL1file->Substring(ind-1,1) == ")")
				{
					int num = ::Convert::ToInt32(newL1file->Substring(newL1file->LastIndexOf("(") + 1,newL1file->LastIndexOf(")") - 1 - newL1file->LastIndexOf("(")));
					newL1file = newL1file->Replace("(" + num.ToString() + ")","(" + (num+1).ToString() + ")");
				}
				else
				{
					newL1file = newL1file->Insert(ind," (1)");
					if (::File::Exists(newL1file))
					{
						int num = ::Convert::ToInt32(newL1file->Substring(newL1file->LastIndexOf("(") + 1,newL1file->LastIndexOf(")") - 1 - newL1file->LastIndexOf("(")));
						newL1file = newL1file->Replace("(" + num.ToString() + ")","(" + (num+1).ToString() + ")");
					}
				}
			}
			::File::Move(L1tctfiles[j], newL1file);
		}
		if (deldir)
			::Directory::Delete(orbitdirs[i],true);
	}

	if (::MessageBox::Show("Finished processing folders.  Would you like to proceed with file digestion?", "Proceed?", ::MessageBoxButtons::YesNo) == ::DialogResult::No)
		return;

	array<String^>^ files = ::Directory::GetFiles(fbd->SelectedPath, "*level1*.fits");
	DATE = DateTime::Now;
	Form1::Enabled = false;
	WAITBAR = gcnew ::JPWaitBar::WaitBar();
	WAITBAR->Text = "Digesting L1 Files...";
	WAITBAR->ProgressBar->Maximum = files->Length;
	UVITL1DigestWrkr->RunWorkerAsync(files);
	WAITBAR->ShowDialog();
}

