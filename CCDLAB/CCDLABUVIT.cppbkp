void Form1::CreateDriftFromPCMenuItem_DoubleClick(System::Object^  sender, System::EventArgs^  e)
{
	unsigned __int32 starttime = 0;
	String^ startstring = DriftFromListTimeTxt->Text;
	try
	{
		starttime = ::Convert::ToUInt32(startstring);
	}
	catch (...)
	{
		if (startstring->Length == 0)
			starttime = 0;
		else
		{
			::MessageBox::Show("Something wrong with the start time: '" + startstring + "'", "Error...");
			return;
		}
	}

	unsigned __int32 endtime = ::UInt32::MaxValue;
	String^ endstring = DriftFromListEndTimeTxt->Text;
	try
	{
		endtime = ::Convert::ToUInt32(endstring);
	}
	catch (...)
	{
		if (endstring->Length == 0)
			endtime = ::UInt32::MaxValue;
		else
		{
			::MessageBox::Show("Something wrong with the start time: '" + endstring + "'", "Error...");
			return;
		}
	}
	if (endtime < starttime)
	{
		::MessageBox::Show("End time can't be less than start time...", "Error...");
		return;
	}

	UVITMenu->HideDropDown();
	CreateDriftListMenuItem->HideDropDown();
	CreateDriftFromPCMenuItem->HideDropDown();

	OpenFileDialog^ dlg;
	String^ dir;
	String^ intslistfile;

	if (!UVDRIFTBATCH)
	{
		dir = (String^)GetReg("L2EventListPath");
		dlg = gcnew OpenFileDialog();
		dlg->InitialDirectory = dir;
		dlg->Filter = "FITS (*.fits)|*.fits";
		dlg->Multiselect = true;
		dlg->Title = "Select the Centroid INTEGERS List(s) (_XYInts_List)";
		if (dlg->ShowDialog() != ::DialogResult::OK)
			return;

		intslistfile = dlg->FileNames[0];
		dir = intslistfile->Substring(0,intslistfile->LastIndexOf("\\"));

		UVDRIFTAUTORUN = UVAutoApplyDriftandImageChck->Checked;

		if (dlg->FileNames->Length > 1)//batch, use higher level directory for L1 path
		{
			if (starttime != 0 || endtime != ::UInt32::MaxValue)
			{
				UVITMenu->ShowDropDown();
				CreateDriftListMenuItem->ShowDropDown();
				CreateDriftFromPCMenuItem->ShowDropDown();
				::MessageBox::Show("Doesn't make sense to specify Start and/or End time if doing a batch of files.  I'm going to stop.","Error...");
				return;
			}
			dir = dir->Substring(0,dir->LastIndexOf("\\"));
			UVDRIFTBATCH = true;
			UVDRIFTAUTORUN = true;
			UVCONVERTLISTTOIMAGEBATCH = false;
			UVAutoApplyDriftandImageChck->Checked = true;
			UVAutoDriftImageViewChck->Checked = false;
			UVDRIFTBATCHFILES = dlg->FileNames;
			UVDRIFTBATCHFILESINDEX = 0;
			AUTOLOADIMAGESFILES = gcnew array<String^>(dlg->FileNames->Length);
		}
		SetReg("L2EventListPath", dir);
	}
	else
	{
		intslistfile = UVDRIFTBATCHFILES[UVDRIFTBATCHFILESINDEX];
	}

	//ok so now send the filenames and dir to the worker arg, load the fits files and arrays there
	array<Object^>^ arg = gcnew array<Object^>(3);
	arg[0] = (Object^)intslistfile;
	arg[1] = (Object^)starttime;
	arg[2] = (Object^)endtime;

	if (UVDRIFTBATCH)
	{
		if (UVDRIFTBATCHFILESINDEX == 0)
		{
			DATE = ::DateTime::Now;
			Form1::Enabled = false;
			WAITBAR = gcnew JPWaitBar::WaitBar();
			WAITBAR->ProgressBar->Maximum = 100;
			//WAITBAR->DialogResult = ::DialogResult::OK;
			WAITBAR->Text = "File " + (UVDRIFTBATCHFILESINDEX+1).ToString() + " of " + UVDRIFTBATCHFILES->Length + ". Calculating drift...";
			DriftFromPCListWrkr->RunWorkerAsync(arg);
			WAITBAR->ShowDialog();
		}
		else
		{
			WAITBAR->Text = "File " + (UVDRIFTBATCHFILESINDEX+1).ToString() + " of " + UVDRIFTBATCHFILES->Length + ". Calculating drift...";
			DriftFromPCListWrkr->RunWorkerAsync(arg);
		}
	}
	else
	{
		Form1::Enabled = false;
		WAITBAR = gcnew JPWaitBar::WaitBar();
		WAITBAR->ProgressBar->Maximum = 100;
		//WAITBAR->DialogResult = ::DialogResult::OK;
		WAITBAR->Text = "File 1 of 1. Calculating drift...";
		DriftFromPCListWrkr->RunWorkerAsync(arg);
		WAITBAR->ShowDialog();
	}
}

void Form1::DriftFromPCListWrkr_DoWork(System::Object^  sender, System::ComponentModel::DoWorkEventArgs^  e)
{
	array<Object^>^ arg = (array<Object^>^)e->Argument;
	String^ intslistfile = (String^)arg[0];
	unsigned __int32 starttime = (unsigned __int32)arg[1];
	unsigned __int32 endtime = (unsigned __int32)arg[2];

	FitsFile^ intslist = gcnew JPFits::FitsFile(intslistfile,nullptr,true,false,false);
	array<double,2>^ ints = FitsFile::ReadImageArrayOnly(intslistfile, nullptr);

	String^ fraclistfile = intslistfile->Replace("Ints","Frac");
	array<double,2>^ frac = FitsFile::ReadImageArrayOnly(fraclistfile, nullptr);
	ints = JPMath::MatrixAddMatrix(ints,frac);
	ints = JPMath::MatrixAddScalar(ints,16);

	String^ timeslistfile = intslistfile->Remove(intslistfile->IndexOf("XYInts_List")) + "TimeList.fits";
	String^ deDrift = "_deDrift";
	while (intslistfile->Contains(deDrift))
	{
		timeslistfile = timeslistfile->Replace("TimeList","TimeList_deDrift");
		deDrift += "_deDrift";
	}
	if (!::IO::File::Exists(timeslistfile))
	{
		::MessageBox::Show("Error finding the Time List file...stopping.","Error");
		return;
	}
	FitsFile^ timeslist = gcnew FitsFile(timeslistfile,nullptr,true,false,false);
	array<double>^ times = FitsFile::ReadImageVectorOnly(timeslistfile,nullptr);

	if (starttime == 0)
	{
		starttime = (unsigned __int32)times[0];
		//auto-skip initial frame with 1000's counts & outside taper active-region
		array<int>^ ffsskip = JPMath::Find(times,starttime,"==");
		if (ffsskip->Length > 1000)
			starttime = (unsigned __int32)times[ffsskip[ffsskip->Length-1]+1];
	}
	if (endtime == ::UInt32::MaxValue)
		endtime = (unsigned __int32)times[times->Length-1];

	String^ xoffset = intslist->GetKeyValue("XOFFSET");//from GSE CCCDLAB processing
	if (xoffset == "")
		xoffset = intslist->GetKeyValue("WIN_XOFF");//from L2 data
	if (xoffset == "")
	{
		::MessageBox::Show("Can't find the image x-offset...stopping.","Error");
		return;
	}
	double ox = ::Convert::ToDouble(xoffset);//x offset

	String^ yoffset = intslist->GetKeyValue("YOFFSET");//from GSE CCCDLAB processing
	if (yoffset == "")
		yoffset = intslist->GetKeyValue("WIN_YOFF");//from L2 data
	if (yoffset == "")
	{
		::MessageBox::Show("Can't find the image y-offset...stopping.","Error");
		return;
	}
	double oy = ::Convert::ToDouble(yoffset);//y offset

	String^ sizex = intslist->GetKeyValue("XSIZE");
	if (sizex == "")
		sizex = intslist->GetKeyValue("WIN_X_SZ");
	if (sizex == "")
	{
		::MessageBox::Show("Can't find the image x-size...stopping.","Error");
		return;
	}
	double szx = ::Convert::ToDouble(sizex);//x size

	String^ sizey = intslist->GetKeyValue("YSIZE");
	if (sizey == "")
		sizey = intslist->GetKeyValue("WIN_Y_SZ");
	if (sizey == "")
	{
		::MessageBox::Show("Can't find the image y-size...stopping.","Error");
		return;
	}
	double szy = ::Convert::ToDouble(sizey);//y size

	double prec = 1;
	szx = (szx + 1)*prec;
	szy = (szy + 1)*prec;

	array<double,2>^ REFimg = gcnew array<double,2>((int)szx,(int)szy);
	array<double,2>^ relimg = gcnew array<double,2>((int)szx,(int)szy);
	array<double,2>^ img	= gcnew array<double,2>((int)szx,(int)szy);

	array<int>^ foundinds;
	int Ntimes = times->Length;
	int Nfound;
	int xpos, ypos;
	int c = 0;
	unsigned __int32 currtime = starttime;
	array<double>^ xyshift = gcnew array<double>(2){0,0};
	
	foundinds = JPMath::Find(times, starttime, "=");
	int RUNind = foundinds[0]-1;//running index in lists...start RUNind decremented because it increments in code below
	int ENDind = Ntimes-1;//indeces are 0-based
	int nstacks = (endtime-starttime)/(int(UVDRIFTSTACKTIME*1000));
	endtime = nstacks*((unsigned __int32)(UVDRIFTSTACKTIME*1000)) + starttime;
	foundinds = JPMath::Find(times, endtime, "<=");
	if (foundinds->Length > 0)
		ENDind = foundinds[foundinds->Length-1];
	int shiftlistlength = ENDind - RUNind;

	array<double,2>^ xyshiftsLIST = gcnew array<double,2>(3,shiftlistlength);//[time, xshift, yshift]

	array<int,2>^ find1s;
	int intprog = int(100*RUNind/Ntimes);
	int listcounter = -1;
	int k = 0;
	bool end = false;//the routine will have to tell when it is at the end of the time list

	double xshiftmean, yshiftmean, shiftcounter;

	while (!end)
	{
		if (WAITBAR->DialogResult == ::DialogResult::Cancel)
			return;
		if ((100*(listcounter+1))/shiftlistlength > intprog)
		{
			intprog = (100*(listcounter+1))/shiftlistlength;
			DriftFromPCListWrkr->ReportProgress(intprog);
		}

		if (RUNind+1 >= ENDind       /*  currtime + UVDRIFTSTACKTIME*1000 > endtime*/)
		{
			end = true;
			continue;
		}

		c++;
		img = gcnew array<double,2>((int)szx,(int)szy);

		foundinds = JPMath::Find(times, currtime + UVDRIFTSTACKTIME*1000, "<=", RUNind+1);
		Nfound = foundinds->Length;

		int j;
		try
		{
			for (j = 0; j < Nfound; j++)
			{
				xpos = (int)((ints[0,foundinds[j]] - ox*32)/32);
				ypos = (int)((ints[1,foundinds[j]] - oy*32)/32);

				if (xpos >=0 && ypos >= 0 && xpos <= szx-1 && ypos <= szy-1)
					img[xpos,ypos]++;
			}
		}
		catch (::Exception^ e)
		{
			::MessageBox::Show(e->Message + "   x" + xpos.ToString() + "   y" + ypos.ToString() + "    j"   + j.ToString() + " code section ziggy " + intslistfile + " xs" + img->GetLength(0) + " ys" + img->GetLength(1));
			/*WAITBAR->DialogResult = ::DialogResult::Cancel;
			return;*/
		}

		try
		{
			if (currtime == starttime)
			{				
				find1s = JPMath::Find(img,1,"=");
				REFimg = JPMath::Replace(img,find1s,0);

				for (k = 0; k < Nfound; k++)
				{
					listcounter++;
					xyshiftsLIST[0,listcounter] = times[RUNind+1 + k];
					xyshiftsLIST[1,listcounter] = 0;
					xyshiftsLIST[2,listcounter] = 0;
				}
			}
			else
			{
				find1s = JPMath::Find(img,1,"=");
				relimg = JPMath::Replace(img,find1s,0);

				try
				{
					xyshift = JPMath::XCorrImageLagShifts(REFimg, relimg, false, false);
				}
				catch (...)
				{
					xyshift = gcnew array<double>(2){0,0};
				}

				//correct strange large spikes???.......PC mode here
				double dxdt = (xyshift[0] - xyshiftsLIST[1,listcounter]/32) / UVDRIFTSTACKTIME;//x-pixels per second
				double dydt = (xyshift[1] - xyshiftsLIST[2,listcounter]/32) / UVDRIFTSTACKTIME;//y-pixels per second
				if (Math::Abs(dxdt) > 5)
				{
					//dxdt = (xyshiftsLIST[1,listcounter]/32 - xyshiftsLIST[1,listcounter-k-1]/32) / UVDRIFTSTACKTIME;  //why was it -k-1?
					dxdt = (xyshiftsLIST[1,listcounter]/32 - xyshiftsLIST[1,listcounter-1]/32) / UVDRIFTSTACKTIME;
					xyshift[0] = xyshiftsLIST[1,listcounter]/32 + dxdt*(times[RUNind+1]/1000 - xyshiftsLIST[0,listcounter]/1000);
				}
				if (Math::Abs(dydt) > 5)
				{
					//dydt = (xyshiftsLIST[2,listcounter]/32 - xyshiftsLIST[2,listcounter-k-1]/32) / UVDRIFTSTACKTIME;  //why was it -k-1?
					dydt = (xyshiftsLIST[2,listcounter]/32 - xyshiftsLIST[2,listcounter-1]/32) / UVDRIFTSTACKTIME;
					xyshift[1] = xyshiftsLIST[2,listcounter]/32 + dydt*(times[RUNind+1]/1000 - xyshiftsLIST[0,listcounter]/1000);
				}
				//done correction

				xshiftmean += xyshift[0];
				yshiftmean += xyshift[1];
				shiftcounter++;

				for (k = 0; k < Nfound; k++)
				{
					listcounter++;
					xyshiftsLIST[0,listcounter] = times[RUNind+1 + k];
					xyshiftsLIST[1,listcounter] = (double)int(xyshift[0]*32);
					xyshiftsLIST[2,listcounter] = (double)int(xyshift[1]*32);
					if (listcounter+1 == shiftlistlength)
					{
						end = true;
						break;
					}
				}
			}
		}
		catch (Exception^ e)
		{
			::MessageBox::Show(e->Message + "  " + e->Data + "   " + e->TargetSite + "  " + e->StackTrace + "   " + e->Source + "	" /*+ (listcounter-k-1).ToString()*/);
		}

		RUNind = foundinds[Nfound-1];
		if (RUNind == Ntimes-1)
			end = true;
		else
			currtime = (unsigned __int32)times[RUNind+1];
	}

	bool doInterp = DriftFromPCInterpolateChck->Checked;
	int interpN;
	try
	{
		if (doInterp)
		{
			int u = 1;
			for (int i = 0; i < shiftlistlength-1; i++)
				if (xyshiftsLIST[1,i] != xyshiftsLIST[1,i+1] || xyshiftsLIST[2,i] != xyshiftsLIST[2,i+1])
					u++;//number of unique drift positions
			int rememberu = u;

			array<double>^ t0 = gcnew array<double>(u);
			array<double>^ x0 = gcnew array<double>(u);
			array<double>^ y0 = gcnew array<double>(u);
			array<double>^ dxdt = gcnew array<double>(u);
			array<double>^ dydt = gcnew array<double>(u);

			u = 0;
			double tstart = xyshiftsLIST[0,0];
			double tend;
			for (int i = 0; i < shiftlistlength-1; i++)
			{
				if (xyshiftsLIST[1,i] != xyshiftsLIST[1,i+1] || xyshiftsLIST[2,i] != xyshiftsLIST[2,i+1])
				{
					tend = xyshiftsLIST[0,i];
					t0[u] = (tstart + tend)/2;
					x0[u] = xyshiftsLIST[1,i];
					y0[u] = xyshiftsLIST[2,i];
					u++;
					tstart = tend;
				}
			}
			t0[rememberu-1] = xyshiftsLIST[0,shiftlistlength-1];
			x0[rememberu-1] = xyshiftsLIST[1,shiftlistlength-1];
			y0[rememberu-1] = xyshiftsLIST[2,shiftlistlength-1];

			//smoothing
			interpN = DriftSmoothNDrop->SelectedIndex;
			if (interpN < 0)
				interpN = 3;
			else
				interpN = 3 + interpN*2;

			double mx0 = JPMath::Mean(x0);
			double my0 = JPMath::Mean(y0);

			x0 = JPMath::Smooth(x0,interpN);
			y0 = JPMath::Smooth(y0,interpN);

			double mx1 = JPMath::Mean(x0);
			double my1 = JPMath::Mean(y0);

			x0 = JPMath::VectorSubScalar(x0,mx1-mx0);
			y0 = JPMath::VectorSubScalar(y0,my1-my0);
			//done smoothing

			for (int i = 0; i < rememberu-1; i++)
			{
				dxdt[i] = (x0[i+1] - x0[i])/(t0[i+1] - t0[i]);
				dydt[i] = (y0[i+1] - y0[i])/(t0[i+1] - t0[i]);
			}
			dxdt[rememberu-1] = dxdt[rememberu-2];
			dydt[rememberu-1] = dydt[rememberu-2];

			u = 0;
			int i = 0;
			for (i ; i < shiftlistlength; i++)
			{
				while (xyshiftsLIST[0,i] <= t0[u+1])
				{
					xyshiftsLIST[1,i] = x0[u] + Math::Round(dxdt[u]*(xyshiftsLIST[0,i] - t0[u]));
					xyshiftsLIST[2,i] = y0[u] + Math::Round(dydt[u]*(xyshiftsLIST[0,i] - t0[u]));
					i++;
				}
				u++;
				i--;
				if (u >= rememberu-2)
					break;
			}
			for (i; i <  shiftlistlength; i++)
			{
				xyshiftsLIST[1,i] = x0[rememberu-1] + Math::Round(dxdt[rememberu-1]*(xyshiftsLIST[0,i] - t0[rememberu-1]));
				xyshiftsLIST[2,i] = y0[rememberu-1] + Math::Round(dydt[rememberu-1]*(xyshiftsLIST[0,i] - t0[rememberu-1]));
			}
		}
	}
	catch (Exception^ e)
	{
		::MessageBox::Show(e->Message + "  " + e->Data + "    " + e->TargetSite + "   " + e->Source + "   " + e->StackTrace);
	}

	String^ driftslistfile;
	if (doInterp)
		driftslistfile = intslistfile->Replace("XYInts_List", "XYDrift_List" + "_" + UVDRIFTSTACKTIME.ToString() + "s" + "_Sm" + interpN.ToString());
	else
		driftslistfile = intslistfile->Replace("XYInts_List", "XYDrift_List" + "_" + UVDRIFTSTACKTIME.ToString() + "s");
	driftslistfile = driftslistfile->Replace(".fits",".drift");

	xshiftmean /= shiftcounter;
	yshiftmean /= shiftcounter;
	#pragma omp parallel for
	for (int i = 0; i < xyshiftsLIST->GetLength(1); i++)
	{
		xyshiftsLIST[1,i] -= xshiftmean*32;
		xyshiftsLIST[2,i] -= yshiftmean*32;
	}

	FitsFile^ driftfits = gcnew FitsFile(driftslistfile,xyshiftsLIST,false);
	driftfits->CopyHeader(timeslist);
	driftfits->WriteFile(::TypeCode::Double);
	UVPLOTDRIFTFILENAME = driftslistfile;
	UVAPPLYDRIFTCENTROIDSFILENAME = intslistfile;
}

void Form1::DriftFromPCListWrkr_ProgressChanged(System::Object^  sender, System::ComponentModel::ProgressChangedEventArgs^  e)
{
	WAITBAR->ProgressBar->Value = e->ProgressPercentage;
	WAITBAR->TextMsg->Text = String::Concat("Completed: ",e->ProgressPercentage,"%");
	WAITBAR->Refresh();
}

void Form1::DriftFromPCListWrkr_RunWorkerCompleted(System::Object^  sender, System::ComponentModel::RunWorkerCompletedEventArgs^  e)
{
	if (WAITBAR->DialogResult != ::DialogResult::Cancel)
	{
		if (!UVDRIFTAUTORUN)
		{
			WAITBAR->Close();
			Form1::Enabled = true;
			Form1::Focus();

			::DialogResult res = ::MessageBox::Show("Completed making the drift correction list.  Would you like to plot it?","Finished...",::MessageBoxButtons::YesNo);
			if (res == ::DialogResult::No)
				return;
			if (res == ::DialogResult::Yes)
			{
				UVPLOTDRIFTLISTNOW = true;
				PlotDriftListMenuItem->PerformClick();
			}
			res = ::MessageBox::Show("Would you like to apply this drift calculation to the centroid list?","Apply drift...",::MessageBoxButtons::YesNo);
			if (res == ::DialogResult::Cancel)
				return;
			if (res == ::DialogResult::Yes)
			{
				XDRIFT_PLOT->Close();
				YDRIFT_PLOT->Close();
				UVAPPLYDRIFTNOW = true;
				PCModeDriftSelfCorrectionMenuItem->PerformClick();
			}
		}
		else
		{
			WAITBAR->Text = "Applying...";
			WAITBAR->TextMsg->Text = "Applying drift to centroid list...";
			WAITBAR->CancelBtn->Enabled = false;
			WAITBAR->Refresh();
			UVAPPLYDRIFTNOW = true;
			PCModeDriftSelfCorrectionMenuItem->PerformClick();
		}
	}
	else
	{
		UVAPPLYDRIFTNOW = false;
		UVDRIFTBATCH = false;
		WAITBAR->Close();
		Form1::Enabled = true;
		Form1::Focus();
	}
}

void Form1::ApplyDriftListMentuItem_Click(System::Object^  sender, System::EventArgs^  e)
{
	String^ driftlistfile;

	OpenFileDialog^ dlg;
	if (UVAPPLYDRIFTNOW)
	{
		//UVAPPLYDRIFTNOW = false;//done below
		driftlistfile = UVPLOTDRIFTFILENAME;
		WAITBAR->ProgressBar->Value = 100;
		WAITBAR->ProgressBar->Update();
		ApplyDriftListWrkr->RunWorkerAsync(driftlistfile);
	}
	else
	{
		UVAPPLYDRIFTNOW = false;
		String^ dir = (String^)GetReg("L2EventListPath");
		dlg = gcnew OpenFileDialog();
		dlg->InitialDirectory = dir;
		dlg->Filter = "FITS (*.fits)|*.fits";
		dlg->Multiselect = false;

		dlg->Title = "Select the DRIFT List (_XYDrift_List)";
		dlg->Filter = "DRIFT (*.drift)|*.drift";
		if (dlg->ShowDialog() != ::DialogResult::OK)
			return;
		driftlistfile = dlg->FileName;
		dir = driftlistfile->Substring(0,driftlistfile->LastIndexOf("\\"));
		SetReg("L2EventListPath", dir);

		dlg = gcnew OpenFileDialog();
		dlg->Title = "Select the Centroid INTEGERS List (_XYInts_List)";
		dlg->Filter = "FITS (*.fits)|*.fits";
		dlg->InitialDirectory = dir;
		dlg->Multiselect = false;
		if (dlg->ShowDialog() != ::DialogResult::OK)
			return;
		UVAPPLYDRIFTCENTROIDSFILENAME = dlg->FileName;

		WAITBAR = gcnew JPWaitBar::WaitBar();
		WAITBAR->Text = "Applying Drift";
		WAITBAR->TextMsg->Text = "Please wait...";
		WAITBAR->CancelBtn->Enabled = false;
		ApplyDriftListWrkr->RunWorkerAsync(driftlistfile);
		WAITBAR->ShowDialog();
	}
}

void Form1::ApplyDriftListWrkr_DoWork(System::Object^  sender, System::ComponentModel::DoWorkEventArgs^  e)
{
	String^ driftlistfile = (String^)e->Argument;

	FitsFile^ driftsfits = gcnew JPFits::FitsFile(driftlistfile, nullptr, true, false, false);
	array<double, 2>^ drifts = FitsFile::ReadImageArrayOnly(driftlistfile, nullptr);

	String^ timelistfile = driftlistfile->Remove(driftlistfile->IndexOf("XYDrift")) + "TimeList.fits";
	String^ deDrift = "_deDrift";
	while (driftlistfile->Contains(deDrift))
	{
		timelistfile = timelistfile->Replace("TimeList", "TimeList_deDrift");
		deDrift += "_deDrift";
	}
	OpenFileDialog^ dlg;
	if (!::IO::File::Exists(timelistfile))
	{
		dlg = gcnew OpenFileDialog();
		dlg->Title = "Select the Centroid TIME List (_TimeList)";
		dlg->Filter = "FITS (*.fits)|*.fits";
		if (dlg->ShowDialog() != ::DialogResult::OK)
			return;
		timelistfile = dlg->FileName;
	}
	array<double>^ times = FitsFile::ReadImageVectorOnly(timelistfile, nullptr);

	String^ framelistfile = timelistfile->Replace("Time", "Frame");
	if (!::File::Exists(framelistfile))
	{
		::MessageBox::Show("Frame List not found.  Error & exiting...");
		return;
	}
	array<double>^ frames = FitsFile::ReadImageVectorOnly(framelistfile, nullptr);

	String^ flatlistfile = timelistfile->Replace("Time", "Flat");
	if (!::File::Exists(flatlistfile))
	{
		::MessageBox::Show("Flat Field List not found.  Error & exiting...");
		return;
	}
	array<double>^ flats = FitsFile::ReadImageVectorOnly(flatlistfile, nullptr);

	String^ mdMmlistfile = timelistfile->Replace("TimeList", "XYmdMm_List");
	mdMmlistfile = mdMmlistfile->Replace("drift", "fits");
	if (!::File::Exists(mdMmlistfile))
	{
		::MessageBox::Show("Max Min Corners List not found.  Error & exiting...");
		return;
	}
	array<double, 2>^ mdMms = FitsFile::ReadImageArrayOnly(mdMmlistfile, nullptr);

	String^ HJDlistfile = timelistfile->Replace("TimeList", "HJDList");
	HJDlistfile = HJDlistfile->Replace("drift", "fits");
	if (!::File::Exists(HJDlistfile))
	{
		::MessageBox::Show("HJDList Time List not found.  Error & exiting...");
		return;
	}
	array<double>^ HJDS = FitsFile::ReadImageVectorOnly(HJDlistfile, nullptr);

	String^ intslistfile;
	if (UVAPPLYDRIFTNOW)
		UVAPPLYDRIFTNOW = false;
	intslistfile = UVAPPLYDRIFTCENTROIDSFILENAME;
	array<double, 2>^ ints = FitsFile::ReadImageArrayOnly(intslistfile, nullptr);

	String^ fraclistfile = intslistfile->Replace("Ints", "Frac");
	array<double, 2>^ frac = FitsFile::ReadImageArrayOnly(fraclistfile, nullptr);

	//make exposure array
	array<double, 2>^ exposurearray;
	int offset = 0;
	double res = 1;
	int sz = int(600 / res);
	bool createexposurearray = ApplyDriftCreateExpArrayChc->Checked;
	if (createexposurearray)
	{
		exposurearray = gcnew array<double, 2>(sz, sz);

		WAITBAR->Text = "Exposure Array...";
		WAITBAR->TextMsg->Text = "Creating exposure array...please wait...";
		WAITBAR->Refresh();

		offset = 44/int(res);
		double xcenter, ycenter, radius;
		String^ detector = driftsfits->GetKeyValue("DETECTOR");
		if (detector == "FUV")
		{
			xcenter = 255/res + (double)offset;
			ycenter = 253/res + (double)offset;
			radius = 253/res;
		}
		if (detector = "NUV")
		{
			xcenter = 254/res + (double)offset;
			ycenter = 255/res + (double)offset;
			radius = 252/res;
		}
		double radiussq = radius * radius;
		//get number of frames...and do within...?
		double time = -1;
		double nframes = 0;
		for (int i = 0; i < driftsfits->Height; i++)
		{
			if (time != drifts[0, i])//new drift frame time...should be new drift...also very first element
			{
				time = drifts[0, i];
				nframes++;
			}
		}

		#pragma omp parallel for
		for (int x = 0; x < sz; x++)
			for (int y = 0; y < sz; y++)
				exposurearray[x, y] = nframes;

		double dx = 0;
		double dy = 0;
		double oldxdrift = drifts[1, 0];
		double oldydrift = drifts[2, 0];
		time = -1;
		for (int i = 0; i < driftsfits->Height; i++)
		{
			if (time != drifts[0, i])//new drift frame time...should be new drift...also very first element
			{
				time = drifts[0, i];

				dx = drifts[1, i] - oldxdrift;
				dy = drifts[2, i] - oldydrift;
				oldxdrift = drifts[1, i];
				oldydrift = drifts[2, i];

				xcenter += dx / 32/res;
				ycenter += dy / 32/res;

				#pragma omp parallel for
				for (int x = 0; x < sz; x++)
					for (int y = 0; y < sz; y++)
						if (((double)x - xcenter)*((double)x - xcenter) + ((double)y - ycenter)*((double)y - ycenter) > radiussq)
							exposurearray[x, y]--;
			}
		}

		exposurearray = JPMath::MatrixDivScalar(exposurearray, double(nframes));
		FitsFile^ exp = gcnew FitsFile(CCDLABPATH + "test.fits", exposurearray, false);
		exp->WriteFile(::TypeCode::Double);
	}

	WAITBAR->Text = "Applying...";
	WAITBAR->TextMsg->Text = "Applying drift...";
	WAITBAR->Refresh();

	//so now use the times from drifts to align on the time from times, and apply onto new ints array and save that array
	double t0 = drifts[0, 0];
	//array<int>^ startindeces = JPMath::Find(times, t0, "=");
	//int t0index = startindeces[0];
	int t0index = JPMath::Find(times, t0, "=", true);

	//will need dedrifted ints and fracs so they align...
	array<double, 2>^ dedriftedXYInts = gcnew array<double, 2>(2, driftsfits->Height);
	array<double, 2>^ dedriftedXYFrac = gcnew array<double, 2>(2, driftsfits->Height);
	array<double>^   dedriftedFlat = gcnew array<double>(driftsfits->Height);
	array<double>^   dedriftedTime = gcnew array<double>(driftsfits->Height);
	array<double>^   dedriftedFrame = gcnew array<double>(driftsfits->Height);
	array<double, 2>^ dedriftedXYmdMm = gcnew array<double, 2>(2, driftsfits->Height);
	array<double>^   dedriftedHJD = gcnew array<double>(driftsfits->Height);
	array<double>^   dedriftedExposure;
	if (createexposurearray)
		dedriftedExposure = gcnew array<double>(driftsfits->Height);

	#pragma omp parallel for
	for (int i = 0; i < driftsfits->Height; i++)
	{
		dedriftedXYInts[0, i] = ints[0, t0index + i] - drifts[1, i];
		dedriftedXYInts[1, i] = ints[1, t0index + i] - drifts[2, i];

		dedriftedXYFrac[0, i] = frac[0, t0index + i];
		dedriftedXYFrac[1, i] = frac[1, t0index + i];

		dedriftedFlat[i] = flats[t0index + i];
		dedriftedTime[i] = times[t0index + i];
		dedriftedFrame[i] = frames[t0index + i];

		dedriftedXYmdMm[0, i] = mdMms[0, t0index + i];
		dedriftedXYmdMm[1, i] = mdMms[1, t0index + i];

		dedriftedHJD[i] = HJDS[t0index + i];

		if (createexposurearray)
		{
			int xpos = (int)(dedriftedXYInts[0, i]/32/res) + offset;
			int ypos = (int)(dedriftedXYInts[1, i]/32/res) + offset;
			if (xpos < 0 || ypos < 0 || xpos >= sz || ypos >= sz)
				dedriftedExposure[i] = 1;
			else
				dedriftedExposure[i] = exposurearray[xpos, ypos];
		}
	}

	WAITBAR->Text = "Saving...";
	WAITBAR->TextMsg->Text = "Saving de-drifted lists...";
	WAITBAR->Refresh();

	//then save the dedrifted lists
	driftsfits->SetKey("HJD0", dedriftedHJD[0].ToString("#.0000000"), "HJD of start of imaging", true, 14);//now it will get added to all other copyheaders's

	int ind = intslistfile->LastIndexOf(".");
	String^ dedriftedXYIntsFile = intslistfile->Insert(ind, "_deDrift");
	FitsFile^ dedriftedXYIntsFits = gcnew FitsFile(dedriftedXYIntsFile, dedriftedXYInts, false);
	dedriftedXYIntsFits->CopyHeader(driftsfits);
	dedriftedXYIntsFits->WriteFile(::TypeCode::Int16);

	ind = fraclistfile->LastIndexOf(".");
	String^ dedriftedXYFracFile = fraclistfile->Insert(ind, "_deDrift");
	FitsFile^ dedriftedXYFracFits = gcnew FitsFile(dedriftedXYFracFile, dedriftedXYFrac, false);
	dedriftedXYFracFits->CopyHeader(driftsfits);
	dedriftedXYFracFits->WriteFile(::TypeCode::Int16);

	ind = flatlistfile->LastIndexOf(".");
	String^ dedriftedFlatFile = flatlistfile->Insert(ind, "_deDrift");
	FitsFile^ dedriftedFlatFits = gcnew FitsFile(dedriftedFlatFile, dedriftedFlat, false);
	dedriftedFlatFits->CopyHeader(driftsfits);
	dedriftedFlatFits->WriteFile(::TypeCode::Double);

	ind = timelistfile->LastIndexOf(".");
	String^ dedriftedTimeFile = timelistfile->Insert(ind, "_deDrift");
	FitsFile^ dedriftedTimeFits = gcnew FitsFile(dedriftedTimeFile, dedriftedTime, false);
	dedriftedTimeFits->CopyHeader(driftsfits);
	dedriftedTimeFits->WriteFile(::TypeCode::UInt32);

	ind = framelistfile->LastIndexOf(".");
	String^ dedriftedFrameFile = framelistfile->Insert(ind, "_deDrift");
	FitsFile^ dedriftedFrameFits = gcnew FitsFile(dedriftedFrameFile, dedriftedFrame, false);
	dedriftedFrameFits->CopyHeader(driftsfits);
	dedriftedFrameFits->WriteFile(::TypeCode::UInt16);

	ind = mdMmlistfile->LastIndexOf(".");
	String^ dedriftedXYmdMmFile = mdMmlistfile->Insert(ind, "_deDrift");
	FitsFile^ dedriftedXYmdMmFits = gcnew FitsFile(dedriftedXYmdMmFile, dedriftedXYmdMm, false);
	dedriftedXYmdMmFits->CopyHeader(driftsfits);
	dedriftedXYmdMmFits->WriteFile(::TypeCode::Int16);

	ind = HJDlistfile->LastIndexOf(".");
	String^ dedriftedHJDFile = HJDlistfile->Insert(ind, "_deDrift");
	FitsFile^ dedriftedHJDFits = gcnew FitsFile(dedriftedHJDFile, dedriftedHJD, false);
	dedriftedHJDFits->CopyHeader(driftsfits);
	dedriftedHJDFits->WriteFile(::TypeCode::Double);

	if (createexposurearray)
	{
		String^ dedriftedExpFile = dedriftedTimeFile->Replace("TimeList", "ExpArray");
		FitsFile^ dedriftedExpFits = gcnew FitsFile(dedriftedExpFile, dedriftedExposure, false);
		dedriftedExpFits->CopyHeader(driftsfits);
		dedriftedExpFits->WriteFile(::TypeCode::Double);
	}

	if (!UVDRIFTAUTORUN)
	{
		WAITBAR->Close();
		::DialogResult res = ::MessageBox::Show("Completed applying the drift correction. Would you like to create the image using current image settings?", "Finished...", ::MessageBoxButtons::YesNo);
		if (res == ::DialogResult::No)
			return;
		if (res == ::DialogResult::Yes)
		{
			UVCREATEIMAGENOW = true;
			UVCREATEIMAGEFILENAME = dedriftedXYIntsFile;
			ConvertListToImgMenu_DropDownOpened(sender, e);
			ConvertListToImgMenu->HideDropDown();
			ConvertListToImgMenu_Click(sender, e);
		}
	}
	else
	{
		WAITBAR->Text = "Image...";
		WAITBAR->TextMsg->Text = "Creating image...";
		WAITBAR->Refresh();

		UVCREATEIMAGENOW = true;
		UVCREATEIMAGEFILENAME = dedriftedXYIntsFile;
		ConvertListToImgMenu_DropDownOpened(sender, e);
		ConvertListToImgMenu->HideDropDown();
		ConvertListToImgMenu_Click(sender, e);
	}
}

void Form1::PlotCountsPerFrameMenuItem_Click(System::Object^  sender, System::EventArgs^  e)
{
	String^ dir = (String^)GetReg("L2EventListPath");
	OpenFileDialog^ dlg = gcnew OpenFileDialog();
	dlg->InitialDirectory = dir;
	dlg->Filter = "FITS (*.fits)|*.fits";
	dlg->Multiselect = false;

	dlg->Title = "Select the TIME List (_TimeList)";
	if (dlg->ShowDialog() != ::DialogResult::OK)
		return;
	String^ timelistfile = dlg->FileName;
	dir = timelistfile->Substring(0,timelistfile->LastIndexOf("\\"));
	SetReg("L2EventListPath", dir);
	FitsFile^ timefits = gcnew JPFits::FitsFile(timelistfile,nullptr,true,false,false);
	array<double>^ time = FitsFile::ReadImageVectorOnly(timelistfile,nullptr);

	//find number of unique times
	int c = 1;
	double t0 = time[0];
	for (int i = 0; i < time->Length; i++)
		if (t0 != time[i])
		{
			c++;
			t0 = time[i];
		}

	array<double>^ plottime = gcnew array<double>(c);
	array<double>^ plotcount = gcnew array<double>(c);

	c = 0;
	t0 = time[0];
	int ind = -1;
	for (int i = 0; i < time->Length; i++)
	{
		if (t0 == time[i])
		{
			c++;
		}
		else
		{
			ind++;
			plotcount[ind] = double(c);
			plottime[ind] = t0/1000;
			c = 1;
			t0 = time[i];
		}
	}
	plotcount[ind+1] = double(c);
	plottime[ind+1] = t0/1000;

	String^ title = "Orbit: " + timefits->GetKeyValue("ORB_NUM") + "; Source: " + timefits->GetKeyValue("SOURCEID") + "; Detector:" + timefits->GetKeyValue("DETECTOR");

	JPPlot^ jpplot = gcnew JPPlot();
	jpplot->Text = title;
	jpplot->PlotLine(plottime,plotcount,"Frame Time (seconds)","Counts in Frame",title, Charting::SeriesChartType::Point);
}

void Form1::perTimeBinMenuItem_Click(System::Object^  sender, System::EventArgs^  e)
{
	double tbin;
	try
	{
		tbin = ::Convert::ToDouble(((String^)plotPerTimeBinComboBox->SelectedItem)->Replace("s",""));
	}
	catch (...)
	{
		::MessageBox::Show("Please select time bin from the drop down...","Warning");
		return;
	}

	String^ dir = (String^)GetReg("L2EventListPath");
	OpenFileDialog^ dlg = gcnew OpenFileDialog();
	dlg->InitialDirectory = dir;
	dlg->Filter = "FITS (*.fits)|*.fits";
	dlg->Multiselect = false;

	dlg->Title = "Select the TIME List (_TimeList)";
	if (dlg->ShowDialog() != ::DialogResult::OK)
		return;
	String^ timelistfile = dlg->FileName;
	dir = timelistfile->Substring(0,timelistfile->LastIndexOf("\\"));
	SetReg("L2EventListPath", dir);
	FitsFile^ timefits = gcnew JPFits::FitsFile(timelistfile,nullptr,true,false,false);
	array<double>^ times = FitsFile::ReadImageVectorOnly(timelistfile,nullptr);

	bool goodselection = false;
	if (timelistfile->Contains("TimeList"))
	{
		goodselection = true;
		for (int i = 0; i < times->Length; i++)
			times[i] /= 1000;//convert to seconds
	}
	if (timelistfile->Contains("HJDList"))
	{
		goodselection = true;
		for (int i = 0; i < times->Length; i++)
			times[i] *= 86400;//convert to seconds
	}
	if (!goodselection)
	{
		::MessageBox::Show("Doesn't seem like you selected a time list...","Error");
		return;
	}

	double nbins = Math::Floor((times[times->Length-1] - times[0])/tbin);

	if (nbins <= 1)
	{
		::MessageBox::Show("Time bin is too large for the selected time list...","Error");
		return;
	}

	array<double>^ bintimes = gcnew array<double>((int)nbins);
	array<double>^ bincounts = gcnew array<double>((int)nbins);

	double currtime = times[0];
	int bin = 0;
	int c = 0;
	double count = 0;

	while (bin < nbins)
	{
		while (times[c] < currtime + tbin)
		{
			c++;
			count++;
		}
		bincounts[bin] = count;
		bintimes[bin] = currtime + tbin/2;
		currtime += tbin;
		count = 0;
		bin++;
	}

	String^ title = "Orbit: " + timefits->GetKeyValue("ORB_NUM") + "; Source: " + timefits->GetKeyValue("SOURCEID") + "; Detector:" + timefits->GetKeyValue("DETECTOR");

	JPPlot^ jpplot = gcnew JPPlot();
	jpplot->Text = title;
	jpplot->PlotLine(bintimes,bincounts,"Bin Time (seconds)","Counts in Bin",title, Charting::SeriesChartType::Point);

}

void Form1::CrossCorrINTDriftChck_Click(System::Object^  sender, System::EventArgs^  e)
{
	if (CrossCorrINTDriftChck->Checked == false)
		CrossCorrINTDriftChck->Checked = true;
	UVITMenu->ShowDropDown();
	CreateDriftListMenuItem->ShowDropDown();
	CreateDriftFromINTMenuItem->ShowDropDown();
	SetReg("CrossCorrINTDrift",CrossCorrINTDriftChck->Checked);
	if (CrossCorrINTDriftChck->Checked)
		PointSrcINTDriftChck->Checked = false;
	SetReg("PointSrcINTDrift",PointSrcINTDriftChck->Checked);
	TryAutoDeBiasINTDrift->Checked = true;
	TryAutoDeBiasINTDrift->Enabled = true;
	SetReg("AutoDeBiasINTDriftChck",TryAutoDeBiasINTDrift->Checked);
	SetReg("AutoDeBiasINTDriftEnab",TryAutoDeBiasINTDrift->Enabled);
}

void Form1::PointSrcINTDriftChck_Click(System::Object^  sender, System::EventArgs^  e)
{
	if (PointSrcINTDriftChck->Checked == false)
		PointSrcINTDriftChck->Checked = true;
	UVITMenu->ShowDropDown();
	CreateDriftListMenuItem->ShowDropDown();
	CreateDriftFromINTMenuItem->ShowDropDown();
