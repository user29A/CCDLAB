void Form1::UVIT_ApplyCPUCorrectionMenu_Click(System::Object^  sender, System::EventArgs^  e)
{
	String^ dir = (String^)GetReg("L2EventListPath");
	OpenFileDialog^ dlg = gcnew OpenFileDialog();
	dlg->InitialDirectory = dir;
	dlg->Filter = "FITS (*.fits)|*.fits";
	dlg->Multiselect = false;
	dlg->Title = "Select the Centroid INTEGERS List (_XYInts_List)";
	if (dlg->ShowDialog() != ::DialogResult::OK)
		return;
	String^ IntsFileList = dlg->FileName;
	String^ FracFileList = IntsFileList->Replace("Ints","Frac");
	FitsFile^ IntsFits = gcnew JPFits::FitsFile(IntsFileList,nullptr,true,true,false);
	FitsFile^ FracFits = gcnew JPFits::FitsFile(FracFileList,nullptr,true,true,false);

	int ind = dlg->FileName->LastIndexOf("\\");
	dir = dlg->FileName->Substring(0,ind);
	SetReg("L2EventListPath",dir);

	String^ CPUXDistFile;
	String^ CPUYDistFile;
	String^ channel = IntsFits->GetKeyValue("CHANNEL");
	if (channel->Length == 0)
		channel = IntsFits->GetKeyValue("DETECTOR");
	if (channel == "FUV")
	{
		if (::File::Exists("C:\\UVIT_CalDB\\Distortion\\FUV_dist_dX.fits"))
		{
			CPUXDistFile = "C:\\UVIT_CalDB\\Distortion\\FUV_dist_dX.fits";
			CPUYDistFile = "C:\\UVIT_CalDB\\Distortion\\FUV_dist_dY.fits";
		}
	}
	else if (channel == "NUV")
	{
		if (::File::Exists("C:\\UVIT_CalDB\\Distortion\\NUV_dist_dX.fits"))
		{
			CPUXDistFile = "C:\\UVIT_CalDB\\Distortion\\NUV_dist_dX.fits";
			CPUYDistFile = "C:\\UVIT_CalDB\\Distortion\\NUV_dist_dY.fits";
		}
	}
	else if (channel == "VIS")
	{
		if (::File::Exists("C:\\UVIT_CalDB\\Distortion\\VIS_dist_dX.fits"))
		{
			CPUXDistFile = "C:\\UVIT_CalDB\\Distortion\\VIS_dist_dX.fits";
			CPUYDistFile = "C:\\UVIT_CalDB\\Distortion\\VIS_dist_dY.fits";
		}
	}
	else
	{
		//get the CPU *X* correction image
		dlg->Title = "Select CPU *X* Correction FITS Image File";
		dlg->InitialDirectory = (String^)GetReg("OpenCPUDistPath");
		if (dlg->ShowDialog() != ::DialogResult::OK)
			return;
		String^ CPUXDistFile = dlg->FileName;
		ind = dlg->FileName->LastIndexOf("\\");
		dir = dlg->FileName->Substring(0,ind);
		SetReg("OpenCPUDistPath",dir);

		//get the CPU *Y* correction image
		dlg->Title = "Select CPU *Y* Correction FITS Image File";
		dlg->InitialDirectory = dir;
		if (dlg->ShowDialog() != ::DialogResult::OK)
			return;
		String^ CPUYDistFile = dlg->FileName;
	}
	JPFits::FitsFile^ CPUXDistFits = gcnew JPFits::FitsFile(CPUXDistFile,nullptr,true,true,false);
	JPFits::FitsFile^ CPUYDistFits = gcnew JPFits::FitsFile(CPUYDistFile,nullptr,true,true,false);
	
	int xcorr, ycorr;
	int NPts = FracFits->Height;
	#pragma omp parallel for private(xcorr, ycorr)
	for(int j = 0; j < NPts; j++)//now apply Distortion correction...just apply it to the integer values which are 1/32 pixel anyway
	{
		xcorr = int(32*CPUXDistFits->Image[int(IntsFits->Image[0,j]/32), int(IntsFits->Image[1,j]/32)]);
	    ycorr = int(32*CPUYDistFits->Image[int(IntsFits->Image[0,j]/32), int(IntsFits->Image[1,j]/32)]);

		IntsFits->Image[0,j] -= xcorr;
		IntsFits->Image[1,j] -= ycorr;
	}

	ind = IntsFileList->LastIndexOf(".");
	IntsFileList = IntsFileList->Insert(ind,"_deDist");
	ind = FracFileList->LastIndexOf(".");
	FracFileList = FracFileList->Insert(ind,"_deDist");
	IntsFits->WriteFile(IntsFileList,TypeCode::Int16);
	FracFits->WriteFile(FracFileList,TypeCode::Int16);

	::MessageBox::Show("CPU Distortion Correction Completed...","Finished...");
}

void Form1::UVIT_ApplyFPNMenu_Click(System::Object^  sender, System::EventArgs^  e)
{
	String^ dir = (String^)GetReg("L2EventListPath");
	OpenFileDialog^ dlg = gcnew OpenFileDialog();
	dlg->InitialDirectory = dir;
	dlg->Filter = "FITS (*.fits)|*.fits";
	dlg->Multiselect = false;
	dlg->Title = "Select the Centroid INTEGERS List (_XYInts_List)";
	if (dlg->ShowDialog() != ::DialogResult::OK)
		return;
	String^ IntsFileList = dlg->FileName;
	String^ FracFileList = IntsFileList->Replace("Ints","Frac");
	FitsFile^ IntsFits = gcnew JPFits::FitsFile(IntsFileList,nullptr,true,true,false);
	FitsFile^ FracFits = gcnew JPFits::FitsFile(FracFileList,nullptr,true,true,false);

	int ind = dlg->FileName->LastIndexOf("\\");
	dir = dlg->FileName->Substring(0,ind);
	SetReg("L2EventListPath",dir);

	String^ FPNFile;
	String^ channel = IntsFits->GetKeyValue("CHANNEL");
	if (channel->Length == 0)
		channel = IntsFits->GetKeyValue("DETECTOR");
	String^ alg = IntsFits->GetKeyValue("CENTROID");
	if (alg->Length == 0)
		alg = IntsFits->GetKeyValue("ALGRITHM");
	bool FPNsuccess = false;
	if (channel == "FUV")
	{
		if (alg == "3S" || alg == "3x3 Square")
		{
			if (::File::Exists("C:\\UVIT_CalDB\\FPN\\FUV 3Sq FPN.fits"))
			{
				FPNFile = "C:\\UVIT_CalDB\\FPN\\FUV 3Sq FPN.fits";
				FPNsuccess = true;
			}
		}
		if (alg == "5S" || alg == "5x5 Square")
		{
			if (::File::Exists("C:\\UVIT_CalDB\\FPN\\FUV 5Sq FPN.fits"))
			{
				FPNFile = "C:\\UVIT_CalDB\\FPN\\FUV 5Sq FPN.fits";
				FPNsuccess = true;
			}
		}
	}
	if (channel == "NUV")
	{
		if (alg == "3S" || alg == "3x3 Square")
		{
			if (::File::Exists("C:\\UVIT_CalDB\\FPN\\NUV 3Sq FPN.fits"))
			{
				FPNFile = "C:\\UVIT_CalDB\\FPN\\NUV 3Sq FPN.fits";
				FPNsuccess = true;
			}
		}
		if (alg == "5S" || alg == "5x5 Square")
		{
			if (::File::Exists("C:\\UVIT_CalDB\\FPN\\NUV 5Sq FPN.fits"))
			{
				FPNFile = "C:\\UVIT_CalDB\\FPN\\NUV 5Sq FPN.fits";
				FPNsuccess = true;
			}
		}
	}	
	if (channel == "VIS")
	{
		if (alg == "3S" || alg == "3x3 Square")
		{
			if (::File::Exists("C:\\UVIT_CalDB\\FPN\\VIS 3Sq FPN.fits"))
			{
				FPNFile = "C:\\UVIT_CalDB\\FPN\\VIS 3Sq FPN.fits";
				FPNsuccess = true;
			}
		}
		if (alg == "5S" || alg == "5x5 Square")
		{
			if (::File::Exists("C:\\UVIT_CalDB\\FPN\\VIS 5Sq FPN.fits"))
			{
				FPNFile = "C:\\UVIT_CalDB\\FPN\\VIS 5Sq FPN.fits";
				FPNsuccess = true;
			}
		}
	}
	if (!FPNsuccess)
	{
		//get the FPN correction table
		dlg->Title = "Select FPN Correction FITS Image File";
		dlg->InitialDirectory = (String^)GetReg("OpenFPNPath");
		if (dlg->ShowDialog() != ::DialogResult::OK)
			return;
		FPNFile = dlg->FileName;
		ind = dlg->FileName->LastIndexOf("\\");
		dir = dlg->FileName->Substring(0,ind);
		SetReg("OpenFPNPath",dir);
	}
	FitsFile^ FPNFits  = gcnew JPFits::FitsFile(FPNFile,nullptr,true,true,false);

	int NPts = FracFits->Height;
	#pragma omp parallel for
	for(int j = 0; j < NPts; j++)
	{
		//this is for doing 5x5 and if centroid are out of bounds for 3x3.
		//find the centroids out of bounds; xdecs < -16, xdecs > 15;
		//then move them to the adjacent pixel they want to be in with centroids in bounds
		if (FracFits->Image[0,j] < -16)//X
		{
			IntsFits->Image[0,j] -= 32;//adjust integer
			FracFits->Image[0,j] += 32;//adjust fractional
		}
		if (FracFits->Image[1,j] < -16)//Y
		{
			IntsFits->Image[1,j] -= 32;//adjust integer
			FracFits->Image[1,j] += 32;//adjust fractional
		}
		if (FracFits->Image[0,j] > 15)//X
		{
			IntsFits->Image[0,j] += 32;//adjust integer
			FracFits->Image[0,j] -= 32;//adjust fractional
		}
		if (FracFits->Image[1,j] > 15)//Y
		{
			IntsFits->Image[1,j] += 32;//adjust integer
			FracFits->Image[1,j] -= 32;//adjust fractional
		}
	}

	#pragma omp parallel for
	for(int j = 0; j < NPts; j++)
	{
		//adjust centroids to range from 0 to +1 (0 - 31), instead of -0.5
		//to correspond to the FPN Table coordinates ::::THIS MUST be UNDONE at end
		FracFits->Image[0,j] += 16;
		FracFits->Image[1,j] += 16;
	}

	Random^ rand = gcnew Random();
	for(int j = 0; j < NPts; j++)
	{
		//redistribute centroids evenly between the posts, so they can be interpolated
		//using Shyam's Way
		FracFits->Image[0,j] += rand->NextDouble();
		FracFits->Image[1,j] += rand->NextDouble();
	}

	#pragma omp parallel for
	for(int j = 0; j < NPts; j++)//now apply FPN correction
	{
		FracFits->Image[0,j] *= (double)int(FPNFits->Image[1,int(FracFits->Image[0,j]*4096/32)]);
		FracFits->Image[1,j] *= (double)int(FPNFits->Image[2,int(FracFits->Image[1,j]*4096/32)]);
	}

	#pragma omp parallel for
	for(int j = 0; j < NPts; j++)//reset the centroids to -16 to +15 range
	{
		FracFits->Image[0,j] -= 16;//x
		FracFits->Image[1,j] -= 16;//y
	}

	ind = IntsFileList->LastIndexOf(".");
	IntsFileList = IntsFileList->Insert(ind,"_deFPN");
	ind = FracFileList->LastIndexOf(".");
	FracFileList = FracFileList->Insert(ind,"_deFPN");
	IntsFits->WriteFile(IntsFileList,TypeCode::Int16);
	FracFits->WriteFile(FracFileList,TypeCode::Int16);

	::MessageBox::Show("FPN Correction Completed...","Finished...");
}

void Form1::UVITMenu_Click(System::Object^  sender, System::EventArgs^  e)
{
	DriftFromPCInterpolateChck->Checked = ::Convert::ToBoolean(GetReg("PCDriftInterpChck"));
	SmoothINTDriftChck->Checked = ::Convert::ToBoolean(GetReg("SmoothINTDrift"));
	TryAutoDeBiasINTDrift->Checked = ::Convert::ToBoolean(GetReg("deBiasINTDrift"));
	UserXShiftTxt->Text = (String^)GetReg("UserXShiftTxt");
	UserYShiftTxt->Text = (String^)GetReg("UserYShiftTxt");
	UserRotationTxt->Text = (String^)GetReg("UserRotationTxt");
	UserRotationXTxt->Text = (String^)GetReg("UserRotationXTxt");
	UserRotationYTxt->Text = (String^)GetReg("UserRotationYTxt");
	FlipHorizontalMenuItem->Checked = ::Convert::ToBoolean(GetReg("FlipHorizontalMenuItem"));
	FlipVerticalMenuItem->Checked = ::Convert::ToBoolean(GetReg("FlipVerticalMenuItem"));
	PointSrcINTDriftChck->Checked = ::Convert::ToBoolean(GetReg("PointSrcINTDrift"));
	CrossCorrINTDriftChck->Checked = ::Convert::ToBoolean(GetReg("CrossCorrINTDrift"));
	TryAutoDeBiasINTDrift->Checked = ::Convert::ToBoolean(GetReg("AutoDeBiasINTDriftChck"));
	TryAutoDeBiasINTDrift->Enabled = ::Convert::ToBoolean(GetReg("AutoDeBiasINTDriftEnab"));
	CosmicRayFilterSigmaMenuTxt->Text = (String^)GetReg("UVCRSigmaThreshold");
	CosmicRayFilterSigmaMenuChck->Checked = ::Convert::ToBoolean(GetReg("UVCRSigmaThresholdChck"));
	CosmicRayFilterCountMenuChck->Checked = ::Convert::ToBoolean(GetReg("UVCRNumberThresholdChck"));
	FilterCosmicRaysChckMenuItem->Checked = ::Convert::ToBoolean(GetReg("FilterCRs"));
	MaxMinThreshTxt->Text = (String^)GetReg("MaxMinThreshTxtText");
	MaxMinThreshChck->Checked = ::Convert::ToBoolean(GetReg("MaxMinThreshChck"));
	MaxMinThreshTxt->Enabled = ::Convert::ToBoolean(GetReg("MaxMinThreshTxtEnab"));
	MaxMinCountTwiceChck->Enabled = ::Convert::ToBoolean(GetReg("MaxMinCountTwiceChckEnab"));
	MaxMinCountTwiceChck->Checked = ::Convert::ToBoolean(GetReg("MaxMinCountTwiceChck"));
	ApplyFlatListToImageChck->Checked = ::Convert::ToBoolean(GetReg("UVApplyFlatList"));
	L1DigestApplyDISTChck->Checked = ::Convert::ToBoolean(GetReg("L1DigestApplyDIST"));
	L1DigestApplyFPNChck->Checked = ::Convert::ToBoolean(GetReg("L1DigestApplyFPN"));
	ApplyDriftCreateExpArrayChc->Checked = ::Convert::ToBoolean(GetReg("ApplyDriftCreateExpArrayChc"));

	L1CentroidPaddingChck->Checked = ::Convert::ToBoolean(GetReg("L1CentroidPaddingChck"));
	PCCentroidPaddingDrop->SelectedIndex = ::Convert::ToInt32(GetReg("PCCentroidPaddingDrop"));
	if (PCCentroidPaddingDrop->SelectedIndex == 0)
		UVPCMODEPADOFFSET = 22;
	if (PCCentroidPaddingDrop->SelectedIndex == 1)
		UVPCMODEPADOFFSET = 44;
	if (L1CentroidPaddingChck->Checked)
		PCCentroidPaddingDrop->Enabled = true;
	else
	{
		PCCentroidPaddingDrop->Enabled = false;
		UVPCMODEPADOFFSET = 0;
	}

	DriftSmoothNDrop->SelectedIndex = (int)GetReg("DriftSmoothNDrop_index");
	if (::Convert::ToBoolean(GetReg("PCDriftInterpChck")))
		DriftSmoothNDrop->Enabled = true;
	else
		DriftSmoothNDrop->Enabled = false;
	L1DiscardDataTimeChck->Checked = ::Convert::ToBoolean(GetReg("L1DiscardDataTimeChck"));
	if (L1DiscardDataTimeChck->Checked)
		L1DiscardDataTimeDrop->Enabled = true;
	else
		L1DiscardDataTimeDrop->Enabled = false;
	L1DiscardDataTimeDrop->SelectedIndex = (int)GetReg("L1DiscardDataTimeDrop");
	L1DiscardDuplicateChck->Checked = ::Convert::ToBoolean(GetReg("L1DiscardDuplicateChck"));
	if (::Convert::ToBoolean(GetReg("LinearRotationChck")))
	{
		LinearRotationChck->Checked = true;
		GeneralTransformChck->Checked = false;
		FlipHorizontalMenuItem->Enabled = true;
		FlipVerticalMenuItem->Enabled = true;
		UserXShiftTxt->Enabled = true;
		UserYShiftTxt->Enabled = true;
		UserRotationTxt->Enabled = true;
		UserRotationXTxt->Enabled = true;
		UserRotationYTxt->Enabled = true;

		TransformCoefATxt->Enabled = false;
		TransformCoefBTxt->Enabled = false;
		TransformCoefCTxt->Enabled = false;
		TransformCoefDTxt->Enabled = false;
		TransformCenterXTxt->Enabled = false;
		TransformCenterYTxt->Enabled = false;
		TransformShiftXTxt->Enabled = false;
		TransformShiftYTxt->Enabled = false;
	}
	else if (::Convert::ToBoolean(GetReg("GeneralTransformChck")))
	{
		LinearRotationChck->Checked = false;
		GeneralTransformChck->Checked = true;

		FlipHorizontalMenuItem->Enabled = false;
		FlipVerticalMenuItem->Enabled = false;
		UserXShiftTxt->Enabled = false;
		UserYShiftTxt->Enabled = false;
		UserRotationTxt->Enabled = false;
		UserRotationXTxt->Enabled = false;
		UserRotationYTxt->Enabled = false;

		TransformCoefATxt->Enabled = true;
		TransformCoefBTxt->Enabled = true;
		TransformCoefCTxt->Enabled = true;
		TransformCoefDTxt->Enabled = true;
		TransformCenterXTxt->Enabled = true;
		TransformCenterYTxt->Enabled = true;
		TransformShiftXTxt->Enabled = true;
		TransformShiftYTxt->Enabled = true;
	}
	else
	{
		LinearRotationChck->Checked = false;
		GeneralTransformChck->Checked = false;

		FlipHorizontalMenuItem->Enabled = false;
		FlipVerticalMenuItem->Enabled = false;
		UserXShiftTxt->Enabled = false;
		UserYShiftTxt->Enabled = false;
		UserRotationTxt->Enabled = false;
		UserRotationXTxt->Enabled = false;
		UserRotationYTxt->Enabled = false;

		TransformCoefATxt->Enabled = false;
		TransformCoefBTxt->Enabled = false;
		TransformCoefCTxt->Enabled = false;
		TransformCoefDTxt->Enabled = false;
		TransformCenterXTxt->Enabled = false;
		TransformCenterYTxt->Enabled = false;
		TransformShiftXTxt->Enabled = false;
		TransformShiftYTxt->Enabled = false;
	}
	TransformCoefATxt->Text = (String^)GetReg("TransformCoefATxt");
	TransformCoefBTxt->Text = (String^)GetReg("TransformCoefBTxt");
	TransformCoefCTxt->Text = (String^)GetReg("TransformCoefCTxt");
	TransformCoefDTxt->Text = (String^)GetReg("TransformCoefDTxt");
	TransformCenterXTxt->Text = (String^)GetReg("TransformCenterXTxt");
	TransformCenterYTxt->Text = (String^)GetReg("TransformCenterYTxt");
	TransformShiftXTxt->Text = (String^)GetReg("TransformShiftXTxt");
	TransformShiftYTxt->Text = (String^)GetReg("TransformShiftYTxt");
	UVAutoApplyDriftandImageChck->Checked = ::Convert::ToBoolean(GetReg("UVAutoApplyDriftandImageChck"));
	UVAutoDriftImageViewChck->Checked = ::Convert::ToBoolean(GetReg("UVAutoDriftImageViewChck"));
	if (UVAutoApplyDriftandImageChck->Checked)
		UVAutoDriftImageViewChck->Enabled = true;
	else
		UVAutoDriftImageViewChck->Enabled = false;

}

