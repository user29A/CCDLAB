void Form1::DigestL1FitsFileMenuItem_Click(System::Object^  sender, System::EventArgs^  e)
{
	UVITMenu->HideDropDown();
	DigestL1FitsFileMenuItem->HideDropDown();

	String^ dir = (String^)GetReg("L2EventListPath");
	OpenFileDialog^ dlg = gcnew OpenFileDialog();
	dlg->InitialDirectory = dir;
	dlg->Filter = "L1 Event List (*.fits)|*.fits";
	dlg->Multiselect = true;

	if (dlg->ShowDialog() != ::DialogResult::OK)
		return;

	String^ file = dlg->FileNames[0];
	dir = file->Substring(0,file->LastIndexOf("\\"));
	SetReg("L2EventListPath", dir);

	DATE = DateTime::Now;
	Form1::Enabled = false;
	WAITBAR = gcnew ::JPWaitBar::WaitBar();
	WAITBAR->Text = "Digesting L1 Files...";
	WAITBAR->ProgressBar->Maximum = dlg->FileNames->Length;
	UVITL1DigestWrkr->RunWorkerAsync(dlg->FileNames);
	WAITBAR->ShowDialog();
}

void Form1::UVITL1DigestWrkr_DoWork(System::Object^  sender, System::ComponentModel::DoWorkEventArgs^  e)
{
	array<String^>^ argfiles = (array<String^>^)e->Argument;
	String^ dir = (String^)GetReg("L2EventListPath");
	String^ mode = "";

	bool ApplyDIST = L1DigestApplyDISTChck->Checked;
	bool ApplyFPN  = L1DigestApplyFPNChck->Checked;

	::ArrayList^ dir_list = gcnew ArrayList();

	int errorfileindex = 0;

	try
	{
		for (int xi = 0; xi < argfiles->Length; xi++)
		{
			errorfileindex = xi;
			String^ FileName = argfiles[xi];
			String^ dir = FileName->Substring(0,FileName->LastIndexOf("\\"));
			String^ path = dir;
			FitsFile^ source = gcnew FitsFile(FileName,nullptr,true,false,false);

			FileStream^ fs = gcnew FileStream(FileName,IO::FileMode::Open);
			BufferedStream ^ bs = gcnew BufferedStream(fs);
			array<unsigned char>^ c = gcnew array<unsigned char>(2880);

			int naxis, naxis1, naxis2, bitpix;
			//read past primary header
			bool end = false;
			while (end == false)
			{
				//read 2880 block
				bs->Read(c,0,2880);//stream will be placed at end of header block, so that it can begin reading data values or 2ndry header
				for (int i = 0; i < 36; i++)
				{
					String^ line = System::Text::Encoding::ASCII->GetString(c,i*80,80);

					if (line->Substring(0,5)->Equals("NAXIS"))
						naxis = ::Convert::ToInt32(line->Substring(10,20));
					if (line->Substring(0,6)->Equals("NAXIS1"))
						naxis1 = ::Convert::ToInt32(line->Substring(10,20));
					if (line->Substring(0,6)->Equals("NAXIS2"))
						naxis2 = ::Convert::ToInt32(line->Substring(10,20));
					if (line->Substring(0,6)->Equals("BITPIX"))
						bitpix = ::Convert::ToInt32(line->Substring(10,20));
					if (line->Substring(0,8)->Equals("OBS_MODE"))
						mode = line->Substring(11,2);
					if (line->Substring(0,8)->Equals("END     "))//check if we're at the end of the header keys
					{
						end = true;
						break;
					}
				}
			}
			if (mode != "PC" && mode != "IM")
			{
				MessageBox::Show("Can't determine observation mode: " + mode, "Error...");
				return;
			}
			//now at end of primary header; if primary header has image data, must skip past it
			if (naxis != 0)
			{
				__int64 NBytes = __int64(naxis1)*__int64(naxis2)*__int64(::Math::Abs(bitpix))/8;
				__int64 rem;
				::Math::DivRem(NBytes,2880,rem);
				bs->Seek(NBytes+(2880-rem),::SeekOrigin::Current);
			}
			//should now be at a header extension
			//read it until it is as its end, then skip again to 2nd extension

			end = false;
			while (end == false)
			{
				//read 2880 block
				bs->Read(c,0,2880);//stream will be placed at end of header block, so that it can begin reading data values or 2ndry header
				for (int i = 0; i < 36; i++)
				{
					String^ line = System::Text::Encoding::ASCII->GetString(c,i*80,80);

					if (line->Substring(0,5)->Equals("NAXIS"))
						naxis = ::Convert::ToInt32(line->Substring(10,20));
					if (line->Substring(0,6)->Equals("NAXIS1"))
						naxis1 = ::Convert::ToInt32(line->Substring(10,20));
					if (line->Substring(0,6)->Equals("NAXIS2"))
						naxis2 = ::Convert::ToInt32(line->Substring(10,20));
					if (line->Substring(0,6)->Equals("BITPIX"))
						bitpix = ::Convert::ToInt32(line->Substring(10,20));
					if (line->Substring(0,8)->Equals("END     "))//check if we're at the end of the header keys
					{
						end = true;
						break;
					}
				}
			}

			//now at end of 1st extension header, skip its data
			if (naxis != 0)
			{
				__int64 Nbytes = __int64(naxis1)*__int64(naxis2)*__int64(::Math::Abs(bitpix))/8;
				__int64 rem;
				::Math::DivRem(Nbytes,2880,rem);
				bs->Seek(Nbytes+(2880-rem),::SeekOrigin::Current);
			}

			//should now be at 2nd extension header
			//read it until it is as its end
			int width = 0;
			end = false;
			while (end == false)
			{
				//read 2880 block
				bs->Read(c,0,2880);//stream will be placed at end of header block, so that it can begin reading data values or 2ndry header
				for (int i = 0; i < 36; i++)
				{
					String^ line = System::Text::Encoding::ASCII->GetString(c,i*80,80);

					if (line->Substring(0,6)->Equals("NAXIS1"))
						naxis1 = ::Convert::ToInt32(line->Substring(10,20));
					if (line->Substring(0,6)->Equals("NAXIS2"))
						naxis2 = ::Convert::ToInt32(line->Substring(10,20));
					if (line->Substring(0,6)->Equals("BITPIX"))
						bitpix = ::Convert::ToInt32(line->Substring(10,20));
					if (line->Substring(0,7)->Equals("TFORM15"))
					{
						String^ tform15 = line->Substring(11,6);
						tform15 = tform15->Replace("B","");//PC mode
						tform15 = tform15->Replace("I","");//IM mode
						width = ::Convert::ToInt32(tform15);
					}
					if (line->Substring(0,8)->Equals("END     "))//check if we're at the end of the header keys
						end = true;
				}
			}//now ready to get the L1 data
			__int64 file_bspos = bs->Position;

			//get the .tct file, and get the delta between absolute time and detector time from the first element in those tables
			//apply (add) that difference to all detector times in order to get absolute local JD times, then use that to get HJD
			double JD_abs_time_delta_sec;
			String^ tctfile = FileName->Substring(0,FileName->LastIndexOf("uvt")) + "uvt_level1.tct";
			bool tctfileexists = ::File::Exists(tctfile);
			if(tctfileexists)
			{
				array<double>^ SPS_TIME_MJD = JPFits::FitsFile::ReadBinaryTableExtensionEntry(tctfile,"TCT","SPS_TIME_MJD");
				double mjdref = SPS_TIME_MJD[0];
				array<double>^ LOCAL_TIMEF = JPFits::FitsFile::ReadBinaryTableExtensionEntry(tctfile,"TCT","LOCAL_TIMEF");
				double detref = LOCAL_TIMEF[0];
				JD_abs_time_delta_sec = mjdref + 2455197.5*86400 - detref;
			}

			if (mode == "PC")
			{
				if (WAITBAR->DialogResult == ::DialogResult::Cancel)
					return;
				UVITL1DigestWrkr->ReportProgress(xi+1, mode + "_" + argfiles->Length);

				int NBytes = naxis1*naxis2;
				array<unsigned char>^ arr = gcnew array<unsigned char>(NBytes);
				bs->Read(arr,0,NBytes);
				bs->Close();
				fs->Close();

				if (NBytes < 250000)
					goto skipto;

				bool discardtimebool = L1DiscardDataTimeChck->Checked;
				unsigned int discardtimeint;
				if (discardtimebool)
				{
					String^ discardtimestring = (String^)L1DiscardDataTimeDrop->SelectedItem;
					discardtimestring = discardtimestring->Replace(" Minutes","");
					discardtimeint = ::Convert::ToInt32(discardtimestring)*60*1000;
				}

				String^ channel = source->GetKeyValue("DETECTOR");
				String^ alg = source->GetKeyValue("CENTROID");
				String^ FPNFile;
				FitsFile^ FPNFits;
				Random^ rand;
				if (ApplyFPN)
				{
					if (channel == "FUV")
					{
						if (alg == "3S")
						{
							if (::File::Exists("C:\\UVIT_CalDB\\FPN\\FUV 3Sq FPN.fits"))
								FPNFile = "C:\\UVIT_CalDB\\FPN\\FUV 3Sq FPN.fits";
						}
						if (alg == "5S")
						{
							if (::File::Exists("C:\\UVIT_CalDB\\FPN\\FUV 5Sq FPN.fits"))
								FPNFile = "C:\\UVIT_CalDB\\FPN\\FUV 5Sq FPN.fits";
						}
					}
					else if (channel == "NUV")
					{
						if (alg == "3S")
						{
							if (::File::Exists("C:\\UVIT_CalDB\\FPN\\NUV 3Sq FPN.fits"))
								FPNFile = "C:\\UVIT_CalDB\\FPN\\NUV 3Sq FPN.fits";
						}
						if (alg == "5S")
						{
							if (::File::Exists("C:\\UVIT_CalDB\\FPN\\NUV 5Sq FPN.fits"))
								FPNFile = "C:\\UVIT_CalDB\\FPN\\NUV 5Sq FPN.fits";
						}
					}
					else if (channel == "VIS")
					{
						if (alg == "3S")
						{
							if (::File::Exists("C:\\UVIT_CalDB\\FPN\\VIS 3Sq FPN.fits"))
								FPNFile = "C:\\UVIT_CalDB\\FPN\\VIS 3Sq FPN.fits";
						}
						if (alg == "5S")
						{
							if (::File::Exists("C:\\UVIT_CalDB\\FPN\\VIS 5Sq FPN.fits"))
								FPNFile = "C:\\UVIT_CalDB\\FPN\\VIS 5Sq FPN.fits";
						}
					}
					else
					{
						//get the FPN correction table
						OpenFileDialog^ dlg = gcnew OpenFileDialog();
						dlg->Filter = "FITS (*.fits)|*.fits";
						dlg->Multiselect = false;
						dlg->Title = "Select FPN Correction FITS Image File";
						if (dlg->ShowDialog() != ::DialogResult::OK)
							return;
						FPNFile = dlg->FileName;
					}
					FPNFits  = gcnew JPFits::FitsFile(FPNFile,nullptr,true,true,false);
					rand = gcnew Random();
				}

				String^ CPUXDistFile;
				String^ CPUYDistFile;
				JPFits::FitsFile^ CPUXDistFits;
				JPFits::FitsFile^ CPUYDistFits;
				if (ApplyDIST)
				{
					if (channel == "FUV")
					{
						if (::File::Exists("C:\\UVIT_CalDB\\Distortion\\FUV_dist_dX.fits"))
						{
							CPUXDistFile = "C:\\UVIT_CalDB\\Distortion\\FUV_dist_dX.fits";
							CPUYDistFile = "C:\\UVIT_CalDB\\Distortion\\FUV_dist_dY.fits";
						}
					}
					else if (channel == "NUV")
					{
						if (::File::Exists("C:\\UVIT_CalDB\\Distortion\\NUV_dist_dX.fits"))
						{
							CPUXDistFile = "C:\\UVIT_CalDB\\Distortion\\NUV_dist_dX.fits";
							CPUYDistFile = "C:\\UVIT_CalDB\\Distortion\\NUV_dist_dY.fits";
						}
					}
					else if (channel == "VIS")
					{
						if (::File::Exists("C:\\UVIT_CalDB\\Distortion\\VIS_dist_dX.fits"))
						{
							CPUXDistFile = "C:\\UVIT_CalDB\\Distortion\\VIS_dist_dX.fits";
							CPUYDistFile = "C:\\UVIT_CalDB\\Distortion\\VIS_dist_dY.fits";
						}
					}
					else
					{
						OpenFileDialog^ dlg = gcnew OpenFileDialog();
						dlg->Filter = "FITS (*.fits)|*.fits";
						dlg->Multiselect = false;
						//get the CPU *X* correction image
						dlg->Title = "Select CPU *X* Correction FITS Image File";
						if (dlg->ShowDialog() != ::DialogResult::OK)
							return;
						String^ CPUXDistFile = dlg->FileName;

						//get the CPU *Y* correction image
						dlg->Title = "Select CPU *Y* Correction FITS Image File";
						if (dlg->ShowDialog() != ::DialogResult::OK)
							return;
						String^ CPUYDistFile = dlg->FileName;
					}
					CPUXDistFits = gcnew JPFits::FitsFile(CPUXDistFile,nullptr,true,true,false);
					CPUYDistFits = gcnew JPFits::FitsFile(CPUYDistFile,nullptr,true,true,false);
				}

				int byteindx = 0;
				double bzero = 0;
				double bscale = 1;

				//first thing, get number of sets
				int Nset = 0;
				unsigned __int16 prevframe = UInt16::MaxValue;
				unsigned __int32 prevtime  = UInt32::MaxValue;
				for (int i = 0; i < naxis2; i++)
				{
					//frame count
					byteindx = i*naxis1;
					byteindx += 65;
					bzero = 32768;
					unsigned __int16 frame = int(((arr[byteindx])<<8) | arr[byteindx + 1]) + (unsigned __int16)bzero;//likely get rid of bzero by using unsigned int instead of int on arr

					//frame time
					byteindx = i*naxis1;
					byteindx += 67;
					bzero = 2147483648;
					unsigned __int32 time = int(((arr[byteindx])<<24) | (arr[byteindx + 1]<<16) | (arr[byteindx + 2])<<8 | arr[byteindx + 3]) + (unsigned __int32)bzero;//likely get rid of bzero by using unsigned int instead of int on arr

					if (prevframe > frame || prevtime > time)//then imaging session set has reset, also first set, or frame or time rolled over & start new set on rollover
						Nset++;
					prevframe = frame;
					prevtime = time;
				}
				
				//have number of sets, now need number of centroids in each set
				array<int>^ Ncentroids = gcnew array<int>(Nset);
				int Ncent = 0;
				Nset = 0;
				prevframe = UInt16::MaxValue;
				prevtime  = UInt32::MaxValue;
				for (int i = 0; i < naxis2; i++)
				{
					//frame count
					byteindx = i*naxis1;
					byteindx += 65;
					bzero = 32768;
					unsigned __int16 frame = int(((arr[byteindx])<<8) | arr[byteindx + 1]) + (unsigned __int16)bzero;//likely get rid of bzero by using unsigned int instead of int on arr

					//frame time
					byteindx = i*naxis1;
					byteindx += 67;
					bzero = 2147483648;
					unsigned __int32 time = int(((arr[byteindx])<<24) | (arr[byteindx + 1]<<16) | (arr[byteindx + 2])<<8 | arr[byteindx + 3]) + (unsigned __int32)bzero;//likely get rid of bzero by using unsigned int instead of int on arr

					if (prevframe > frame || prevtime > time)//then imaging session set has reset, also first set, or frame or time rolled over & start new set on rollover
						Nset++;
					prevframe = frame;
					prevtime = time;

					//Centroid
					byteindx = i*naxis1;
					byteindx += 79;
					for (int j = 0; j < width/6; j++)
					{
						unsigned __int16 xword = unsigned __int16((arr[byteindx + j*6]<<8)	   | arr[byteindx + j*6 + 1]);
						unsigned __int16 yword = unsigned __int16((arr[byteindx + j*6 + 2]<<8) | arr[byteindx + j*6 + 3]);
						unsigned __int16 sword = unsigned __int16((arr[byteindx + j*6 + 4]<<8) | arr[byteindx + j*6 + 5]);

						if (xword == 0 && yword == 0 && sword == 0)//end of data for this i'th row
							break;

						Ncent++;//number of centroids, only incremented if there was more data for this row
						Ncentroids[Nset-1]++;
					}
				}

				array<double>^				HJDS;
				array<unsigned __int16>^	frames;
				array<unsigned __int32>^	times;
				array<__int16,2>^			ints;
				array<__int16,2>^			decs;
				array<unsigned __int16,2>^	mdMm;

				Ncent = 0;
				Nset = 0;
				prevframe = UInt16::MaxValue;
				prevtime  = UInt32::MaxValue;
				for (int i = 0; i <= naxis2; i++)
				{
					if (i == naxis2)
					{
						prevframe = UInt16::MaxValue;//will force the last set to be written
						prevtime  = UInt32::MaxValue;
						goto lastset;
					}

					//frame count
					byteindx = i*naxis1;
					byteindx += 65;
					bzero = 32768;
					unsigned __int16 frame = int(((arr[byteindx])<<8) | arr[byteindx + 1]) + (unsigned __int16)bzero;//likely get rid of bzero by using unsigned int instead of int on arr

					//frame time
					byteindx = i*naxis1;
					byteindx += 67;
					bzero = 2147483648;
					unsigned __int32 time = int(((arr[byteindx])<<24) | (arr[byteindx + 1]<<16) | (arr[byteindx + 2])<<8 | arr[byteindx + 3]) + (unsigned __int32)bzero;//likely get rid of bzero by using unsigned int instead of int on arr

					/*//TIME //supposedly mission elapsed time, or something, but perhaps can use with lbt file for aligning filter
					byteindx = i*naxis1;
					byteindx += 0;
					bzero = 0;
					array<unsigned char>^ dbl = gcnew array<unsigned char>(8);
					dbl[7] = arr[byteindx];
					dbl[6] = arr[byteindx + 1];
					dbl[5] = arr[byteindx + 2];
					dbl[4] = arr[byteindx + 3];
					dbl[3] = arr[byteindx + 4];
					dbl[2] = arr[byteindx + 5];
					dbl[1] = arr[byteindx + 6];
					dbl[0] = arr[byteindx + 7];
					double HJD = BitConverter::ToDouble(dbl, 0);*/
					//the above time isn't exact.  Now use the JD_abs_time_delta_sec to get the HJD here
					double JD;
					if (tctfileexists)
						JD = (double(time)/1000 + JD_abs_time_delta_sec)/86400;//this should be the local JD...it will get used below to get HJD
					else
						JD = 0;

					lastset:

					if (prevframe > frame || prevtime > time)//then imaging session set has reset, also first set, or frame or time rolled over & start new set on rollover
					{
						if (Nset > 0 || i == naxis2)//then the previous set data needs to be written
						{
							if (times != nullptr)
							if (times->Length > /*0*/1000)//so that short corrupt files dont get written
							if (discardtimebool && (times[times->Length-1] - times[0]) > discardtimeint || !discardtimebool)
							{
								dir = path + "\\" + source->GetKeyValue("DETECTOR") + "_" + source->GetKeyValue("FILTER") + "\\" + source->GetKeyValue("SOURCEID") + "_" + source->GetKeyValue("DETECTOR") + "_" + source->GetKeyValue("FILTER") + "_" + source->GetKeyValue("ORB_NUM") + "_" + (times[0]/1000).ToString("0000000000");
								::Directory::CreateDirectory(dir);
								String^ obj_orb_chan;
								obj_orb_chan = dir + "\\" + source->GetKeyValue("SOURCEID") + "_" + source->GetKeyValue("DETECTOR") + "_" + source->GetKeyValue("FILTER") + "_" + source->GetKeyValue("ORB_NUM") + "_" + (times[0]/1000).ToString("0000000000");
								dir_list->Add(dir);
								e->Result = dir_list;

								String^ HJDfile = obj_orb_chan + "_HJDList.fits";
								if (tctfileexists)//else all 0's
									HJDS = HJDC(HJDS, Convert::ToDouble(source->GetKeyValue("RA_PNT")), Convert::ToDouble(source->GetKeyValue("DEC_PNT")), false);
								source->AddKey("HJD0", HJDS[0].ToString("#.0000000"), "HJD of start of imaging", 14);//now it will get added to all other copyheaders's
								JPFits::FitsFile^ f = gcnew FitsFile(HJDfile,HJDS,false);
								f->CopyHeader(source);
								f->WriteFile(::TypeCode::Double);

								String^ framefile = obj_orb_chan + "_FrameList.fits";
								f = gcnew FitsFile(framefile,frames,false);
								f->CopyHeader(source);
								f->WriteFile(::TypeCode::UInt16);

								String^ timefile = obj_orb_chan + "_TimeList.fits";
								f = gcnew FitsFile(timefile,times,false);
								f->CopyHeader(source);
								f->WriteFile(::TypeCode::UInt32);

								FitsFile^ flat;
								String^ channel = f->GetKeyValue("CHANNEL");
								if (channel->Length == 0)
									channel = f->GetKeyValue("DETECTOR");
								bool flatsuccess = false;
								if (channel == "FUV")
									if (::File::Exists("C:\\UVIT_CalDB\\Flats Normalized\\FUV Normalized Flat.fits"))
									{
										flat = gcnew FitsFile("C:\\UVIT_CalDB\\Flats Normalized\\FUV Normalized Flat.fits", nullptr, true, true, false);
										flatsuccess = true;
									}
								if (channel == "NUV")
									if (::File::Exists("C:\\UVIT_CalDB\\Flats Normalized\\NUV Normalized Flat.fits"))
									{
										flat = gcnew FitsFile("C:\\UVIT_CalDB\\Flats Normalized\\NUV Normalized Flat.fits", nullptr, true, true, false);
										flatsuccess = true;
									}
								if (channel == "VIS")
									if (::File::Exists("C:\\UVIT_CalDB\\Flats Normalized\\VIS Normalized Flat.fits"))
									{
										flat = gcnew FitsFile("C:\\UVIT_CalDB\\Flats Normalized\\VIS Normalized Flat.fits", nullptr, true, true, false);
										flatsuccess = true;
									}
								if (!flatsuccess)
								{
									::MessageBox::Show("Couldn't find the flat file in the CalDB...stopping.", "Error");
									WAITBAR->DialogResult = ::DialogResult::Cancel;
									return;
								}
								array<double>^ flats = gcnew array<double>(Ncentroids[Nset-1]);
								#pragma omp parallel for
								for(int j = 0; j < Ncentroids[Nset-1]; j++)
									flats[j] = flat->Image[int(ints[0,j]/32),int(ints[1,j]/32)];
								String^ flatfile = obj_orb_chan + "_FlatList.fits";
								FitsFile^ fitsflatlist = gcnew FitsFile(flatfile, flats, false);
								fitsflatlist->CopyHeader(source);
								fitsflatlist->WriteFile(::TypeCode::Double);

								String^ intsfile = obj_orb_chan + "_XYInts_List.fits";
								if (ApplyFPN)
									intsfile = intsfile->Insert(intsfile->LastIndexOf("."),"_deFPN");
								if (ApplyDIST)
									intsfile = intsfile->Insert(intsfile->LastIndexOf("."),"_deDIST");
								f = gcnew FitsFile(intsfile,ints,false);
								f->CopyHeader(source);
								f->WriteFile(::TypeCode::Int16);

								String^ fracfile = obj_orb_chan + "_XYFrac_List.fits";
								if (ApplyFPN)
									fracfile = fracfile->Insert(fracfile->LastIndexOf("."),"_deFPN");
								if (ApplyDIST)
									fracfile = fracfile->Insert(fracfile->LastIndexOf("."),"_deDIST");
								f = gcnew FitsFile(fracfile,decs,false);
								f->CopyHeader(source);
								f->WriteFile(::TypeCode::Int16);

								String^ mdMmfile = obj_orb_chan + "_XYmdMm_List.fits";
								f = gcnew FitsFile(mdMmfile,mdMm,false);
								f->CopyHeader(source);
								f->WriteFile(::TypeCode::Int16);

								bool splitFUVlists = true;
								if (splitFUVlists && times[times->Length-1] - times[0] > 1000*1000 && source->GetKeyValue("DETECTOR") == "FUV")//split the file?
								{
									unsigned __int32 splittime = times[(times->Length-1)/2];
									int splitindex = 0;
									while (splittime > times[splitindex])
										splitindex++;
									splitindex--;//roll one back

									array<double>^ HJDS_A = gcnew array<double>(splitindex+1);
									array<unsigned __int16>^ frames_A = gcnew array<unsigned __int16>(splitindex+1);
									array<unsigned __int32>^ times_A = gcnew array<unsigned __int32>(splitindex+1);
									array<double>^ flats_A = gcnew array<double>(splitindex+1);
									array<__int16,2>^ ints_A = gcnew array<__int16,2>(2,splitindex+1);
									array<__int16,2>^ decs_A = gcnew array<__int16,2>(2,splitindex+1);
									array<unsigned __int16,2>^ mdMm_A = gcnew array<unsigned __int16,2>(2,splitindex+1);

									array<double>^ HJDS_B = gcnew array<double>(times->Length - splitindex - 1);
									array<unsigned __int16>^ frames_B = gcnew array<unsigned __int16>(times->Length - splitindex - 1);
									array<unsigned __int32>^ times_B = gcnew array<unsigned __int32>(times->Length - splitindex - 1);
									array<double>^ flats_B = gcnew array<double>(times->Length - splitindex - 1);
									array<__int16,2>^ ints_B = gcnew array<__int16,2>(2,times->Length - splitindex - 1);
									array<__int16,2>^ decs_B = gcnew array<__int16,2>(2,times->Length - splitindex - 1);
									array<unsigned __int16,2>^ mdMm_B = gcnew array<unsigned __int16,2>(2,times->Length - splitindex - 1);

									#pragma omp parallel for
									for (int s = 0; s < splitindex+1; s++)
									{
										HJDS_A[s] = HJDS[s];
										frames_A[s] = frames[s];
										times_A[s] = times[s];
										flats_A[s] = flats[s];
										ints_A[0,s] = ints[0,s];
										ints_A[1,s] = ints[1,s];
										decs_A[0,s] = decs[0,s];
										decs_A[1,s] = decs[1,s];
										mdMm_A[0,s] = mdMm[0,s];
										mdMm_A[1,s] = mdMm[1,s];
									}

									#pragma omp parallel for
									for (int s = 0; s < times->Length - splitindex - 1; s++)
									{
										HJDS_B[s] = HJDS[splitindex+1+s];
										frames_B[s] = frames[splitindex+1+s];
										times_B[s] = times[splitindex+1+s];
										flats_B[s] = flats[splitindex+1+s];
										ints_B[0,s] = ints[0,splitindex+1+s];
										ints_B[1,s] = ints[1,splitindex+1+s];
										decs_B[0,s] = decs[0,splitindex+1+s];
										decs_B[1,s] = decs[1,splitindex+1+s];
										mdMm_B[0,s] = mdMm[0,splitindex+1+s];
										mdMm_B[1,s] = mdMm[1,splitindex+1+s];
									}

									//directory for A will be the same...same starting time stamp and will already be created.  Delete existing files in it and write
									//the new A ones
									::File::Delete(HJDfile);
									::File::Delete(timefile);
									::File::Delete(framefile);
									::File::Delete(flatfile);
									::File::Delete(intsfile);
									::File::Delete(fracfile);
									::File::Delete(mdMmfile);

									f = gcnew FitsFile(HJDfile,HJDS_A,false);
									f->CopyHeader(source);
									f->WriteFile(::TypeCode::Double);

									f = gcnew FitsFile(framefile,frames_A,false);
									f->CopyHeader(source);
									f->WriteFile(::TypeCode::UInt16);

									f = gcnew FitsFile(timefile,times_A,false);
									f->CopyHeader(source);
									f->WriteFile(::TypeCode::UInt32);

									f = gcnew FitsFile(flatfile, flats_A, false);
									f->CopyHeader(source);
									f->WriteFile(::TypeCode::Double);

									f = gcnew FitsFile(intsfile,ints_A,false);
									f->CopyHeader(source);
									f->WriteFile(::TypeCode::Int16);

									f = gcnew FitsFile(fracfile,decs_A,false);
									f->CopyHeader(source);
									f->WriteFile(::TypeCode::Int16);

									f = gcnew FitsFile(mdMmfile,mdMm_A,false);
									f->CopyHeader(source);
									f->WriteFile(::TypeCode::Int16);

									//directory for B will need to be created and will have the starting time of B
									dir = path + "\\" + source->GetKeyValue("DETECTOR") + "_" + source->GetKeyValue("FILTER") + "\\" + source->GetKeyValue("SOURCEID") + "_" + source->GetKeyValue("DETECTOR") + "_" + source->GetKeyValue("FILTER") + "_" + source->GetKeyValue("ORB_NUM") + "_" + (times_B[0]/1000).ToString("0000000000");
									::Directory::CreateDirectory(dir);
									String^ obj_orb_chan;
									obj_orb_chan = dir + "\\" + source->GetKeyValue("SOURCEID") + "_" + source->GetKeyValue("DETECTOR") + "_" + source->GetKeyValue("FILTER") + "_" + source->GetKeyValue("ORB_NUM") + "_" + (times_B[0]/1000).ToString("0000000000");
									dir_list->Add(dir);
									e->Result = dir_list;

									HJDfile = obj_orb_chan + "_HJDList.fits";
									f = gcnew FitsFile(HJDfile,HJDS_B,false);
									f->CopyHeader(source);
									f->WriteFile(::TypeCode::Double);

									framefile = obj_orb_chan + "_FrameList.fits";
									f = gcnew FitsFile(framefile,frames_B,false);
									f->CopyHeader(source);
									f->WriteFile(::TypeCode::UInt16);

									timefile = obj_orb_chan + "_TimeList.fits";
									f = gcnew FitsFile(timefile,times_B,false);
									f->CopyHeader(source);
									f->WriteFile(::TypeCode::UInt32);

									flatfile =  obj_orb_chan + "_FlatList.fits";
									f = gcnew FitsFile(flatfile, flats_B, false);
									f->CopyHeader(source);
									f->WriteFile(::TypeCode::Double);

									intsfile = obj_orb_chan + "_XYInts_List.fits";
									if (ApplyFPN)
										intsfile = intsfile->Insert(intsfile->LastIndexOf("."),"_deFPN");
									if (ApplyDIST)
										intsfile = intsfile->Insert(intsfile->LastIndexOf("."),"_deDIST");
									f = gcnew FitsFile(intsfile,ints_B,false);
									f->CopyHeader(source);
									f->WriteFile(::TypeCode::Int16);

									fracfile = obj_orb_chan + "_XYFrac_List.fits";
									if (ApplyFPN)
										fracfile = fracfile->Insert(fracfile->LastIndexOf("."),"_deFPN");
									if (ApplyDIST)
										fracfile = fracfile->Insert(fracfile->LastIndexOf("."),"_deDIST");
									f = gcnew FitsFile(fracfile,decs_B,false);
									f->CopyHeader(source);
									f->WriteFile(::TypeCode::Int16);

									mdMmfile = obj_orb_chan + "_XYmdMm_List.fits";
									f = gcnew FitsFile(mdMmfile,mdMm_B,false);
									f->CopyHeader(source);
									f->WriteFile(::TypeCode::Int16);
								}
							}
						}

						if (i == naxis2)
							goto lastset2;//last set was written so now go end

						//reset everything for new centroids list
						Nset++;
						Ncent = 0;
						HJDS = gcnew array<double>(Ncentroids[Nset-1]);
						frames = gcnew array<unsigned __int16>(Ncentroids[Nset-1]);
						times = gcnew array<unsigned __int32>(Ncentroids[Nset-1]);
						ints = gcnew array<__int16,2>(2,Ncentroids[Nset-1]);
						decs = gcnew array<__int16,2>(2,Ncentroids[Nset-1]);
						mdMm = gcnew array<unsigned __int16,2>(2,Ncentroids[Nset-1]);
					}
					prevframe = frame;
					prevtime = time;

					//Centroid
					byteindx = i*naxis1;
					byteindx += 79;
					for (int j = 0; j < width/6; j++)
					{
						unsigned __int16 xword = unsigned __int16((arr[byteindx + j*6]<<8) | arr[byteindx + j*6 + 1]);
						unsigned __int16 yword = unsigned __int16((arr[byteindx + j*6 + 2]<<8) | arr[byteindx + j*6 + 3]);
						unsigned __int16 sword = unsigned __int16((arr[byteindx + j*6 + 4]<<8) | arr[byteindx + j*6 + 5]);

						if (xword == 0 && yword == 0 && sword == 0)//end of data for this i'th row
							break;

						bool xword_parity_error = CCDLAB::GSEExtractImg::Check_Even_Parity_Flag(xword);
						bool yword_parity_error = CCDLAB::GSEExtractImg::Check_Even_Parity_Flag(yword);
						bool sword_parity_error = CCDLAB::GSEExtractImg::Check_Even_Parity_Flag(sword);

						/*if (xword_parity_error)
							::MessageBox::Show("Error found on 'xword' at byteindex " + (byteindx + j*6).ToString() + " at file " + source->FileName,"Parity Error...");
						if (yword_parity_error)
							::MessageBox::Show("Error found on 'yword' at byteindex " + (byteindx + j*6 + 2).ToString() + " at file " + source->FileName,"Parity Error...");
						if (sword_parity_error)
							::MessageBox::Show("Error found on 'sword' at byteindex " + (byteindx + j*6 + 4).ToString() + " at file " + source->FileName,"Parity Error...");*/

						bool p_error = false;
						if (xword_parity_error || yword_parity_error || sword_parity_error)
						{
							/*if (::Directory::Exists(path + "\\" + source->GetKeyValue("DETECTOR") + "_" + source->GetKeyValue("FILTER") + "\\" + source->GetKeyValue("SOURCEID") + "_" + source->GetKeyValue("ORB_NUM") + "_" + source->GetKeyValue("DETECTOR") + "_" + source->GetKeyValue("FILTER") + "_" + (times[0]/1000).ToString("0000000000")))
								::Directory::Delete(path + "\\" + source->GetKeyValue("DETECTOR") + "_" + source->GetKeyValue("FILTER") + "\\" + source->GetKeyValue("SOURCEID") + "_" + source->GetKeyValue("ORB_NUM") + "_" + source->GetKeyValue("DETECTOR") + "_" + source->GetKeyValue("FILTER") + "_" + (times[0]/1000).ToString("0000000000"),true);

							if (!::Directory::Exists(source->FilePath + "Digested L1 Parity Errors\\"))
								::Directory::CreateDirectory(source->FilePath + "Digested L1 Parity Errors\\");
							::File::Move(source->FullFileName,source->FilePath + "Digested L1 Parity Errors\\" + source->FileName);

							goto parity_error;*/

							p_error = true;
						}

						//x
						unsigned __int16 ixpos = ((xword)>>7)*32;
						__int16	fxpos = ((xword&0x7F)>>1);
						if (fxpos >= 32)
							fxpos = fxpos - 64;
						
						//y
						unsigned __int16 iypos = ((yword)>>7)*32;
						__int16	fypos = ((yword&0x7F)>>1);
						if (fypos >= 32)
							fypos = fypos - 64;
						
						//corner
						unsigned __int16 mc  = ((sword&0x1FF)>>1)*16;
						unsigned __int16 dMm = (sword>>9)*16;

						/*if (ixpos >= 511*32 || ixpos < 0 || iypos >= 511*32 || iypos < 0 || fxpos > 31 || fxpos < -32 || fypos > 31 || fypos < -32)
							p_error = true;*///just treat as p_error if p_error not detected
						//no dont do this because maybe the corrections just moved it out.  Leave p_error as an actual p_error...will see them drifting in the corner
						
						if (ApplyFPN && !p_error)
						{
							if (fxpos < -16)//X
							{
								ixpos -= 32;//adjust integer
								fxpos += 32;//adjust fractional
							}
							if (fypos < -16)//Y
							{
								iypos -= 32;//adjust integer
								fypos += 32;//adjust fractional
							}
							if (fxpos > 15)//X
							{
								ixpos += 32;//adjust integer
								fxpos -= 32;//adjust fractional
							}
							if (fypos > 15)//Y
							{
								iypos += 32;//adjust integer
								fypos -= 32;//adjust fractional
							}

							fxpos += 16;
							fypos += 16;

							double fx = double(fxpos);
							double fy = double(fypos);

							fx += rand->NextDouble();
							fy += rand->NextDouble();

							fx *= FPNFits->Image[1,int(fx*4096/32)];
							fy *= FPNFits->Image[2,int(fy*4096/32)];

							fxpos = (__int16)fx;
							fypos = (__int16)fy;

							fxpos -= 16;//x
							fypos -= 16;//y
						}

						/*if (ixpos >= 511*32 || ixpos < 0 || iypos >= 511*32 || iypos < 0 || fxpos > 31 || fxpos < -32 || fypos > 31 || fypos < -32)
							p_error = true;*///just treat as p_error if p_error not detected
						//no dont do this because maybe the corrections just moved it out.  Leave p_error as an actual p_error...will see them drifting in the corner

						int xcorr, ycorr;
						if (ApplyDIST && !p_error)
						{
							xcorr = int(32*CPUXDistFits->Image[ixpos/32, iypos/32]);
							ycorr = int(32*CPUYDistFits->Image[ixpos/32, iypos/32]);
							
							ixpos -= xcorr;
							iypos -= ycorr;
						}

						/*if (ixpos >= 511*32 || ixpos < 0 || iypos >= 511*32 || iypos < 0 || fxpos > 31 || fxpos < -32 || fypos > 31 || fypos < -32)
							p_error = true;*///just treat as p_error if p_error not detected
						//no dont do this because maybe the corrections just moved it out.  Leave p_error as an actual p_error...will see them drifting in the corner

						//HJDS[Ncent] = HJD/86400 + 2455197.5;//now Julian Day.day
						HJDS[Ncent] = JD;
						frames[Ncent] = frame;
						times[Ncent] = time;

						if (p_error)
						{
							ints[0,Ncent] = 0;//these will be seen in a final image as drifting around at the top left corner
							ints[1,Ncent] = 0;
							decs[0,Ncent] = 0;
							decs[1,Ncent] = 0;
							mdMm[0,Ncent] = 0;
							mdMm[1,Ncent] = 0;
						}
						else
						{
							ints[0,Ncent] = ixpos;
							ints[1,Ncent] = iypos;
							decs[0,Ncent] = fxpos;
							decs[1,Ncent] = fypos;
							mdMm[0,Ncent] = mc;
							mdMm[1,Ncent] = dMm;
						}
						Ncent++;//number of centroids, only incremented if there was more data for this row
					}
				}
				lastset2:;

			}//end if PC mode

			if (mode == "IM")
			{
				bool discardtimebool = L1DiscardDataTimeChck->Checked;
				int discardtimeint;
				if (discardtimebool)
				{
					String^ discardtimestring = (String^)L1DiscardDataTimeDrop->SelectedItem;
					discardtimestring = discardtimestring->Replace(" Minutes","");
					discardtimeint = ::Convert::ToInt32(discardtimestring)*60;
				}

				int byteindx = 0;
				double bzero = 0;
				double bscale = 1;

				int xsize  = ::Convert::ToInt32(source->GetKeyValue("WIN_X_SZ"));//zero-based
				int ysize  = ::Convert::ToInt32(source->GetKeyValue("WIN_Y_SZ"));//zero-based
				int imsize = (xsize+1)*(ysize+1);
				array<double,2>^ d2im = gcnew array<double,2>(xsize+1,ysize+1);
				array<unsigned __int16>^ d1im = gcnew array<unsigned __int16>(imsize);//just 1-D is fine cause we're just gonna write it
				int pixnum = 0;
				int intprog = 0;
				int Nimages = width*naxis2/imsize;
				unsigned __int16 prevframe = UInt16::MaxValue - 1;
				int set = 0;

				int arr_size = 100000*naxis1;
				array<unsigned char>^ arr = gcnew array<unsigned char>(arr_size);

				__int64 img_length = fs->Length - file_bspos;
				int N = int(img_length/arr_size);//number of naxis1 segments

				for (int f = 0; f < N+1; f++)
				{
					int L = 0;
					if (f == N)
						L = int(img_length - __int64(f*arr_size));
					else
						L = arr_size;

					bs->Read(arr,0,L);

					for (int i = 0; i < L/naxis1; i++)
					{
						//frame count
						byteindx = i*naxis1;
						byteindx += 65;
						bzero = 32768;
						unsigned __int16 frame = int(((arr[byteindx])<<8) | arr[byteindx + 1]) + (unsigned __int16)bzero;

						//frame time
						byteindx = i*naxis1;
						byteindx += 67;
						bzero = 2147483648;
						bscale = 1;
						unsigned __int32 time = int(((arr[byteindx])<<24) | (arr[byteindx + 1]<<16) | (arr[byteindx + 2])<<8 | arr[byteindx + 3]) + (unsigned __int32)bzero;

						//orbit
						byteindx = i*naxis1;
						byteindx += 2247;
						bzero = 2147483648;
						bscale = 1;
						unsigned __int32 orbit = (unsigned __int32)(((arr[byteindx])<<24) | (arr[byteindx + 1]<<16) | (arr[byteindx + 2])<<8 | arr[byteindx + 3]);// + (unsigned __int32)bzero;

						if (prevframe != frame)//then it is a new image; also fires at very beginning.
						{
							if (prevframe > frame && prevframe != UInt16::MaxValue)//then frame has reset for some reason, so start a new file name set; also fires at very beginning
							{
								set++;//used in file name of image
								if (source->GetKeyValue("DETECTOR") == "VIS")
									dir = path + "\\" + "VIS" + "\\" + source->GetKeyValue("SOURCEID") + "_" + source->GetKeyValue("DETECTOR") + "_" + source->GetKeyValue("FILTER") + "_" + source->GetKeyValue("ORB_NUM") + "_" + (time/1000).ToString("0000000000");
								else
									dir = path + "\\" + source->GetKeyValue("DETECTOR") + "_" + source->GetKeyValue("FILTER") + "\\" + source->GetKeyValue("SOURCEID") + "_" + source->GetKeyValue("DETECTOR") + "_" + source->GetKeyValue("FILTER") + "_" + source->GetKeyValue("ORB_NUM") + "_" + (time/1000).ToString("0000000000");
								::Directory::CreateDirectory(dir);
							}
							pixnum = 0;//force restart
							prevframe = frame;
						}

						//Pixel
						byteindx = i*naxis1;
						byteindx += 79;
						bzero = 32768;
						for (int j = 0; j < width; j++)
						{
							if (pixnum >= imsize)//image is done
							{
								if (WAITBAR->DialogResult == ::DialogResult::Cancel)
									return;
								intprog++;
								UVITL1DigestWrkr->ReportProgress(100*intprog/Nimages, mode + "_" + (xi+1).ToString() + "_" + argfiles->Length);

								pixnum = 0;//reset pixel index

								for (int jj = 0; jj < ysize+1; jj++)
									for (int ii = 0; ii < xsize+1; ii++)
										d2im[ii,jj] = (double)(d1im[jj*(xsize+1) + ii]);
								
								String^ obj_orb_chan;
								obj_orb_chan = dir + "\\" + source->GetKeyValue("SOURCEID") + "_" + source->GetKeyValue("DETECTOR") + "_" + source->GetKeyValue("FILTER") + "_" + source->GetKeyValue("ORB_NUM") + "_" + (time).ToString("0000000000000") + ".fits";
								FitsFile^ fits = gcnew FitsFile(obj_orb_chan,d2im,false);
								fits->CopyHeader(source);
								fits->AddKey("FRMTIME", (double(time)/1000).ToString(), "EU Frame Time (s)",18);
								fits->AddKey("FRAMENO", frame.ToString(), "Frame Number",18);
								fits->AddKey("FRAMESET", set.ToString(), "Frame Set",18);
								array<double>^ JD = gcnew array<double>(1){(double(time)/1000 + JD_abs_time_delta_sec)/86400};
								JD = HJDC(JD, Convert::ToDouble(source->GetKeyValue("RA_PNT")), Convert::ToDouble(source->GetKeyValue("DEC_PNT")), false);
								fits->AddKey("FRAMEHJD", JD[0].ToString(), "Heliocentric Julian Date (days)",18);
								if (frame > 16)//skip writing first image so that noise images don't come in
									fits->WriteFile(::TypeCode::UInt16);
								d2im = gcnew array<double,2>(xsize+1,ysize+1);
								d1im = gcnew array<unsigned __int16>(imsize);
								break;
							}

							d1im[pixnum] = ((arr[byteindx + j*2]<<8) | arr[byteindx + j*2 + 1]) + 32768;
							pixnum++;
						}
					}
				}
				bs->Close();
				fs->Close();

				//check for any small directories and get rid of them
				if(discardtimebool)
				{
					array<String^>^ dir_list;
					if (source->GetKeyValue("DETECTOR") == "VIS")
						dir_list = ::Directory::GetDirectories(path + "\\" + "VIS");
					else
						dir_list = ::Directory::GetDirectories(path + "\\" + source->GetKeyValue("DETECTOR") + "_" + source->GetKeyValue("FILTER"));
					for (int i = 0; i < dir_list->Length; i++)
						if (::Directory::GetFiles(dir_list[i])->Length < discardtimeint)
							::Directory::Delete(dir_list[i],true);
				}

			}//end if IM mode

			skipto:;

			if (!::Directory::Exists(source->FilePath + "Digested L1\\"))
				::Directory::CreateDirectory(source->FilePath + "Digested L1\\");
			::File::Move(source->FullFileName,source->FilePath + "Digested L1\\" + source->FileName);
			//if (tctfileexists)
				//::File::Move(tctfile,source->FilePath + "Digested L1\\" + tctfile->Substring(tctfile->LastIndexOf("\\")));
			//because there's only one tct file for multiple l1 files, they must stay till the end and then be transferred

			//parity_error:;//continue main for loop
		}
	}
	catch (Exception^ e)
	{
		MessageBox::Show(e->Data + "	" + e->InnerException + "	" + e->Message + "	" + e->Source + "	" + e->StackTrace + "	" + e->TargetSite + "\n\r" + "File: " + argfiles[errorfileindex]);
	}
}

void Form1::UVITL1DigestWrkr_ProgressChanged(System::Object^  sender, System::ComponentModel::ProgressChangedEventArgs^  e)
{
	String^ mode = (String^)e->UserState;
	if (mode->Substring(0,2) == "PC")
	{
		int first = mode->IndexOf("_");
		WAITBAR->ProgressBar->Maximum = ::Convert::ToInt32(mode->Substring(first+1));
		WAITBAR->Text = "Digesting L1 PC File(s)...";
		WAITBAR->ProgressBar->Value = e->ProgressPercentage;
		WAITBAR->TextMsg->Text = String::Concat("Digesting file: ",e->ProgressPercentage," of ",WAITBAR->ProgressBar->Maximum);
	}
	if (mode->Substring(0,2) == "IM")
	{
		int first = mode->IndexOf("_");
		int last = mode->LastIndexOf("_");
		WAITBAR->Text = "Digesting L1 Files: " + mode->Substring(first+1,last-first-1) + " of " + mode->Substring(last+1);
		WAITBAR->ProgressBar->Maximum = 100;
		WAITBAR->ProgressBar->Value = e->ProgressPercentage;
		WAITBAR->TextMsg->Text = String::Concat("Extracting INT-mode frames: ",e->ProgressPercentage,"%");
	}
	WAITBAR->Refresh();
}

void Form1::UVITL1DigestWrkr_RunWorkerCompleted(System::Object^  sender, System::ComponentModel::RunWorkerCompletedEventArgs^  e)
{
	if (WAITBAR->DialogResult != ::DialogResult::Cancel)
	{
		if (L1DiscardDuplicateChck->Checked && e->Result != nullptr)//result = nullptr if only IM done
		{
			ArrayList^ dir_list = (ArrayList^)e->Result;
			WAITBAR->ProgressBar->Maximum = dir_list->Count-1;
			WAITBAR->Text = "Searching for duplicated data...";
			L1DiscardDuplicateWrkr->RunWorkerAsync(dir_list);
			//WAITBAR->ShowDialog(); already shown
		}
		else
		{
			TimeSpan ts = DateTime::Now - DATE;
			::MessageBox::Show("Completed digesting L1 data in " + ts.Minutes.ToString() + "m" + ts.Seconds.ToString() + "s.","Finished...");
			WAITBAR->Close();
			Form1::Enabled = true;
			Form1::Focus();
		}

		//move the tct files
		String^ dir = (String^)GetReg("L2EventListPath");//the tct files will be here
		array<String^>^ tctfiles = ::Directory::GetFiles(dir,"*level1.tct");
		for (int i = 0; i < tctfiles->Length; i++)
			::File::Move(tctfiles[i], dir + "\\Digested L1\\" + tctfiles[i]->Substring(tctfiles[i]->LastIndexOf("\\")));
	}
	else
	{
		Form1::Enabled = true;
		Form1::Focus();
	}
}

void Form1::L1DiscardDuplicateWrkr_DoWork(System::Object^  sender, System::ComponentModel::DoWorkEventArgs^  e)
{
	ArrayList^ dir_list = (ArrayList^)e->Argument;
	ArrayList^ delete_dir_list = gcnew ArrayList();
	FitsFile^ fitsi;
	array<double>^ fitsistart;
	array<double>^ fitsiend;
	FitsFile^ fitsj;
	array<double>^ fitsjstart;
	array<double>^ fitsjend;

	for (int i = 0; i < dir_list->Count-1; i++)
	{
		if (WAITBAR->DialogResult == ::DialogResult::Cancel)
			return;
		L1DiscardDuplicateWrkr->ReportProgress(i+1,delete_dir_list->Count);

		String^ diri = (String^)dir_list[i];
		String^ diritime = diri->Substring(diri->Length-10);
		array<String^>^ afilei = ::Directory::GetFiles(diri,"*TimeList*");
		String^ filei = afilei[0];
		fitsi = gcnew FitsFile(filei,nullptr,true,false,false);
		String^ detectori = fitsi->GetKeyValue("DETECTOR");
		String^ filteri = fitsi->GetKeyValue("FILTER");
		fitsistart = JPFits::FitsFile::ReadImageVectorOnly(filei, gcnew array<int>(4){0,0,0,0});
		fitsiend   = JPFits::FitsFile::ReadImageVectorOnly(filei, gcnew array<int>(4){0,0,fitsi->Height-1,fitsi->Height-1});

		for (int j = i+1; j < dir_list->Count; j++)
		{
			String^ dirj = (String^)dir_list[j];
			String^ dirjtime = dirj->Substring(dirj->Length-10);
			array<String^>^ afilej = ::Directory::GetFiles(dirj,"*TimeList*");
			String^ filej = afilej[0];
			fitsj = gcnew FitsFile(filej,nullptr,true,false,false);
			String^ detectorj = fitsj->GetKeyValue("DETECTOR");
			String^ filterj = fitsj->GetKeyValue("FILTER");

			if (detectori != detectorj || filteri != filterj)
				continue;

			if (diritime == dirjtime)
			//definitely duplicated data, delete the directory with smaller files...they start at the exact same time so delete the smaller one
			//or if they're the same size, then delete earlier one
			{	
				::FileStream^ fs = gcnew FileStream(filei,::IO::FileMode::Open);
				__int64 fli = fs->Length;
				fs->Close();
				fs = gcnew FileStream(filej,::IO::FileMode::Open);
				__int64 flj = fs->Length;
				fs->Close();

				if (flj < fli)
				{
					if (!delete_dir_list->Contains(dirj))
						delete_dir_list->Add(dirj);//delete the directory with smaller files
				}
				else
				{
					if (!delete_dir_list->Contains(diri))
						delete_dir_list->Add(diri);//delete the earlier directory
				}
				continue;
			}

			//check if times are overlapping - directory times are not the same, but there may be overlapping data within
			fitsjstart = JPFits::FitsFile::ReadImageVectorOnly(filej, gcnew array<int>(4){0,0,0,0});
			fitsjend   = JPFits::FitsFile::ReadImageVectorOnly(filej, gcnew array<int>(4){0,0,fitsj->Height-1,fitsj->Height-1});

			if (fitsistart[0] >= fitsjstart[0] && fitsistart[0] <= fitsjend[0])//then i starts within j...delete the directory with smaller files
			{
				::FileStream^ fs = gcnew FileStream(filei,::IO::FileMode::Open);
				__int64 fli = fs->Length;
				fs->Close();
				fs = gcnew FileStream(filej,::IO::FileMode::Open);
				__int64 flj = fs->Length;
				fs->Close();

				if (flj < fli)
				{
					if (!delete_dir_list->Contains(dirj))
						delete_dir_list->Add(dirj);//delete the directory with smaller files
				}
				else
				{
					if (!delete_dir_list->Contains(diri))
						delete_dir_list->Add(diri);//delete the earlier directory
				}
				continue;
			}

			if (fitsiend[0] >= fitsjstart[0] && fitsiend[0] <= fitsjend[0])//then i ends within j...delete the directory with smaller files
			{
				::FileStream^ fs = gcnew FileStream(filei,::IO::FileMode::Open);
				__int64 fli = fs->Length;
				fs->Close();
				fs = gcnew FileStream(filej,::IO::FileMode::Open);
				__int64 flj = fs->Length;
				fs->Close();

				if (flj < fli)
				{
					if (!delete_dir_list->Contains(dirj))
						delete_dir_list->Add(dirj);//delete the directory with smaller files
				}
				else
				{
					if (!delete_dir_list->Contains(diri))
						delete_dir_list->Add(diri);//delete the earlier directory
				}
				continue;
			}

			if (fitsjstart[0] >= fitsistart[0] && fitsjstart[0] <= fitsiend[0])//then j starts within i...delete the directory with smaller files
			{
				::FileStream^ fs = gcnew FileStream(filei,::IO::FileMode::Open);
				__int64 fli = fs->Length;
				fs->Close();
				fs = gcnew FileStream(filej,::IO::FileMode::Open);
				__int64 flj = fs->Length;
				fs->Close();

				if (flj < fli)
				{
					if (!delete_dir_list->Contains(dirj))
						delete_dir_list->Add(dirj);//delete the directory with smaller files
				}
				else
				{
					if (!delete_dir_list->Contains(diri))
						delete_dir_list->Add(diri);//delete the earlier directory
				}
				continue;
			}

			if (fitsjend[0] >= fitsistart[0] && fitsjend[0] <= fitsiend[0])//then j ends within i...delete the directory with smaller files
			{
				::FileStream^ fs = gcnew FileStream(filei,::IO::FileMode::Open);
				__int64 fli = fs->Length;
				fs->Close();
				fs = gcnew FileStream(filej,::IO::FileMode::Open);
				__int64 flj = fs->Length;
				fs->Close();

				if (flj < fli)
				{
					if (!delete_dir_list->Contains(dirj))
						delete_dir_list->Add(dirj);//delete the directory with smaller files
				}
				else
				{
					if (!delete_dir_list->Contains(diri))
						delete_dir_list->Add(diri);//delete the earlier directory
				}
				continue;
			}
		}
	}

	for (int w = 0; w < delete_dir_list->Count; w++)
	{
		try
		{
			::Directory::Delete((String^)delete_dir_list[w],true);
		}
		catch (...)
		{};
	}


	//need to check VIS directories...get them from the FUV/NUV upper object directory
	String^ objdir = ((String^)dir_list[0]);
	objdir = objdir->Substring(0,objdir->LastIndexOf("\\"));
	objdir = objdir->Substring(0,objdir->LastIndexOf("\\")) + "\\" + "VIS";
	array<String^>^ VISdirs = ::Directory::GetDirectories(objdir,"*VIS*");//there may be multiple VIS directories...go through them and check for repeated VIS files
	ArrayList^ del_file_list = gcnew ArrayList();

	array<String^>^ VISfiles = ::Directory::GetFiles(objdir,"*VIS*.fits",::SearchOption::AllDirectories);
	//for all VIS files, scan forward and delete the forward/secondary ones
	for (int j = 0; j < VISfiles->Length; j++)
	{
		String^ Jtime = VISfiles[j]->Substring(VISfiles[j]->LastIndexOf("_") + 1, 13);
		for (int k = j + 1; k < VISfiles->Length; k++)
		{
			String^ Ktime = VISfiles[k]->Substring(VISfiles[k]->LastIndexOf("_") + 1, 13);
			if (Ktime == Jtime)
			{
				del_file_list->Add(VISfiles[k]);
			}
		}
	}

	for (int i = 0; i < del_file_list->Count; i++)
		if (::File::Exists((String^)del_file_list[i]))
			::File::Delete((String^)del_file_list[i]);

	//now must check for directories which have been created but should actually be continuations
	//so sort the directories by time, then for each sorted directory, check the first and last files for continuation
	//if there is, then move the secondary files to the first directory, and delete the secondary directory
	try
	{
		array<double>^ VISdirtimes = gcnew array<double>(VISdirs->Length);
		for (int j = 0; j < VISdirs->Length; j++)
			VISdirtimes[j] = ::Convert::ToDouble(VISdirs[j]->Substring(VISdirs[j]->LastIndexOf("_") + 1));
		Array::Sort(VISdirtimes,VISdirs);
		//directories now sorted by start times

		ArrayList^ deldirlist = gcnew ArrayList();
		for (int j = 1; j < VISdirs->Length; j++)
		{
			array<String^>^ jm1files = ::Directory::GetFiles(VISdirs[j-1], "*VIS*.fits");
			array<String^>^ jfiles = ::Directory::GetFiles(VISdirs[j], "*VIS*.fits");
			Array::Sort(jm1files);
			Array::Sort(jfiles);
			double jm1fileendtime = ::Convert::ToDouble(jm1files[jm1files->Length-1]->Substring(jm1files[jm1files->Length-1]->LastIndexOf("_") + 1, 13));
			double jfilestartttime = ::Convert::ToDouble(jfiles[0]->Substring(jfiles[0]->LastIndexOf("_") + 1, 13));
			String^ jm1path = jm1files[0]->Substring(0,jm1files[0]->LastIndexOf("\\")) + "\\";

			if (jfilestartttime - jm1fileendtime <= 10*1000)//less than 10 seconds they should be the same sequence...1 ideally should be enough of a check
			{
				//then move the j files into j-1
				for (int k = 0; k < jfiles->Length; k++)
				{
					String^ jfile = jfiles[k]->Substring(jfiles[k]->LastIndexOf("\\") + 1);
					::File::Move(jfiles[k], jm1path + jfile);
				}
				deldirlist->Add(VISdirs[j]);
				//and skip the current directory on next iteration
				j++;
			}
		}
		//delete the empty directories
		for (int j = 0; j < deldirlist->Count; j++)
			::Directory::Delete((String^)deldirlist[j], true);
	}
	catch (Exception^ e)
	{
		MessageBox::Show(e->Data + "	" + e->InnerException + "	" + e->Message + "	" + e->Source + "	" + e->StackTrace + "	" + e->TargetSite);
	}
}

void Form1::L1DiscardDuplicateWrkr_ProgressChanged(System::Object^  sender, System::ComponentModel::ProgressChangedEventArgs^  e)
{
	WAITBAR->ProgressBar->Value = e->ProgressPercentage;
	WAITBAR->TextMsg->Text = "Checking directory " + e->ProgressPercentage.ToString() + " of " + WAITBAR->ProgressBar->Maximum.ToString() + ". Found " + ::Convert::ToInt32(e->UserState).ToString() + " duplicated data sets.";
	WAITBAR->Refresh();
}

void Form1::L1DiscardDuplicateWrkr_RunWorkerCompleted(System::Object^  sender, System::ComponentModel::RunWorkerCompletedEventArgs^  e)
{
	if (WAITBAR->DialogResult != ::DialogResult::Cancel)
	{
		TimeSpan ts = DateTime::Now - DATE;
		::MessageBox::Show("Completed digesting L1 data and discarding duplicated data in " + ts.Minutes.ToString() + "m" + ts.Seconds.ToString() + "s.","Finished...");
	}
	WAITBAR->Close();
	Form1::Enabled = true;
	Form1::Focus();
}

void Form1::DigestL2EventListMenuItem_Click(System::Object^  sender, System::EventArgs^  e)
{
	String^ dir = (String^)GetReg("L2EventListPath");
	OpenFileDialog^ dlg = gcnew OpenFileDialog();
	dlg->InitialDirectory = dir;
	dlg->Filter = "L2 Event List (*.events)|*.events";
	dlg->Title = "Please select the *.events list file...";
	dlg->Multiselect = false;

	if (dlg->ShowDialog() != ::DialogResult::OK)
		return;

	String^ file = dlg->FileName;
	dir = file->Substring(0,file->LastIndexOf("\\"));
	SetReg("L2EventListPath", dir);

	FitsFile^ source = gcnew FitsFile(file,nullptr,true,false,false);

	array<double>^ frams = ::FitsFile::ReadUVIT_L2BinaryExtensionTableColumn(file,"FrameCount");
	array<double>^ times = ::FitsFile::ReadUVIT_L2BinaryExtensionTableColumn(file,"Time");
	array<double>^ xints = ::FitsFile::ReadUVIT_L2BinaryExtensionTableColumn(file,"Ix");
	array<double>^ xdecs = ::FitsFile::ReadUVIT_L2BinaryExtensionTableColumn(file,"Fx");
	array<double>^ yints = ::FitsFile::ReadUVIT_L2BinaryExtensionTableColumn(file,"Iy");
	array<double>^ ydecs = ::FitsFile::ReadUVIT_L2BinaryExtensionTableColumn(file,"Fy");
	array<double>^ cdMms = ::FitsFile::ReadUVIT_L2BinaryExtensionTableColumn(file,"Max-Min");
	array<double>^ cmins = ::FitsFile::ReadUVIT_L2BinaryExtensionTableColumn(file,"Min");

	String^ obj_orb_chan;
	obj_orb_chan = dir + "//" + source->GetKeyValue("SOURCEID") + "_" + "Orb" + source->GetKeyValue("ORB_NUM") + "_" + source->GetKeyValue("DETECTOR");

	JPFits::FitsFile^ f = gcnew FitsFile(obj_orb_chan + "_FrameList.fits",frams,false);
	f->CopyHeader(source);
	f->WriteFile(::TypeCode::UInt16);

	for (int i = 0; i < times->Length; i++)
		times[i]*=1000;//make them in milliseconds
	f = gcnew FitsFile(obj_orb_chan + "_TimeList.fits",times,false);
	f->CopyHeader(source);
	f->WriteFile(::TypeCode::UInt32);

	array<double,2>^ ints = gcnew array<double,2>(2,xints->Length);
	for (int i = 0; i < xints->Length; i++)
	{
		ints[0,i] = xints[i]*32;
		ints[1,i] = yints[i]*32;
	}
	f = gcnew FitsFile(obj_orb_chan + "_XYInts_List.fits",ints,false);
	f->CopyHeader(source);
	f->WriteFile(::TypeCode::UInt16);

	array<double,2>^ frac = gcnew array<double,2>(2,xints->Length);
	for (int i = 0; i < xints->Length; i++)
	{
		frac[0,i] = xdecs[i]*32;
		frac[1,i] = ydecs[i]*32;
	}
	f = gcnew FitsFile(obj_orb_chan + "_XYFrac_List.fits",frac,false);
	f->CopyHeader(source);
	f->WriteFile(::TypeCode::Int16);

	array<double,2>^ mdMm = gcnew array<double,2>(2,xints->Length);
	for (int i = 0; i < xints->Length; i++)
	{
		mdMm[0,i] = cmins[i]*16;
		mdMm[1,i] = cdMms[i]*16;
	}
	f = gcnew FitsFile(obj_orb_chan + "_XYmdMm_List.fits",mdMm,false);
	f->CopyHeader(source);
	f->WriteFile(::TypeCode::Int16);

	FitsFile^ flat;
	String^ channel = f->GetKeyValue("CHANNEL");
	if (channel->Length == 0)
		channel = f->GetKeyValue("DETECTOR");
	bool flatsuccess = false;
	if (channel == "FUV")
		if (::File::Exists("C:\\UVIT_CalDB\\Flats Normalized\\FUV Normalized Flat.fits"))
		{
			flat = gcnew FitsFile("C:\\UVIT_CalDB\\Flats Normalized\\FUV Normalized Flat.fits", nullptr, true, true, false);
			flatsuccess = true;
		}
	if (channel == "NUV")
		if (::File::Exists("C:\\UVIT_CalDB\\Flats Normalized\\NUV Normalized Flat.fits"))
		{
			flat = gcnew FitsFile("C:\\UVIT_CalDB\\Flats Normalized\\NUV Normalized Flat.fits", nullptr, true, true, false);
			flatsuccess = true;
		}
	if (channel == "VIS")
		if (::File::Exists("C:\\UVIT_CalDB\\Flats Normalized\\VIS Normalized Flat.fits"))
		{
			flat = gcnew FitsFile("C:\\UVIT_CalDB\\Flats Normalized\\VIS Normalized Flat.fits", nullptr, true, true, false);
			flatsuccess = true;
		}
	if (flatsuccess)
	{
		array<double>^ flatlist = gcnew array<double>(xints->Length);

		for(int j = 0; j < xints->Length; j++)
			flatlist[j] = flat->Image[int(ints[0,j]/32),int(ints[1,j]/32)];

		String^ name = obj_orb_chan + "_FlatList.fits";
		FitsFile^ fitsflatlist = gcnew FitsFile(name, flatlist, false);
		fitsflatlist->CopyHeader(source);
		fitsflatlist->WriteFile(::TypeCode::Double);
	}

	::MessageBox::Show("Completed digesting L2 event list data.","Finished...");
}

void Form1::CreateFlatFieldListMenuItem_Click(System::Object^  sender, System::EventArgs^  e)
{
	String^ dir = (String^)GetReg("L2EventListPath");
	OpenFileDialog^ dlg = gcnew OpenFileDialog();
	dlg->InitialDirectory = dir;
	dlg->Filter = "FITS (*.fits)|*.fits";
	dlg->Multiselect = false;
	dlg->Title = "Select the Centroid INTEGERS List (_XYInts_List)";
	if (dlg->ShowDialog() != ::DialogResult::OK)
		return;
	String^ intslistfile = dlg->FileName;
	dir = intslistfile->Substring(0,intslistfile->LastIndexOf("\\"));
	SetReg("L2EventListPath", dir);
	FitsFile^ intsfits = gcnew JPFits::FitsFile(intslistfile,nullptr,true,true,false);


	dir = (String^)GetReg("CreateFlatPath");
	dlg = gcnew OpenFileDialog();
	dlg->InitialDirectory = dir;
	dlg->Filter = "FITS (*.fits)|*.fits";
	dlg->Multiselect = false;
	dlg->Title = "Select the FLAT FIELD IMAGE fits file";
	if (dlg->ShowDialog() != ::DialogResult::OK)
		return;
	String^ flatfile = dlg->FileName;
	dir = flatfile->Substring(0,flatfile->LastIndexOf("\\"));
	SetReg("CreateFlatPath", dir);
	FitsFile^ flat = gcnew FitsFile(flatfile, nullptr, true, true, false);

	int NPts = intsfits->Height;
	array<double>^ flatlist = gcnew array<double>(NPts);

	for(int j = 0; j < NPts; j++)
		flatlist[j] = flat->Image[int(intsfits->Image[0,j]/32),int(intsfits->Image[1,j]/32)];

	String^ name = intslistfile->Substring(0,intslistfile->IndexOf("XYInts")) + "FlatList.fits";
	FitsFile^ fitsflatlist = gcnew FitsFile(name, flatlist, false);
	fitsflatlist->CopyHeader(intsfits);
	fitsflatlist->WriteFile(::TypeCode::Double);

	::MessageBox::Show("Completed making the flat field list.","Finished...");
}

void Form1::ParcelStackTimeDrop_Click(System::Object^  sender, System::EventArgs^  e)
{
	String^ time = (String^)ParcelStackTimeDrop->SelectedItem;
	time = time->Remove(time->IndexOf("s"));
	UVPARCELTIME = ::Convert::ToDouble(time);

	if (UVPARCELTIME == 0)
		if (::MessageBox::Show("Parcelling out each frame as a file can create an extremely large number of files. Are you sure?","Warning...",::MessageBoxButtons::YesNo) == ::DialogResult::No)
			return;

	String^ dir = (String^)GetReg("L2EventListPath");
	OpenFileDialog^ dlg = gcnew OpenFileDialog();
	dlg->InitialDirectory = dir;
	dlg->Filter = "FITS (*.fits)|*.fits";
	dlg->Multiselect = false;
	dlg->Title = "Select the Centroid TIME List (_TimeList)";
	if (dlg->ShowDialog() != ::DialogResult::OK)
		return;
	String^ timelistfile = dlg->FileName;
	dir = timelistfile->Substring(0,timelistfile->LastIndexOf("\\"));
	SetReg("L2EventListPath", dir);

	dlg->Title = "Select the Centroid INTEGERS List (_XYInts_List)";
	if (dlg->ShowDialog() != ::DialogResult::OK)
		return;
	String^ intslistfile = dlg->FileName;
	
	::FolderBrowserDialog^ fb = gcnew ::FolderBrowserDialog();
	fb->SelectedPath = dir;
	if (fb->ShowDialog() != ::DialogResult::OK)
		return;
	String^ parceldir = fb->SelectedPath + "\\";
	SetReg("FolderBrowserPath", fb->SelectedPath);

	//ok so now send the filenames and dir to the worker arg, load the fits files and arrays there
	array<Object^>^ arg = gcnew array<Object^>(3);
	arg[0] = (Object^)timelistfile;
	arg[1] = (Object^)intslistfile;
	arg[2] = (Object^)parceldir;
	Form1::Enabled = false;
	WAITBAR = gcnew JPWaitBar::WaitBar();
	WAITBAR->ProgressBar->Maximum = 100;
	WAITBAR->DialogResult = ::DialogResult::OK;
	WAITBAR->Text = "Parcelling List...";
	UVParcelWrkr->RunWorkerAsync(arg);
	WAITBAR->Show();
}

void Form1::UVParcelWrkr_DoWork(System::Object^  sender, System::ComponentModel::DoWorkEventArgs^  e)
{
	array<Object^>^ arg = (array<Object^>^)e->Argument;
	String^ timeslistfile = (String^)arg[0];
	String^ intslistfile = (String^)arg[1];
	String^ fraclistfile = intslistfile->Replace("Ints","Frac");
	String^ parceldir = (String^)arg[2];

	FitsFile^ timeslist = gcnew JPFits::FitsFile(timeslistfile,nullptr,true,false,false);
	array<double>^ times = FitsFile::ReadImageVectorOnly(timeslistfile,nullptr);

	FitsFile^ intslist = gcnew JPFits::FitsFile(intslistfile,nullptr,true,false,false);
	array<double,2>^ ints = FitsFile::ReadImageArrayOnly(intslistfile, nullptr);
	
	FitsFile^ fraclist = gcnew JPFits::FitsFile(fraclistfile,nullptr,true,false,false);
	array<double,2>^ frac = FitsFile::ReadImageArrayOnly(fraclistfile, nullptr);

	String^ EXTXRNG = fraclist->GetKeyValue("EXTXRNG");//from GSE CCDLAB processing
	if (EXTXRNG == "")
		EXTXRNG = "0:511";//from L2 data
	String^ EXTYRNG = fraclist->GetKeyValue("EXTYRNG");//from GSE CCDLAB processing
	if (EXTYRNG == "")
		EXTYRNG = "0:511";//from L2 data
	int ix = EXTXRNG->IndexOf(":");
	int iy = EXTYRNG->IndexOf(":");
	double rx1 = ::Convert::ToDouble(EXTXRNG->Substring(0,ix));//range start
	double ry1 = ::Convert::ToDouble(EXTYRNG->Substring(0,iy));
	double rx2 = ::Convert::ToDouble(EXTXRNG->Substring(ix+1));//range end
	double ry2 = ::Convert::ToDouble(EXTYRNG->Substring(iy+1));

	String^ xoffset = intslist->GetKeyValue("XOFFSET");//from GSE CCCDLAB processing
	if (xoffset == "")
		xoffset = intslist->GetKeyValue("WIN_XOFF");//from L2 data
	double ox = ::Convert::ToDouble(xoffset);//x offset
	String^ yoffset = intslist->GetKeyValue("YOFFSET");//from GSE CCCDLAB processing
	if (yoffset == "")
		yoffset = intslist->GetKeyValue("WIN_YOFF");//from L2 data
	double oy = ::Convert::ToDouble(yoffset);//y offset
	String^ sizex = intslist->GetKeyValue("XSIZE");
	if (sizex == "")
		sizex = intslist->GetKeyValue("WIN_X_SZ");
	double szx = ::Convert::ToDouble(sizex);//x size
	String^ sizey = intslist->GetKeyValue("YSIZE");
	if (sizey == "")
		sizey = intslist->GetKeyValue("WIN_Y_SZ");
	double szy = ::Convert::ToDouble(sizey);//y size

	if (rx1 != 0 && rx2 != 511)
			szx = rx2-rx1;
	if (ry1 != 0 && ry2 != 511)
		szy = ry2-ry1;

	double prec = UVLISTTOIMAGEPREC;
	szx = (szx + 1)*prec;
	szy = (szy + 1)*prec;

	String^ str = "Each image will be " + Math::Round(szx*szy*8/1024/1024,5).ToString() + "MB.  Are you sure you can do this?";

	if (::MessageBox::Show(str, "Warning...", ::MessageBoxButtons::YesNo) == ::DialogResult::No)
	{
		WAITBAR->CancelBtn->PerformClick();
		return;	
	}

	array<int,2>^ img;

	array<int>^ foundinds;
	int ind = -1;
	int Ntimes = times->Length;
	int Nfound;
	int xpos, ypos;
	FitsFile^ stackimg;
	String^ parcelname;
	int c = 0;
	unsigned __int32 currtime = 0;
	int intprog = 0;
	bool end = false;//the routine will have to tell when it is at the end of the time list
	while (!end)
	{
		if (WAITBAR->DialogResult == ::DialogResult::Cancel)
			return;
		if (100*ind/Ntimes > intprog+1)
		{
			intprog++;
			UVParcelWrkr->ReportProgress(intprog);
		}

		c++;
		currtime = (unsigned __int32)times[ind+1];
		img = gcnew array<int,2>((int)szx,(int)szy);
		foundinds = JPMath::Find(times, times[ind+1]+UVPARCELTIME*1000, "<=", ind+1);
		if (foundinds->Length == 0)
			goto nonefound;
		Nfound = foundinds->Length;
		ind = foundinds[Nfound-1];
		if (ind == Ntimes-1)
			end = true;

		int j;
		try
		{
			for (j = 0; j < Nfound; j++)
			{
				/*xpos = (int)((ints[0,foundinds[j]] - ox*32)/32);
				ypos = (int)((ints[1,foundinds[j]] - oy*32)/32);*/

				xpos = (int)((ints[0,foundinds[j]] - rx1*32 - ox*32 + frac[0,foundinds[j]] + 16)/32 * prec);//reset integers to start at 0
				ypos = (int)((ints[1,foundinds[j]] - ry1*32 - oy*32 + frac[1,foundinds[j]] + 16)/32 * prec);//must add 16 to fractionals

				if (xpos < 0 || ypos < 0 || xpos > szx-1 || ypos > szy-1)//ignore out of bounds
					continue;

				img[xpos,ypos]++;
			}
		}
		catch (::Exception^ e)
		{
			::MessageBox::Show(e->Message + "   " + xpos.ToString() + "   " + ypos.ToString() + "    "   + j.ToString());
		}

		nonefound:;

		parcelname = parceldir + currtime.ToString("000000000000000") + ".fits";
		stackimg = gcnew FitsFile(parcelname,img,false);
		stackimg->CopyHeader(intslist);
		stackimg->AddKey("PARCTIME", currtime.ToString("000000000000000"), "Parcel time.", 10);
		stackimg->AddKey("FRMTIME", (double(currtime)/1000).ToString(), "Frame time.", 11);
		stackimg->WriteFile(::TypeCode::UInt16);
	}
}

void Form1::UVParcelWrkr_ProgressChanged(System::Object^  sender, System::ComponentModel::ProgressChangedEventArgs^  e)
{
	WAITBAR->ProgressBar->Value = e->ProgressPercentage;
	WAITBAR->TextMsg->Text = String::Concat("Completed: ",e->ProgressPercentage,"%");
	WAITBAR->Refresh();
}

void Form1::UVParcelWrkr_RunWorkerCompleted(System::Object^  sender, System::ComponentModel::RunWorkerCompletedEventArgs^  e)
{
	WAITBAR->Close();
	Form1::Enabled = true;
	Form1::Focus();
	if (WAITBAR->DialogResult != ::DialogResult::Cancel)
		::MessageBox::Show("Parcelling Completed...","Finished...");
}

void Form1::PlotDriftListMenuItem_Click(System::Object^  sender, System::EventArgs^  e)
{
	String^ driftlistfile;
	if (UVPLOTDRIFTLISTNOW)
	{
		UVPLOTDRIFTLISTNOW = false;
		driftlistfile = UVPLOTDRIFTFILENAME;
	}
	else
	{
		String^ dir = (String^)GetReg("L2EventListPath");
		OpenFileDialog^ dlg = gcnew OpenFileDialog();
		dlg->InitialDirectory = dir;
		dlg->Filter = "DRIFT (*.drift)|*.drift";
		dlg->Multiselect = false;
		dlg->Title = "Select the Drift List (_XYDrift_List)";
		if (dlg->ShowDialog() != ::DialogResult::OK)
			return;
		driftlistfile = dlg->FileName;
	}

	FitsFile^ driftfits = gcnew JPFits::FitsFile(driftlistfile,nullptr,true,true,false);

	//only want to plot unique times or else 10,000's data to be plotted which is slow
	int unique = 0;
	double timecheck = -1;
	for (int i = 0; i < driftfits->Height; i++)
	{
		if (timecheck == driftfits->Image[0,i])
			continue;
		
		unique++;
		timecheck = driftfits->Image[0,i];
	}
	//now unique is how many unique time there are, so make arrays for time, x, y

	array<double>^ time	  = gcnew array<double>(unique);
	array<double>^ xdrift = gcnew array<double>(unique);
	array<double>^ ydrift = gcnew array<double>(unique);

	timecheck = -1;
	unique = -1;//now an index
	for (int i = 0; i < driftfits->Height; i++)
	{
		if (timecheck == driftfits->Image[0,i])
			continue;

		unique++;
		timecheck = driftfits->Image[0,i];

		time[unique]   = driftfits->Image[0,i]/1000;
		xdrift[unique] = driftfits->Image[1,i]/32;
		ydrift[unique] = driftfits->Image[2,i]/32;
	}

	String^ title = "Orbit: " + driftfits->GetKeyValue("ORB_NUM") + "; Source: " + driftfits->GetKeyValue("SOURCEID") + "; Detector:" + driftfits->GetKeyValue("DETECTOR");

	if (XDRIFT_PLOT->IsDisposed)
		XDRIFT_PLOT = gcnew JPPlot();
	if (YDRIFT_PLOT->IsDisposed)
		YDRIFT_PLOT = gcnew JPPlot();

	XDRIFT_PLOT->Text = "X-Drift";
	XDRIFT_PLOT->PlotLine(time,xdrift,"Time (seconds)","X-Drift (pixels)",title, Charting::SeriesChartType::Line);
	if (XDRIFT_PLOT->plotchart1->AxesGridMenuChck->Checked == false)
		XDRIFT_PLOT->plotchart1->AxesGridMenuChck->PerformClick();
	YDRIFT_PLOT->Text = "Y-Drift";
	YDRIFT_PLOT->PlotLine(time,ydrift,"Time (seconds)","Y-Drift (pixels)",title, Charting::SeriesChartType::Line);
	if (YDRIFT_PLOT->plotchart1->AxesGridMenuChck->Checked == false)
		YDRIFT_PLOT->plotchart1->AxesGridMenuChck->PerformClick();
}

